<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Overview | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex min-h-screen flex-col md:h-screen md:flex-row overflow-x-hidden md:overflow-hidden antialiased selection:bg-white/30">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:p-4 focus:bg-white focus:text-black focus:font-semibold">Skip to content</a>

  <%- include('partials/admin-sidebar', { activePage: 'overview' }) %>

  <!-- Main Content -->
  <main id="main-content" class="flex-1 flex min-h-0 flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <!-- Header -->
    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-white font-medium tracking-tight">Admin</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span>Dashboard</span>
      </div>
      <div class="flex items-center gap-4">
        <div class="h-8 w-8 rounded-full bg-white/10 border border-white/20 flex items-center justify-center">
          <span class="material-symbols-outlined text-[16px] text-white">person</span>
        </div>
      </div>
    </header>

    <!-- Scrollable content -->
    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-6xl mx-auto space-y-10">
        
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-white mb-2">Overview</h1>
          <p class="text-gray-400 font-light text-sm">Platform Statistics</p>
        </div>

        <!-- Dashboard Widgets -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          
          <!-- Widget 1 -->
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all"></div>
            <div class="flex items-center justify-between mb-4 relative z-10">
              <span class="text-sm font-medium text-gray-400">Total Active Question Banks</span>
              <span class="material-symbols-outlined text-gray-500">folder_open</span>
            </div>
            <div class="text-4xl font-semibold tracking-tighter text-white relative z-10">
              <%= ((stats.banks || 0) + (stats.codingBanks || 0)) %>
            </div>
          </div>

          <!-- Widget 2 -->
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-24 h-24 bg-green-500/10 rounded-full blur-2xl group-hover:bg-green-500/20 transition-all"></div>
            <div class="flex items-center justify-between mb-4 relative z-10">
              <span class="text-sm font-medium text-gray-400">Total Tests</span>
              <span class="material-symbols-outlined text-gray-500">sensors</span>
            </div>
            <div class="text-4xl font-semibold tracking-tighter text-white relative z-10">
              <%= ((stats.tests || 0) + (stats.codingTests || 0)) %>
            </div>
          </div>

          <!-- Widget 3 -->
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-all"></div>
            <div class="flex items-center justify-between mb-4 relative z-10">
              <span class="text-sm font-medium text-gray-400">Total Coding Challenges</span>
              <span class="material-symbols-outlined text-gray-500">code_blocks</span>
            </div>
            <div class="text-4xl font-semibold tracking-tighter text-white relative z-10">
              <%= stats.codingChallenges || 0 %>
            </div>
          </div>

          <!-- Widget 4 -->
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-24 h-24 bg-yellow-500/10 rounded-full blur-2xl group-hover:bg-yellow-500/20 transition-all"></div>
            <div class="flex items-center justify-between mb-4 relative z-10">
              <span class="text-sm font-medium text-gray-400">Status</span>
              <span class="material-symbols-outlined text-gray-500">moving</span>
            </div>
            <div class="text-4xl font-semibold tracking-tighter text-green-400 flex items-baseline gap-1 relative z-10">
              Operational
            </div>
          </div>

        </div>

        <hr class="border-white/10 my-8">
        
        <div class="glass-card rounded-2xl p-8 flex flex-col md:flex-row items-center justify-between gap-6">
           <div>
             <h3 class="text-lg font-medium text-white mb-1">Quick Navigation</h3>
             <p class="text-sm text-gray-400 font-light max-w-xl leading-relaxed">Use the sidebar to manage different sections of the platform. Both MCQ and Coding modules are available.</p>
           </div>
           <a href="/admin/banks" class="shrink-0 bg-white text-black hover:bg-gray-200 px-6 py-3 rounded-full text-sm font-semibold transition-colors">
             Go to Banks
           </a>
        </div>

      </div>
    </div>
  </main>
</body>
</html>
