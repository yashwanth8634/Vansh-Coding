<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Environments | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="/css/vansh2k26-theme.css">
  
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #000000; color: #ffffff; }
    
    .glass-sidebar { background: rgba(10, 10, 10, 0.8); border-right: 1px solid rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); }
    .glass-nav { background: rgba(0, 0, 0, 0.6); border-bottom: 1px solid rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); }
    
    .glass-card { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.08); transition: all 0.2s ease-out; }
    .glass-card:hover { background: rgba(255, 255, 255, 0.03); border-color: rgba(255, 255, 255, 0.12); }

    .nav-item { color: #888; transition: all 0.2s; }
    .nav-item:hover { color: #fff; background: rgba(255,255,255,0.05); }
    .nav-item.active { color: #fff; background: rgba(255,255,255,0.1); font-weight: 500; }
    
    .grid-bg {
      background-size: 40px 40px;
      background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                        linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
  </style>
</head>
<body class="vc-admin flex h-screen overflow-hidden antialiased selection:bg-white/30">

  <aside class="w-20 md:w-64 glass-sidebar flex flex-col shrink-0 z-20">
    <div class="h-16 flex items-center justify-center md:justify-start md:px-6 border-b border-white/10 shrink-0">
      <span class="material-symbols-outlined text-[24px] text-white">terminal</span>
      <span class="ml-3 font-semibold tracking-tight text-white hidden md:block">VanshCoding Admin</span>
    </div>
    
    <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-2">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3 hidden md:block">Main</div>
      <a href="/admin" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">space_dashboard</span>
        <span class="text-sm hidden md:block">Overview</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">MCQ Section</div>
      <a href="/admin/banks" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">folder_open</span>
        <span class="text-sm hidden md:block">Question Banks</span>
      </a>
      <a href="/admin/tests" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">link</span>
        <span class="text-sm hidden md:block">Tests</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">Coding Section</div>
      <a href="/admin/coding/banks" class="nav-item active flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">data_object</span>
        <span class="text-sm hidden md:block">Coding Environments</span>
      </a>
      <a href="/admin/coding/tests" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">api</span>
        <span class="text-sm hidden md:block">Coding Sessions</span>
      </a>
      <a href="/admin/coding" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">code_blocks</span>
        <span class="text-sm hidden md:block">Coding Challenges</span>
      </a>
    </nav>
    
    <div class="p-4 border-t border-white/10 shrink-0">
      <form action="/api/admin/logout" method="POST">
        <button type="submit" class="w-full flex items-center justify-center md:justify-start gap-3 px-3 py-2.5 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors">
          <span class="material-symbols-outlined text-[20px]">logout</span>
          <span class="text-sm font-medium hidden md:block">Sign Out</span>
        </button>
      </form>
    </div>
  </aside>

  <main class="flex-1 flex flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">Coding Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Coding Environments</span>
      </div>
      
      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/coding/banks" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Environments</a>
        <a href="/admin/coding/tests" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Sessions</a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-8">
        
        <div class="xl:col-span-4 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Create Environment</h1>
            <p class="text-gray-400 font-light text-sm">Create a new coding environment.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-yellow-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <form id="createBankForm" class="space-y-5 relative z-10">
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Environment Name</label>
                <input type="text" id="bankName" required 
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
                  placeholder="e.g., SDE Intern Screener">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Description</label>
                <input type="text" id="bankDesc"
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
                  placeholder="Optional">
              </div>
              <button type="submit" class="w-full bg-white text-black hover:bg-gray-200 py-3 px-4 rounded-xl text-sm font-semibold transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.98] flex justify-center items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">add</span> Create Environment
              </button>
            </form>
          </div>
        </div>

        <div class="xl:col-span-8 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Existing Environments</h1>
            <p class="text-gray-400 font-light text-sm">Manage your coding environments.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-2 h-max max-h-[calc(100vh-250px)] overflow-y-auto">
            <div class="space-y-2 p-2">
              <% banks.forEach(bank => { %>
                <div class="bg-black/40 border border-white/5 hover:border-white/10 hover:bg-white/5 p-5 rounded-xl flex flex-col gap-4 transition-all group">
                  <div class="flex justify-between items-start">
                    <div>
                      <strong class="text-base font-medium text-white block mb-1"><%= bank.title %></strong>
                      <span class="text-sm text-gray-400 tracking-wide block mb-3"><%= bank.description %></span>
                      <div class="flex items-center gap-2 text-xs">
                         <span class="inline-flex items-center bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 px-2 py-0.5 rounded font-semibold uppercase tracking-wider">
                           <%= bank.challenges ? bank.challenges.length : 0 %> Attached Challenges
                         </span>
                      </div>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <button onclick="deleteBank('<%= bank._id %>')" class="bg-transparent text-gray-500 hover:text-red-400 hover:bg-red-500/10 border border-transparent hover:border-red-500/20 p-2 rounded-lg transition-colors flex items-center justify-center">
                        <span class="material-symbols-outlined text-[18px]">delete</span>
                      </button>
                    </div>
                  </div>
                  
                  <div class="border-t border-white/10 pt-4 mt-1">
                    <form onsubmit="addChallenge(event, '<%= bank._id %>')" class="flex gap-2">
                      <select name="challengeId" required class="flex-1 px-3 py-2 bg-[#0a0a0a] border border-white/10 rounded-lg text-sm text-gray-300 outline-none appearance-none focus:border-white/30">
                        <option value="">Attach Challenge to Environment...</option>
                        <% challenges.forEach(c => { %>
                          <% const isAttached = bank.challenges && bank.challenges.some(bc => bc._id.toString() === c._id.toString()); %>
                          <% if(!isAttached) { %>
                            <option value="<%= c._id %>"><%= c.title %> (<%= c.difficulty %>)</option>
                          <% } %>
                        <% }); %>
                      </select>
                      <button type="submit" class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors border border-white/10">
                        Attach
                      </button>
                    </form>
                    
                    <div class="mt-3 space-y-1">
                      <% if(bank.challenges && bank.challenges.length > 0) { %>
                        <% bank.challenges.forEach(c => { %>
                          <div class="flex justify-between items-center text-sm bg-black/50 p-2 px-3 rounded-md border border-white/5">
                            <span class="text-gray-300"><%= c.title %></span>
                            <button onclick="removeChallenge('<%= bank._id %>', '<%= c._id %>')" class="text-gray-500 hover:text-red-400">
                              <span class="material-symbols-outlined text-[16px]">close</span>
                            </button>
                          </div>
                        <% }) %>
                      <% } %>
                    </div>
                  </div>

                </div>
              <% }); %>
              <% if(banks.length === 0) { %>
                <div class="text-gray-500 text-center py-16 text-sm font-medium bg-black/20 rounded-xl border border-dashed border-white/10 flex flex-col items-center">
                  <span class="material-symbols-outlined text-4xl mb-3 opacity-50">data_object</span>
                  No coding environments found.
                </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <script>
    document.getElementById('createBankForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Processing...';
      btn.disabled = true;

      const n = document.getElementById('bankName').value, d = document.getElementById('bankDesc').value;
      const res = await fetch('/api/coding/admin/banks', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: n, description: d }) });
      if(res.ok) window.location.reload(); 
      else { alert('Failed to create coding environment.'); btn.innerHTML = originalText; btn.disabled = false; }
    });

    async function addChallenge(e, bankId) {
      e.preventDefault();
      const cid = e.target.challengeId.value;
      const res = await fetch(`/api/coding/admin/banks/${bankId}/challenges`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ challengeId: cid })
      });
      if(res.ok) window.location.reload();
    }

    async function removeChallenge(bankId, challengeId) {
      if(confirm('Detach this challenge from the environment?')) {
        const res = await fetch(`/api/coding/admin/banks/${bankId}/challenges/${challengeId}`, { method: 'DELETE' });
        if(res.ok) window.location.reload();
      }
    }

    async function deleteBank(id) {
      if(confirm('Are you sure you want to delete this environment?')) {
        const res = await fetch(`/api/coding/admin/banks/${id}`, { method: 'DELETE' });
        if(res.ok) window.location.reload();
      }
    }
  </script>
</body>
</html>
