<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Environments | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex min-h-screen flex-col md:h-screen md:flex-row overflow-x-hidden md:overflow-hidden antialiased selection:bg-white/30">

  <%- include('partials/admin-sidebar', { activePage: 'coding-banks' }) %>

  <main class="flex-1 flex min-h-0 flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">Coding Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Coding Environments</span>
      </div>
      
      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/coding/banks" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Environments</a>
        <a href="/admin/coding/tests" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Sessions</a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-8">
        
        <div class="xl:col-span-4 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Create Environment</h1>
            <p class="text-gray-400 font-light text-sm">Create a new coding environment.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-yellow-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <form id="createBankForm" class="space-y-5 relative z-10">
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Environment Name</label>
                <input type="text" id="bankName" required 
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
                  placeholder="e.g., SDE Intern Screener">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Description</label>
                <input type="text" id="bankDesc"
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
                  placeholder="Optional">
              </div>
              <button type="submit" class="btn-primary btn-block">
                <span class="material-symbols-outlined text-[18px]">add</span> Create Environment
              </button>
            </form>
          </div>
        </div>

        <div class="xl:col-span-8 space-y-6">
          <div>
            <h2 class="text-2xl font-semibold tracking-tight text-white mb-2">Existing Environments</h2>
            <p class="text-gray-400 font-light text-sm">Manage your coding environments.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-2 h-max md:max-h-[calc(100vh-250px)] overflow-y-auto">
            <div class="space-y-2 p-2">
              <% banks.forEach(bank => { %>
                <div class="bg-black/40 border border-white/5 hover:border-white/10 hover:bg-white/5 p-5 rounded-xl flex flex-col gap-4 transition-all group">
                  <div class="flex justify-between items-start">
                    <div>
                      <strong class="text-base font-medium text-white block mb-1"><%= bank.title %></strong>
                      <% if (bank.description) { %>
                        <span class="text-sm text-gray-400 tracking-wide block mb-3 whitespace-pre-wrap"><%= bank.description %></span>
                      <% } %>
                      <div class="flex items-center gap-2 text-xs">
                         <span class="inline-flex items-center bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 px-2 py-0.5 rounded font-semibold uppercase tracking-wider">
                           <%= bank.challenges ? bank.challenges.length : 0 %> Attached Challenges
                         </span>
                      </div>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                      <button data-action="delete-env" data-id="<%= bank._id %>" class="btn-danger btn-icon btn-sm" type="button" aria-label="Delete environment" title="Delete environment">
                        <span class="material-symbols-outlined text-[18px]">delete</span>
                      </button>
                    </div>
                  </div>
                  
                  <div class="border-t border-white/10 pt-4 mt-1">
                    <form data-action="attach-challenge" data-bank="<%= bank._id %>" class="flex gap-2">
                      <select name="challengeId" required class="flex-1 px-3 py-2 bg-[#0a0a0a] border border-white/10 rounded-lg text-sm text-gray-300 outline-none appearance-none focus:border-white/30">
                        <option value="">Attach Challenge to Environment...</option>
                        <% const attachedIds = new Set((bank.challenges || []).map(bc => bc._id.toString())); %>
                        <% challenges.forEach(c => { %>
                          <% if(!attachedIds.has(c._id.toString())) { %>
                            <option value="<%= c._id %>"><%= c.title %> (<%= c.difficulty %>)</option>
                          <% } %>
                        <% }); %>
                      </select>
                      <button type="submit" class="btn-secondary btn-sm">
                        Attach
                      </button>
                    </form>
                    
                    <div class="mt-3 space-y-1">
                      <% if(bank.challenges && bank.challenges.length > 0) { %>
                        <% bank.challenges.forEach(c => { %>
                          <div class="flex justify-between items-center text-sm bg-black/50 p-2 px-3 rounded-md border border-white/5">
                            <span class="text-gray-300"><%= c.title %></span>
                            <button data-action="remove-challenge" data-env="<%= bank._id %>" data-challenge="<%= c._id %>" class="btn-danger btn-icon btn-sm" type="button" aria-label="Remove challenge" title="Remove puzzle">
                              <span class="material-symbols-outlined text-[16px]">close</span>
                            </button>
                          </div>
                        <% }) %>
                      <% } %>
                    </div>
                  </div>

                </div>
              <% }); %>
              <% if(banks.length === 0) { %>
                <div class="text-gray-500 text-center py-16 text-sm font-medium bg-black/20 rounded-xl border border-dashed border-white/10 flex flex-col items-center">
                  <span class="material-symbols-outlined text-4xl mb-3 opacity-50">data_object</span>
                  No coding environments found.
                </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <script>
    function showToast(message, type = 'error') {
      const existing = document.getElementById('vc-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.id = 'vc-toast';
      const color = type === 'error' ? 'border-red-500/30 text-red-500 bg-red-500/10' : 'border-green-500/30 text-green-500 bg-green-500/10';
      toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-5 py-3 rounded-xl glass-card border ${color} text-sm font-medium shadow-xl transition-all duration-300`;
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => { if (document.getElementById('vc-toast')) toast.remove() }, 4000);
    }

    async function getErrorMessage(res, fallback) {
      try {
        const data = await res.json();
        return data.message || fallback;
      } catch (error) {
        return fallback;
      }
    }

    document.getElementById('createBankForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Processing...';

      const title = document.getElementById('bankName').value, description = document.getElementById('bankDesc').value;
      try {
        const res = await fetch('/api/coding/admin/banks', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, description }) });
        if(res.ok) { window.location.reload(); }
        else { showToast(await getErrorMessage(res, 'Failed to create coding environment.')); btn.innerHTML = originalText; btn.disabled = false; }
      } catch (err) {
        showToast('Network error: ' + err.message);
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });

    document.addEventListener('submit', async (e) => {
      const attachForm = e.target.closest('[data-action="attach-challenge"]');
      if (attachForm) {
        e.preventDefault();
        const bankId = attachForm.dataset.bank;
        const button = attachForm.querySelector('button[type="submit"]');
        const originalText = button.innerHTML;
        if (button) {
          button.disabled = true;
          button.innerHTML = '<span class="material-symbols-outlined animate-spin text-[16px]">sync</span>';
        }
        const cid = attachForm.challengeId.value;
        
        try {
          const res = await fetch(`/api/coding/admin/banks/${bankId}/challenges`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ challengeId: cid })
          });
          if(res.ok) window.location.reload();
          else {
            if (button) { button.disabled = false; button.innerHTML = originalText; }
            showToast(await getErrorMessage(res, 'Failed to attach challenge.'));
          }
        } catch (err) {
          if (button) { button.disabled = false; button.innerHTML = originalText; }
          showToast('Network error: ' + err.message);
        }
      }
    });

    document.addEventListener('click', async (e) => {
      // HANDLE DELETE ENV
      const deleteEnvBtn = e.target.closest('[data-action="delete-env"]');
      if (deleteEnvBtn && !deleteEnvBtn.dataset.confirmPending) {
        deleteEnvBtn.dataset.confirmPending = 'true';
        deleteEnvBtn.innerHTML = '<span class="material-symbols-outlined text-[14px]">check</span>';
        deleteEnvBtn.title = 'Click again to confirm delete';
        deleteEnvBtn.classList.remove('btn-danger');
        deleteEnvBtn.classList.add('bg-red-500/40', 'border-red-500', 'text-red-100');
        
        setTimeout(() => {
          if (deleteEnvBtn.dataset.confirmPending) {
              delete deleteEnvBtn.dataset.confirmPending;
              deleteEnvBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
              deleteEnvBtn.title = 'Delete environment';
              deleteEnvBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
              deleteEnvBtn.classList.add('btn-danger');
          }
        }, 3000);
        return;
      }

      const confirmEnvBtn = e.target.closest('[data-action="delete-env"][data-confirm-pending]');
      if (confirmEnvBtn) {
        const id = confirmEnvBtn.dataset.id;
        delete confirmEnvBtn.dataset.confirmPending;
        confirmEnvBtn.disabled = true;
        confirmEnvBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span>';
        try {
          const res = await fetch(`/api/coding/admin/banks/${id}`, { method: 'DELETE' });
          if(res.ok) window.location.reload();
          else {
            confirmEnvBtn.disabled = false;
            showToast(await getErrorMessage(res, 'Failed to delete environment.'));
            confirmEnvBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
            confirmEnvBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
            confirmEnvBtn.classList.add('btn-danger');
          }
        } catch (err) {
          confirmEnvBtn.disabled = false;
          showToast('Network error: ' + err.message);
          confirmEnvBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
          confirmEnvBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
          confirmEnvBtn.classList.add('btn-danger');
        }
        return;
      }

      // HANDLE REMOVE CHALLENGE
      const removeChalBtn = e.target.closest('[data-action="remove-challenge"]');
      if (removeChalBtn && !removeChalBtn.dataset.confirmPending) {
        removeChalBtn.dataset.confirmPending = 'true';
        removeChalBtn.innerHTML = '<span class="material-symbols-outlined text-[14px]">check</span>';
        removeChalBtn.title = 'Click again to detach challenge';
        removeChalBtn.classList.remove('btn-danger');
        removeChalBtn.classList.add('bg-red-500/40', 'border-red-500', 'text-red-100');
        
        setTimeout(() => {
          if (removeChalBtn.dataset.confirmPending) {
              delete removeChalBtn.dataset.confirmPending;
              removeChalBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">close</span>';
              removeChalBtn.title = 'Remove puzzle';
              removeChalBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
              removeChalBtn.classList.add('btn-danger');
          }
        }, 3000);
        return;
      }

      const confirmRemoveBtn = e.target.closest('[data-action="remove-challenge"][data-confirm-pending]');
      if (confirmRemoveBtn) {
        const bankId = confirmRemoveBtn.dataset.env;
        const challengeId = confirmRemoveBtn.dataset.challenge;
        delete confirmRemoveBtn.dataset.confirmPending;
        confirmRemoveBtn.disabled = true;
        confirmRemoveBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[16px]">sync</span>';
        
        try {
          const res = await fetch(`/api/coding/admin/banks/${bankId}/challenges/${challengeId}`, { method: 'DELETE' });
          if(res.ok) window.location.reload();
          else {
            confirmRemoveBtn.disabled = false;
            showToast(await getErrorMessage(res, 'Failed to remove challenge.'));
            confirmRemoveBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">close</span>';
            confirmRemoveBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
            confirmRemoveBtn.classList.add('btn-danger');
          }
        } catch (err) {
          confirmRemoveBtn.disabled = false;
          showToast('Network error: ' + err.message);
          confirmRemoveBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">close</span>';
          confirmRemoveBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
          confirmRemoveBtn.classList.add('btn-danger');
        }
      }
    });
  </script>
</body>
</html>
