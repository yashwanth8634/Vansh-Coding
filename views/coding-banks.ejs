<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Banks | Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Montserrat:wght@600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    .material-symbols-outlined { font-size: 20px; }
    .tab-btn.active { color: #4f46e5 !important; border-color: #4f46e5 !important; background-color: #eef2ff !important; }
  </style>
</head>
<body class="bg-[radial-gradient(circle_at_top_left,_#dbeafe,_#f8fafc_35%,_#f8fafc)] font-sans text-gray-900">
  <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
    <div class="container max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
      <h1 class="text-xl font-bold font-display text-indigo-600">Admin Dashboard</h1>
      <button class="bg-red-600 text-white py-2 px-4 rounded-lg hover:bg-red-700 font-medium text-sm">Logout</button>
    </div>
  </nav>

  <div class="container max-w-7xl mx-auto p-4 md:p-8">
    <!-- Main Tabs -->
    <div class="flex space-x-1 mb-4 bg-white rounded-xl border border-gray-200 p-1 shadow-sm overflow-x-auto">
      <a href="/admin" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">dashboard</span> Overview</a>
      <a href="/admin/banks" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">quiz</span> MCQ Banks</a>
      <a href="/admin/tests" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">assignment</span> MCQ Tests</a>
      <a href="/admin/coding" class="tab-btn active flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">code</span> Coding Platform</a>
    </div>

    <!-- Sub Tabs for Coding -->
    <div class="flex space-x-1 mb-6 bg-white rounded-xl border border-gray-200 p-1 shadow-sm w-max">
      <a href="/admin/coding" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50">Challenges</a>
      <a href="/admin/coding/banks" class="px-4 py-2 rounded-lg text-sm font-semibold bg-indigo-50 text-indigo-700">Question Banks</a>
      <a href="/admin/coding/tests" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50">Test Links</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Create Bank Form -->
      <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100">
        <h2 class="text-xl font-semibold mb-4 pb-4 border-b border-gray-200">Create Coding Bank</h2>
        <form id="create-bank-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Bank Title:</label>
            <input type="text" id="title" required class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-300" placeholder="e.g., Arrays Basics Test">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Select Challenges:</label>
            <div class="max-h-60 overflow-y-auto border border-gray-200 rounded-lg p-2 bg-gray-50 space-y-1">
              <% challenges.forEach(c => { %>
                <label class="flex items-center p-2 hover:bg-gray-100 rounded cursor-pointer">
                  <input type="checkbox" value="<%= c._id %>" class="challenge-checkbox w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                  <span class="ml-3 text-sm text-gray-800"><%= c.title %> <span class="text-xs text-gray-400 ml-1">(<%= c.difficulty %>)</span></span>
                </label>
              <% }); %>
            </div>
          </div>
          <button type="submit" class="w-full bg-indigo-600 text-white py-3 px-4 rounded-lg hover:bg-indigo-700 font-medium transition-colors cursor-pointer">Create Bank</button>
        </form>
      </div>

      <!-- Existing Banks -->
      <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100">
        <h2 class="text-xl font-semibold mb-4 pb-4 border-b border-gray-200">Existing Banks</h2>
        <div class="space-y-3 max-h-[40rem] overflow-y-auto">
          <% banks.forEach(b => { %>
            <div class="flex flex-col border border-gray-200 p-4 rounded-lg bg-gray-50">
              <div class="flex justify-between items-start mb-2">
                <strong class="font-semibold text-gray-800"><%= b.title %></strong>
                <button onclick="deleteBank('<%= b._id %>')" class="text-gray-400 hover:text-red-600 transition-colors">
                  <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                </button>
              </div>
              <div class="text-sm text-gray-500 mb-2"><%= b.challenges.length %> Challenges Included</div>
              <div class="flex flex-wrap gap-2">
                <% b.challenges.forEach(c => { %>
                  <span class="bg-indigo-100 text-indigo-700 px-2 py-1 rounded text-xs"><%= c.title %></span>
                <% }); %>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('create-bank-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const title = document.getElementById('title').value;
      const checkboxes = document.querySelectorAll('.challenge-checkbox:checked');
      const challenges = Array.from(checkboxes).map(c => c.value);

      if(challenges.length === 0) return alert('Select at least one challenge!');

      const res = await fetch('/api/coding/admin/bank/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, challenges })
      });
      if(res.ok) window.location.reload();
      else alert((await res.json()).message);
    });

    async function deleteBank(id) {
      if(confirm('Delete this bank?')) {
        const res = await fetch(`/api/coding/admin/bank/${id}`, { method: 'DELETE' });
        if(res.ok) window.location.reload();
      }
    }
  </script>
</body>
</html>
