<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Test Results | Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Montserrat:wght@600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    .material-symbols-outlined { font-size: 20px; }
    .tab-btn.active { color: #4f46e5 !important; border-color: #4f46e5 !important; background-color: #eef2ff !important; }
    .code-block { font-family: 'Fira Code', monospace; font-size: 13px; }
  </style>
</head>
<body class="bg-[radial-gradient(circle_at_top_left,_#dbeafe,_#f8fafc_35%,_#f8fafc)] font-sans text-gray-900 min-h-screen flex flex-col">
  <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10 shrink-0">
    <div class="container max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href="/admin/coding/tests" class="text-gray-500 hover:text-indigo-600 transition-colors">
          <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h1 class="text-xl font-bold font-display text-indigo-600">Results: <%= test.codingBank.title %></h1>
      </div>
    </div>
  </nav>

  <div class="container max-w-7xl mx-auto p-4 md:p-8 flex-1">
    
    <div class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
      <div class="flex justify-between items-end mb-6 pb-4 border-b border-gray-200">
        <div>
          <h2 class="text-2xl font-bold text-gray-800">Student Submissions</h2>
          <p class="text-sm text-gray-500 mt-1">Total Attempts: <%= attempts.length %></p>
        </div>
        <div class="text-right">
          <p class="text-sm text-gray-500">Link Identifier</p>
          <p class="font-mono text-indigo-600 font-medium bg-indigo-50 px-3 py-1 rounded inline-block">/coding/test/<%= test.uniqueLink %></p>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-600 text-sm border-y border-gray-200">
              <th class="p-4 font-semibold">Roll No</th>
              <th class="p-4 font-semibold">Submitted At</th>
              <th class="p-4 font-semibold">Completed Challenges</th>
              <th class="p-4 font-semibold text-right">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% if (attempts.length === 0) { %>
              <tr>
                <td colspan="4" class="p-6 text-center text-gray-500">No submissions yet.</td>
              </tr>
            <% } else { %>
              <% attempts.forEach(attempt => { 
                  let solved = 0;
                  attempt.answers.forEach(a => { if(a.status === 'Accepted') solved++; });
              %>
                <tr class="hover:bg-indigo-50/30 transition-colors group">
                  <td class="p-4 font-medium text-gray-900 uppercase"><%= attempt.studentRollNo %></td>
                  <td class="p-4 text-sm text-gray-500"><%= new Date(attempt.submittedAt).toLocaleString() %></td>
                  <td class="p-4">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-sm font-medium
                      <%= solved === attempt.answers.length && attempt.answers.length > 0 ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                      <%= solved %> / <%= attempt.answers.length %>
                    </span>
                  </td>
                  <td class="p-4 text-right">
                    <button onclick="openModal('<%= attempt._id %>')" class="text-indigo-600 hover:text-indigo-800 font-medium text-sm flex items-center justify-end gap-1 ml-auto">
                      <span class="material-symbols-outlined" style="font-size:18px">visibility</span> View Code
                    </button>
                    
                    <!-- Hidden Data Store for Modal -->
                    <script type="application/json" id="data-<%= attempt._id %>">
                      <%- JSON.stringify(attempt.answers) %>
                    </script>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Code Inspection Modal -->
  <div id="codeModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-4xl max-h-[90vh] flex flex-col overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg font-bold text-gray-800" id="modalRollNo">Student Code</h3>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-6 bg-gray-100" id="modalContent">
        <!-- Rendered via JS -->
      </div>
    </div>
  </div>

  <script>
    function openModal(attemptId) {
      const answers = JSON.parse(document.getElementById(`data-${attemptId}`).textContent);
      const content = document.getElementById('modalContent');
      
      let html = '';
      answers.forEach((ans, idx) => {
        const statusColor = ans.status === 'Accepted' ? 'text-green-600 bg-green-50' : (ans.status === 'Unattempted' ? 'text-gray-500 bg-gray-100' : 'text-red-600 bg-red-50');
        
        html += `
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6 overflow-hidden">
            <div class="flex justify-between items-center p-4 border-b border-gray-100">
              <h4 class="font-bold text-gray-800 text-base">Q${idx + 1}: ${ans.challenge ? ans.challenge.title : 'Deleted Challenge'}</h4>
              <div class="flex items-center gap-3">
                <span class="text-xs font-mono bg-gray-200 text-gray-700 px-2 py-1 rounded">${ans.language}</span>
                <span class="text-xs font-semibold px-2.5 py-1 rounded ${statusColor}">${ans.status} (${ans.passedCases}/${ans.totalCases} cases)</span>
              </div>
            </div>
            <div class="bg-[#282a36] text-gray-300 p-4 overflow-x-auto">
              <pre class="code-block m-0">${escapeHtml(ans.code || '// No code submitted')}</pre>
            </div>
          </div>
        `;
      });
      content.innerHTML = html;
      document.getElementById('codeModal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('codeModal').classList.add('hidden');
    }

    function escapeHtml(unsafe) {
        return unsafe.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }
  </script>
</body>
</html>
