<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Results | Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="/css/vansh2k26-theme.css">
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #000000; color: #ffffff; }
    
    .glass-nav { background: rgba(0, 0, 0, 0.6); border-bottom: 1px solid rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); }
    .glass-card { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.08); }
    
    .grid-bg {
      background-size: 40px 40px;
      background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                        linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
    
    .code-block { font-family: 'Fira Code', monospace; font-size: 13px; line-height: 1.6; }
  </style>
</head>
<body class="vc-admin flex flex-col min-h-screen relative overflow-x-hidden antialiased selection:bg-white/30">

  <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

  <!-- Header -->
  <nav class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-20 relative">
    <div class="flex items-center gap-4">
      <a href="/admin/coding/tests" class="text-gray-500 hover:text-white transition-colors flex items-center">
        <span class="material-symbols-outlined text-[24px]">arrow_back</span>
      </a>
      <div class="h-4 w-px bg-white/20"></div>
      <span class="text-white font-medium tracking-tight">VanshCoding</span>
    </div>
    <div class="text-sm text-gray-400 font-mono hidden sm:block">
      /coding/test/<%= test.uniqueLink %>
    </div>
  </nav>

  <main class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-10 py-10 flex-1 flex flex-col">
    
    <div class="glass-card rounded-2xl p-8 border border-white/10 flex-1 flex flex-col shadow-2xl">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4 border-b border-white/10 pb-6">
        <div>
          <h2 class="text-3xl font-semibold text-white tracking-tight mb-2"><%= test.codingBank ? test.codingBank.title : 'Deleted Environment' %></h2>
          <div class="flex items-center gap-3 text-xs">
            <span class="text-gray-300 font-mono"><%= attempts.length %> Attempts</span>
            <span class="text-gray-500 font-mono">ID: <%= test._id %></span>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto border border-white/10 rounded-xl bg-black/40">
        <table class="w-full text-left border-collapse min-w-[700px]">
          <thead>
            <tr class="bg-white/5 border-b border-white/10">
              <th class="p-4 font-medium text-gray-400 text-xs uppercase tracking-wider">Student Roll No</th>
              <th class="p-4 font-medium text-gray-400 text-xs uppercase tracking-wider">Submitted At</th>
              <th class="p-4 font-medium text-gray-400 text-xs uppercase tracking-wider">Score</th>
              <th class="p-4 text-right"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10">
            <% if (attempts.length === 0) { %>
              <tr>
                <td colspan="4" class="p-16 text-center">
                   <div class="flex flex-col items-center justify-center text-gray-500">
                     <span class="material-symbols-outlined text-4xl mb-3 opacity-50">search_off</span>
                     <span class="text-sm">No attempts found.</span>
                   </div>
                </td>
              </tr>
            <% } else { %>
              <% attempts.forEach(attempt => { 
                  let solved = 0;
                  attempt.answers.forEach(a => { if(a.status === 'Accepted') solved++; });
              %>
                <tr class="hover:bg-white/[0.02] transition-colors group">
                  <td class="p-4 font-bold text-white text-sm font-mono"><%= attempt.studentRollNo %></td>
                  <td class="p-4 text-gray-400 text-sm"><%= new Date(attempt.submittedAt).toLocaleString() %></td>
                  <td class="p-4">
                    <% const gradeClass = solved === attempt.answers.length && attempt.answers.length > 0 ? 'text-green-400 bg-green-500/10 border border-green-500/20' : 'text-yellow-400 bg-yellow-500/10 border border-yellow-500/20'; %>
                    <span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-semibold uppercase tracking-wider <%= gradeClass %>">
                      <%= solved %> / <%= attempt.answers.length %> Solved
                    </span>
                  </td>
                  <td class="p-4 text-right">
                    <button onclick="openModal('<%= attempt._id %>')" class="bg-white/5 text-gray-300 hover:text-white hover:bg-white/10 border border-white/10 hover:border-white/20 px-4 py-2 rounded-lg text-xs font-medium transition-all ml-auto flex items-center gap-2">
                       <span class="material-symbols-outlined text-[16px]">terminal</span> View Code
                    </button>
                    <!-- Data Store -->
                    <script type="application/json" id="data-<%= attempt._id %>">
                      <%- JSON.stringify(attempt.answers) %>
                    </script>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <!-- Inspector Modal -->
  <div id="codeModal" class="fixed inset-0 bg-black/80 backdrop-blur-md z-50 hidden flex items-center justify-center p-4 lg:p-10 opacity-0 transition-opacity duration-300">
    <div class="bg-[#0a0a0a] rounded-2xl shadow-2xl w-full max-w-5xl h-full max-h-[90vh] flex flex-col overflow-hidden border border-white/10 transform scale-95 transition-transform duration-300" id="modalDialog">
      <div class="px-6 py-4 border-b border-white/10 flex justify-between items-center bg-[#050505]">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-gray-400 text-[20px]">description</span>
          <h3 class="text-sm font-semibold text-white tracking-wide" id="modalRollNo">Inspect Code</h3>
        </div>
        <button onclick="closeModal()" class="text-gray-500 hover:text-white transition-colors flex items-center justify-center p-1 rounded-md hover:bg-white/10">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      
      <div class="flex-1 overflow-y-auto p-6 bg-[#000]" id="modalContent">
        <!-- Rendered via JS -->
      </div>
    </div>
  </div>

  <script>
    const modalWrap = document.getElementById('codeModal');
    const modalDialog = document.getElementById('modalDialog');

    function openModal(attemptId) {
      const answers = JSON.parse(document.getElementById(`data-${attemptId}`).textContent);
      const content = document.getElementById('modalContent');
      
      let html = '';
      answers.forEach((ans, idx) => {
        const isAccepted = ans.status === 'Accepted';
        const isUnattempted = ans.status === 'Unattempted';
        
        let statusBadge = '';
        if(isAccepted) statusBadge = 'bg-green-500/10 text-green-400 border border-green-500/20';
        else if(isUnattempted) statusBadge = 'bg-white/5 text-gray-500 border border-white/10';
        else statusBadge = 'bg-red-500/10 text-red-400 border border-red-500/20';
        
        html += `
          <div class="bg-[#0a0a0a] rounded-xl border border-white/10 mb-6 overflow-hidden">
            <div class="flex flex-col md:flex-row justify-between md:items-center p-4 border-b border-white/5 bg-[#050505] gap-3">
              <h4 class="font-medium text-white text-sm">Q${idx + 1}: ${ans.challenge ? ans.challenge.title : 'Deleted Challenge'}</h4>
              <div class="flex items-center gap-2">
                <span class="text-[10px] font-semibold tracking-wider uppercase bg-white/5 border border-white/10 text-gray-400 px-2 py-0.5 rounded">${ans.language}</span>
                <span class="text-[10px] font-semibold tracking-wider uppercase px-2 py-0.5 rounded ${statusBadge}">${ans.status} [${ans.passedCases}/${ans.totalCases}]</span>
              </div>
            </div>
            <div class="bg-[#000] p-4 overflow-x-auto">
              <pre class="code-block text-gray-300 m-0"><code class="language-${ans.language.toLowerCase()}">${escapeHtml(ans.code || '// Blank File')}</code></pre>
            </div>
          </div>
        `;
      });
      content.innerHTML = html;
      
      modalWrap.classList.remove('hidden');
      // Trigger animation frame
      setTimeout(() => {
        modalWrap.classList.remove('opacity-0');
        modalDialog.classList.remove('scale-95');
      }, 10);
    }

    function closeModal() {
      modalWrap.classList.add('opacity-0');
      modalDialog.classList.add('scale-95');
      setTimeout(() => {
        modalWrap.classList.add('hidden');
      }, 300);
    }
    
    modalWrap.addEventListener('click', (e) => {
      if(e.target.id === 'codeModal') closeModal();
    });

    function escapeHtml(unsafe) {
        return unsafe.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }
  </script>
</body>
</html>
