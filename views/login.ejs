<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mr & Ms Coder Admin Login | Vansh2k26</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/vansh2k26-theme.css">
    <style>
      body { font-family: 'Inter', sans-serif; background-color: #000; color: #fff; }
      .glass-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); }
      .ambient-glow { position: absolute; inset: 0; margin: auto; width: 45vw; height: 45vw; background: radial-gradient(circle, rgba(59, 130, 246, 0.14) 0%, rgba(0, 0, 0, 0) 70%); pointer-events: none; }
      .grid-bg { background-size: 40px 40px; background-image: linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px); mask-image: linear-gradient(to bottom, black 35%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 35%, transparent 100%); }
    </style>
  </head>
  <body class="min-h-screen relative overflow-hidden antialiased selection:bg-white/30">
    <div class="absolute inset-0 grid-bg pointer-events-none"></div>
    <div class="ambient-glow"></div>

    <div class="min-h-screen flex items-center justify-center p-6 relative z-10">
      <div class="glass-card rounded-2xl p-8 md:p-10 w-full max-w-md">
        <div class="text-center mb-8">
          <div class="mx-auto w-12 h-12 border border-white/20 bg-white/5 rounded-xl flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-gray-500 text-[22px]">admin_panel_settings</span>
          </div>
          <h2 class="text-2xl font-semibold tracking-tight text-gray-500">Mr & Ms Coder Control Room</h2>
          <p class="text-sm text-gray-400 mt-2">Vansh2k26 admin sign-in for quiz and coding rounds.</p>
        </div>

        <form id="login-form" class="space-y-4">
          <div>
            <label for="username" class="sr-only">Username</label>
            <input
              type="text"
              id="username"
              placeholder="Username"
              required
              class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none transition-all"
            />
          </div>
          <div>
            <label for="password" class="sr-only">Password</label>
            <div class="relative">
              <input
                type="password"
                id="password"
                placeholder="Password"
                required
                class="w-full px-4 py-3 pr-24 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none transition-all"
              />
              <button
                id="toggle-password"
                type="button"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-xs font-semibold text-gray-300 px-2 py-1 rounded-md hover:bg-white/10"
              >
                Show
              </button>
            </div>
          </div>

          <button
            type="submit"
            id="login-btn"
            class="w-full bg-white text-black hover:bg-gray-200 py-3 rounded-xl text-sm font-semibold transition-colors"
          >
            Login
          </button>
        </form>

        <p id="login-error" class="text-red-400 mt-4 text-center font-medium text-sm"></p>
      </div>
    </div>

    <script>
      const passwordInput = document.getElementById("password");
      const togglePasswordBtn = document.getElementById("toggle-password");
      const loginBtn = document.getElementById("login-btn");

      togglePasswordBtn.addEventListener("click", () => {
        const show = passwordInput.type === "password";
        passwordInput.type = show ? "text" : "password";
        togglePasswordBtn.textContent = show ? "Hide" : "Show";
      });

      document
        .getElementById("login-form")
        .addEventListener("submit", async (e) => {
          e.preventDefault();
          const username = document.getElementById("username").value;
          const password = document.getElementById("password").value;
          const errorP = document.getElementById("login-error");
          errorP.textContent = "";

          try {
            loginBtn.disabled = true;
            loginBtn.textContent = "Logging in...";
            const res = await fetch("/api/admin/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ username, password }),
            });

            const data = await res.json();

            if (res.ok) {
              window.location.href = "/admin";
            } else {
              errorP.textContent = data.message || "Login failed.";
            }
          } catch (err) {
            errorP.textContent = "An error occurred. Please try again.";
          } finally {
            loginBtn.disabled = false;
            loginBtn.textContent = "Login";
          }
        });
    </script>
  </body>
</html>
