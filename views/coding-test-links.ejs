<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Active Coding Sessions | Admin</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex min-h-screen flex-col md:h-screen md:flex-row overflow-x-hidden md:overflow-hidden antialiased selection:bg-white/30">
  <%- include('partials/admin-sidebar', { activePage: 'coding-test-links' }) %>

  <main class="flex-1 flex min-h-0 flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">Coding Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Active Sessions</span>
      </div>

      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/coding/tests" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Create</a>
        <a href="/admin/coding/tests/links" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Active Sessions</a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto space-y-6">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Active Sessions</h1>
            <p class="text-gray-400 font-light text-sm">List of active coding session links.</p>
          </div>
          <a href="/admin/coding/tests" class="btn-secondary btn-sm">
            <span class="material-symbols-outlined text-[18px]">add_link</span>
            Create Session
          </a>
        </div>

        <div class="glass-card rounded-2xl p-2 h-max md:max-h-[calc(100vh-220px)] overflow-y-auto">
          <div class="space-y-2 p-2">
            <% tests.forEach(t => { %>
              <% const expiry = t.linkExpiresAt ? new Date(t.linkExpiresAt) : null; %>
              <% const isExpired = !expiry || isNaN(expiry) || new Date() > expiry; %>
              <div class="bg-black/40 border border-white/5 hover:border-white/10 hover:bg-white/5 p-5 rounded-xl flex flex-col gap-4 transition-all group <%= isExpired ? 'opacity-50 grayscale-[30%]' : '' %>">
                <div class="flex justify-between items-start">
                  <div>
                    <strong class="text-base font-medium text-white block mb-1"><%= t.codingBank ? t.codingBank.title : 'Deleted Environment' %></strong>
                    <div class="flex items-center gap-2 text-xs">
                      <span class="inline-block w-2 h-2 rounded-full <%= isExpired ? 'bg-red-500' : 'bg-green-500 animate-pulse' %>"></span>
                      <span class="text-gray-400">Expires: <%= expiry && !isNaN(expiry) ? expiry.toLocaleString('en-IN') : '—' %></span>
                    </div>
                    <div class="mt-1 text-gray-500 text-xs font-mono uppercase tracking-wider flex items-center gap-3">
                      <span>Timer: <%= t.durationMinutes || 30 %> min</span>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded-md bg-white/5 border border-white/10 text-[10px] font-medium text-gray-400">
                        Questions: <%= t.numChallenges && t.numChallenges > 0 ? t.numChallenges : 'All' %>
                      </span>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <a href="/admin/coding/results/<%= t._id %>" class="btn-secondary btn-sm">View Results</a>
                    <button data-action="delete-link" data-id="<%= t._id %>" class="btn-danger btn-icon btn-sm" type="button" aria-label="Delete session" title="Delete session">
                      <span class="material-symbols-outlined text-[18px]">delete</span>
                    </button>
                  </div>
                </div>

                <div class="bg-[#0a0a0a] border border-white/10 p-3 rounded-lg flex items-center justify-between">
                  <a href="/coding/test/<%= t.uniqueLink %>" target="_blank" rel="noopener noreferrer" class="text-gray-300 font-mono text-xs hover:text-white transition-colors truncate flex-1 pr-3">/coding/test/<%= t.uniqueLink %></a>
                  <button data-action="copy-link" data-link="/coding/test/<%= t.uniqueLink %>" class="btn-ghost btn-icon btn-sm" type="button" aria-label="Copy coding session link" title="Copy link">
                    <span class="material-symbols-outlined text-[16px]">content_copy</span>
                  </button>
                </div>
              </div>
            <% }); %>
            <% if (tests.length === 0) { %>
              <div class="text-gray-500 text-center py-16 text-sm font-medium bg-black/20 rounded-xl border border-dashed border-white/10 flex flex-col items-center">
                <span class="material-symbols-outlined text-4xl mb-3 opacity-50">link_off</span>
                No active sessions found.
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    function showToast(message, type = 'error') {
      const existing = document.getElementById('vc-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.id = 'vc-toast';
      const color = type === 'error' ? 'border-red-500/30 text-red-500 bg-red-500/10' : 'border-green-500/30 text-green-500 bg-green-500/10';
      toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-5 py-3 rounded-xl glass-card border ${color} text-sm font-medium shadow-xl transition-all duration-300`;
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => { if (document.getElementById('vc-toast')) toast.remove() }, 4000);
    }

    async function getErrorMessage(res, fallback) {
      try {
        const data = await res.json();
        return data.message || fallback;
      } catch (error) {
        return fallback;
      }
    }

    document.addEventListener('click', async (e) => {
      // HANDLE DELETE LINK (With Confirm State)
      const deleteBtn = e.target.closest('[data-action="delete-link"]');
      if (deleteBtn && !deleteBtn.dataset.confirmPending) {
        deleteBtn.dataset.confirmPending = 'true';
        deleteBtn.innerHTML = '<span class="material-symbols-outlined text-[14px]">check</span>';
        deleteBtn.title = 'Click again to confirm delete';
        deleteBtn.classList.remove('btn-danger');
        deleteBtn.classList.add('bg-red-500/40', 'border-red-500', 'text-red-100');
        
        setTimeout(() => {
          if (deleteBtn.dataset.confirmPending) {
              delete deleteBtn.dataset.confirmPending;
              deleteBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
              deleteBtn.title = 'Delete session';
              deleteBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
              deleteBtn.classList.add('btn-danger');
          }
        }, 3000);
        return;
      }

      const confirmBtn = e.target.closest('[data-action="delete-link"][data-confirm-pending]');
      if (confirmBtn) {
        const id = confirmBtn.dataset.id;
        delete confirmBtn.dataset.confirmPending;
        confirmBtn.disabled = true;
        confirmBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span>';
        try {
          const res = await fetch(`/api/coding/admin/tests/${id}`, { method: 'DELETE' });
          if(res.ok) window.location.reload();
          else {
            confirmBtn.disabled = false;
            showToast(await getErrorMessage(res, 'Failed to delete session.'));
            confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
            confirmBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
            confirmBtn.classList.add('btn-danger');
          }
        } catch (err) {
          confirmBtn.disabled = false;
          showToast('Network error: ' + err.message);
          confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
          confirmBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
          confirmBtn.classList.add('btn-danger');
        }
        return;
      }

      // HANDLE COPY LINK
      const copyBtn = e.target.closest('[data-action="copy-link"]');
      if (copyBtn) {
        const url = window.location.origin + copyBtn.dataset.link;
        try {
          await navigator.clipboard.writeText(url);
          const icon = copyBtn.querySelector('.material-symbols-outlined');
          icon.textContent = 'check';
          setTimeout(() => icon.textContent = 'content_copy', 2000);
        } catch (err) {
          showToast('Could not copy — try manually: ' + url);
        }
      }
    });
  </script>
</body>
</html>
