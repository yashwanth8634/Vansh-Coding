<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Active Coding Sessions | Admin</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex h-screen overflow-hidden antialiased selection:bg-white/30">
  <aside class="w-20 md:w-64 glass-sidebar flex flex-col shrink-0 z-20">
    <div class="h-16 flex items-center justify-center md:justify-start md:px-6 border-b border-white/10 shrink-0">
      <span class="material-symbols-outlined text-[24px] text-white">terminal</span>
      <span class="ml-3 font-semibold tracking-tight text-white hidden md:block">Mr & Ms Coder</span>
    </div>

    <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-2">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3 hidden md:block">Main</div>
      <a href="/admin" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">space_dashboard</span>
        <span class="text-sm hidden md:block">Overview</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">Coding Section</div>
      <a href="/admin/coding/banks" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">data_object</span>
        <span class="text-sm hidden md:block">Coding Environments</span>
      </a>
      <a href="/admin/coding/tests" class="nav-item active flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">api</span>
        <span class="text-sm hidden md:block">Coding Sessions</span>
      </a>
      <a href="/admin/coding" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">code_blocks</span>
        <span class="text-sm hidden md:block">Coding Challenges</span>
      </a>
    </nav>

    <div class="p-4 border-t border-white/10 shrink-0">
      <form action="/api/admin/logout" method="POST">
        <button type="submit" class="w-full flex items-center justify-center md:justify-start gap-3 px-3 py-2.5 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors">
          <span class="material-symbols-outlined text-[20px]">logout</span>
          <span class="text-sm font-medium hidden md:block">Sign Out</span>
        </button>
      </form>
    </div>
  </aside>

  <main class="flex-1 flex flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">Coding Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Active Sessions</span>
      </div>

      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/coding/tests" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Create</a>
        <a href="/admin/coding/tests/links" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Active Sessions</a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto space-y-6">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Active Sessions</h1>
            <p class="text-gray-400 font-light text-sm">List of active coding session links.</p>
          </div>
          <a href="/admin/coding/tests" class="inline-flex items-center gap-2 rounded-lg bg-white text-black hover:bg-gray-200 px-4 py-2.5 text-sm font-semibold transition-colors">
            <span class="material-symbols-outlined text-[18px]">add_link</span>
            Create Session
          </a>
        </div>

        <div class="glass-card rounded-2xl p-2 h-max max-h-[calc(100vh-220px)] overflow-y-auto">
          <div class="space-y-2 p-2">
            <% tests.forEach(t => { %>
              <div class="bg-black/40 border border-white/5 hover:border-white/10 hover:bg-white/5 p-5 rounded-xl flex flex-col gap-4 transition-all group">
                <div class="flex justify-between items-start">
                  <div>
                    <strong class="text-base font-medium text-white block mb-1"><%= t.codingBank ? t.codingBank.title : 'Deleted Environment' %></strong>
                    <div class="flex items-center gap-2 text-xs">
                      <span class="inline-block w-2 h-2 rounded-full <%= new Date() > new Date(t.linkExpiresAt) ? 'bg-red-500' : 'bg-green-500 animate-pulse' %>"></span>
                      <span class="text-gray-400">Expires: <%= new Date(t.linkExpiresAt).toLocaleString() %></span>
                    </div>
                    <div class="mt-1 text-gray-500 text-xs font-mono uppercase tracking-wider">
                      Timer: <%= t.durationMinutes || 30 %> min
                    </div>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <a href="/admin/coding/results/<%= t._id %>" class="bg-blue-500/10 text-blue-400 hover:bg-blue-500/20 border border-blue-500/20 hover:border-blue-500/40 px-4 py-2 rounded-lg text-xs font-medium transition-colors">View Results</a>
                    <button onclick="deleteTest('<%= t._id %>', this)" class="bg-transparent text-gray-500 hover:text-red-400 hover:bg-red-500/10 border border-transparent hover:border-red-500/20 p-2 rounded-lg transition-colors flex items-center justify-center">
                      <span class="material-symbols-outlined text-[18px]">delete</span>
                    </button>
                  </div>
                </div>

                <div class="bg-[#0a0a0a] border border-white/10 p-3 rounded-lg flex items-center justify-between">
                  <a href="/coding/test/<%= t.uniqueLink %>" target="_blank" class="text-gray-300 font-mono text-xs hover:text-white transition-colors truncate w-[80%]">/coding/test/<%= t.uniqueLink %></a>
                  <button onclick="navigator.clipboard.writeText(window.location.origin + '/coding/test/<%= t.uniqueLink %>')" class="text-gray-500 hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-[16px]">content_copy</span>
                  </button>
                </div>
              </div>
            <% }); %>
            <% if (tests.length === 0) { %>
              <div class="text-gray-500 text-center py-16 text-sm font-medium bg-black/20 rounded-xl border border-dashed border-white/10 flex flex-col items-center">
                <span class="material-symbols-outlined text-4xl mb-3 opacity-50">link_off</span>
                No active sessions found.
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    async function getErrorMessage(res, fallback) {
      try {
        const data = await res.json();
        return data.message || fallback;
      } catch (error) {
        return fallback;
      }
    }

    async function deleteTest(id, button) {
      if (confirm('Are you sure you want to delete this session? This will remove all associated results.')) {
        if (button) button.disabled = true;
        const res = await fetch(`/api/coding/admin/tests/${id}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
        else {
          if (button) button.disabled = false;
          alert(await getErrorMessage(res, 'Failed to delete session.'));
        }
      }
    }
  </script>
</body>
</html>
