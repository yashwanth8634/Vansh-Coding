<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Test Results</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Montserrat:wght@600;700&family=Noto+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Albert Sans", "Noto Sans", "sans-serif"],
              display: ["Montserrat", "sans-serif"],
            },
          },
        },
      };
    </script>
    <style>
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        font-size: 24px;
      }
    </style>
  </head>
  <body class="bg-gray-50 font-sans text-gray-900">
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
      <div
        class="container max-w-7xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center"
      >
        <h1 class="text-xl sm:text-2xl font-bold font-display text-indigo-600">
          Test Results
        </h1>
        <a
          href="/admin"
          class="bg-gray-500 text-white py-2 px-3 sm:px-4 rounded-lg hover:bg-gray-600 font-medium transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400 text-sm sm:text-base"
        >
          &larr; Back to Dashboard
        </a>
      </div>
    </nav>

    <div class="container max-w-7xl mx-auto p-4 md:p-8">
      <h2 class="text-2xl sm:text-3xl font-bold font-display mb-4">
        Test:
        <span class="text-indigo-600"><%= test.questionBank.title %></span>
      </h2>
      <p class="text-gray-600 mb-6 text-sm sm:text-base">
        <%= test.numQuestions %> Questions | <%= test.duration %> Minutes |
        Created: <%= new Date(test.createdAt).toLocaleDateString() %>
      </p>
      <div class="mb-6">
        <form id="search-form">
          <label
            for="search-rollno"
            class="block text-sm font-medium text-gray-700 mb-1"
            >Search by Roll No:</label
          >
          <div class="flex flex-col sm:flex-row gap-2">
            <input
              type="text"
              id="search-rollno"
              class="w-full sm:max-w-sm p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500"
              placeholder="Enter roll no..."
            />
            <button
              type="submit"
              class="w-full sm:w-auto bg-indigo-600 text-white py-3 px-4 rounded-lg hover:bg-indigo-700 font-semibold transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
            >
              Search
            </button>
            <button
              type="button"
              id="clear-search"
              class="w-full sm:w-auto bg-gray-200 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-300 font-medium transition-colors duration-150"
            >
              Clear
            </button>
          </div>
        </form>
      </div>

      <div
        class="bg-white p-4 sm:p-6 rounded-xl shadow-lg border border-gray-100 overflow-x-auto"
      >
        <h3 class="text-lg sm:text-xl font-semibold mb-4">
          All Attempts (<span id="attempt-count"><%= attempts.length %></span>)
        </h3>
        <table class="w-full min-w-max">
          <thead>
            <tr class="border-b text-left text-gray-600">
              <th class="p-3">Roll No</th>
              <th class="p-3">Score</th>
              <th class="p-3">Submitted At</th>
              <th class="p-3">Details</th>
            </tr>
          </thead>
          <tbody id="results-table-body">
            <% if (attempts.length === 0) { %>
            <tr id="no-results-row">
              <td colspan="4" class="p-4 text-center text-gray-500">
                No one has attempted this test yet.
              </td>
            </tr>
            <% } else { %> <% attempts.forEach(attempt => { %>
            <tr class="border-b last:border-0 hover:bg-gray-50">
              <td class="p-3 font-medium"><%= attempt.studentRollNo %></td>
              <td class="p-3">
                <%= attempt.score %> / <%= test.numQuestions %>
              </td>
              <td class="p-3">
                <%= new Date(attempt.submittedAt).toLocaleString() %>
              </td>

              <td class="p-3">
                <button
                  data-action="view-details"
                  data-rollno="<%= attempt.studentRollNo %>"
                  class="bg-blue-500 text-white px-3 py-1 rounded-md text-sm hover:bg-blue-600 transition-colors"
                >
                  View
                </button>
              </td>
            </tr>
            <% }); %> <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <input type="hidden" id="test-id" value="<%= test._id %>" />

    <div
      id="analysis-modal"
      class="hidden fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-50 p-4"
    >
      <div class="bg-white p-6 sm:p-8 rounded-xl shadow-xl w-full max-w-3xl">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl sm:text-2xl font-bold font-display">
            Analysis for <span id="modal-rollno" class="text-indigo-600"></span>
          </h2>
          <button
            id="modal-close"
            class="text-gray-500 hover:text-gray-800"
            title="Close"
          >
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <p class="text-lg font-semibold mb-4">
          Final Score: <span id="modal-score"></span>
        </p>
        <div
          id="modal-body"
          class="space-y-6 max-h-[70vh] overflow-y-auto pr-2"
        ></div>
      </div>
    </div>

    <script>
      const initialAttemptsData = <%- JSON.stringify(attempts) %>;
      const testTotalQuestions = <%= test.numQuestions %>;
    </script>
    <script src="/js/test-results.js"></script>
  </body>
</html>
