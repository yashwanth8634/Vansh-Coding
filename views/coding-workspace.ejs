<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= test.codingBank.title %> | Exec Workspace</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/dracula.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/javascript/javascript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/python/python.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/clike/clike.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <style>
    body { font-family: 'Inter', sans-serif; background-color: #000000; color: #ffffff; overflow: hidden; }
    
    .glass-nav { background: rgba(0, 0, 0, 0.6); border: 1px solid rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); }
    .glass-card { background: rgba(10, 10, 10, 0.8); border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); }

    .CodeMirror { height: 100%; font-family: 'Fira Code', monospace; font-size: 14px; background: #050505; color: #e5e5e5; }
    
    .grid-bg {
      background-size: 40px 40px;
      background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                        linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      mask-image: linear-gradient(to bottom, black 20%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 20%, transparent 100%);
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
    
    /* CodeMirror custom theme overrides for ultra-minimal dark */
    .cm-s-dracula.CodeMirror, .cm-s-dracula .CodeMirror-gutters { background-color: #050505 !important; border-right: 1px solid rgba(255,255,255,0.05); }
    .cm-s-dracula .CodeMirror-linenumber { color: #555 !important; font-size: 11px; }

    .challenge-tab.active { background-color: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.2); }
  </style>
</head>
<body class="h-screen flex flex-col p-3 md:p-5 gap-4 relative antialiased selection:bg-white/30 text-white">

  <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

  <!-- Top Nav Pill -->
  <nav class="glass-nav rounded-2xl h-16 md:h-20 flex items-center justify-between px-6 shrink-0 z-10 shadow-lg relative overflow-hidden">
    <div class="absolute top-0 right-1/2 w-48 h-10 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="flex items-center gap-4 relative z-10">
      <div class="border border-white/10 bg-white/5 w-10 h-10 rounded-xl flex items-center justify-center">
        <span class="material-symbols-outlined text-white text-[20px]">terminal</span>
      </div>
      <div>
        <h1 class="font-semibold text-sm md:text-base tracking-tight leading-none text-white"><%= test.codingBank.title %></h1>
        <p class="text-gray-500 text-[10px] font-mono uppercase tracking-widest hidden sm:block mt-1">Live Assessment Frame</p>
      </div>
    </div>
    <div class="flex items-center gap-4 relative z-10">
      <input type="text" id="roll-no" placeholder="Roll Number" class="bg-[#0a0a0a] text-white placeholder-gray-600 border border-white/10 focus:bg-[#111] focus:border-white/30 rounded-lg px-4 py-2 text-sm font-medium outline-none transition-all uppercase tracking-widest text-center w-36 md:w-48 shadow-inner" required>
      <button id="final-submit-btn" class="bg-white text-black hover:bg-gray-200 px-6 py-2 rounded-lg text-sm font-semibold shadow-[0_0_15px_rgba(255,255,255,0.1)] transition-transform active:scale-[0.98] flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">publish</span> <span class="hidden sm:inline">Commit Session</span>
      </button>
    </div>
  </nav>

  <!-- Complete Workspace Split Panes -->
  <div class="flex-1 flex flex-col md:flex-row gap-4 overflow-hidden z-10 relative">
    
    <!-- LEFT MOST: Question Navigator -->
    <div class="w-full h-24 md:h-full md:w-20 lg:w-64 glass-card rounded-2xl flex flex-col shrink-0 overflow-hidden shadow-2xl">
      <div class="px-5 py-4 border-b border-white/10 bg-[#050505] shrink-0 hidden lg:flex items-center justify-between">
        <h3 class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest">Execution Modules</h3>
        <span class="material-symbols-outlined text-[16px] text-gray-500">format_list_bulleted</span>
      </div>
      <div class="flex-1 overflow-x-auto md:overflow-x-hidden md:overflow-y-auto p-3 flex md:flex-col gap-2" id="question-tabs">
        <% test.codingBank.challenges.forEach((c, index) => { %>
          <button data-id="<%= c._id %>" class="challenge-tab shrink-0 md:shrink w-auto md:w-full text-left p-3 rounded-xl border border-transparent hover:bg-white/5 transition-all flex items-center gap-3 group">
            <div class="w-8 h-8 rounded-lg shrink-0 bg-[#0a0a0a] border border-white/10 group-[.active]:bg-white group-[.active]:text-black text-gray-400 flex items-center justify-center font-mono text-sm transition-colors">
              <%= index + 1 %>
            </div>
            <div class="hidden lg:block truncate">
              <div class="text-sm font-medium text-gray-300 group-[.active]:text-white truncate mb-0.5"><%= c.title %></div>
              <div class="text-[10px] font-mono uppercase tracking-widest text-gray-500 group-[.active]:text-gray-400"><%= c.difficulty %></div>
            </div>
          </button>
        <% }); %>
      </div>
    </div>

    <!-- MIDDLE: Problem Description -->
    <div class="hidden md:flex flex-col w-1/3 xl:w-[35%] glass-card rounded-2xl border border-white/10 overflow-hidden shrink-0 shadow-2xl bg-[#0a0a0a]">
      <div class="px-6 py-5 border-b border-white/10 bg-[#050505] shrink-0">
        <div class="flex items-center gap-3 mb-2">
          <span id="current-q-diff" class="text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono">--</span>
        </div>
        <h2 id="current-q-title" class="text-xl font-semibold text-white tracking-tight">Loading Constraint...</h2>
      </div>
      <div id="current-q-desc" class="p-6 md:p-8 overflow-y-auto flex-1 prose prose-invert prose-sm max-w-none text-gray-300 font-normal leading-relaxed">
        <!-- Markdown -->
      </div>
    </div>

    <!-- RIGHT: Code Editor & Console -->
    <div class="flex-1 flex flex-col bg-[#050505] rounded-2xl border border-white/10 overflow-hidden relative shadow-2xl">
      <div class="h-14 xl:h-16 bg-[#0a0a0a] border-b border-white/10 flex items-center justify-between px-4 shrink-0">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[16px] text-gray-500">code</span>
          <select id="language-select" class="bg-transparent text-gray-300 text-xs font-mono outline-none hover:text-white transition-colors cursor-pointer appearance-none border border-transparent hover:border-white/10 px-2 py-1 rounded">
            <option value="javascript" class="bg-[#111]">JavaScript (Node.js)</option>
            <option value="python" class="bg-[#111]">Python 3.10</option>
            <option value="java" class="bg-[#111]">Java 15</option>
            <option value="cpp" class="bg-[#111]">C++ (GCC 12)</option>
            <option value="c" class="bg-[#111]">C (GCC 12)</option>
          </select>
        </div>
        <button id="run-btn" class="flex items-center gap-2 text-white bg-white/5 hover:bg-white/10 border border-white/10 px-4 py-1.5 rounded-lg text-xs font-medium transition-all active:scale-[0.98]">
          <span class="material-symbols-outlined text-[16px]">play_arrow</span> Run <span class="hidden xl:inline">Check</span>
        </button>
      </div>

      <!-- Editor -->
      <div class="flex-1 relative p-0" id="editor-container"></div>

      <!-- Console Drawer -->
      <div id="console-drawer" class="h-[45px] bg-[#0a0a0a] border-t border-white/10 flex flex-col shrink-0 transition-all duration-300 z-10 relative">
        <div class="flex items-center justify-between px-6 h-[45px] cursor-pointer select-none group hover:bg-[#111] transition-colors" id="console-toggle">
          <h3 class="text-gray-400 hover:text-white text-xs font-semibold flex items-center gap-2 uppercase tracking-widest transition-colors">
            <span class="material-symbols-outlined text-[16px]">terminal</span> Output Intercept
          </h3>
          <div class="flex items-center gap-4">
            <span id="status-badge" class="hidden text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono"></span>
            <span class="material-symbols-outlined text-[16px] text-gray-500 group-hover:text-white transition-colors" id="console-icon">expand_less</span>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto p-4 md:p-6 text-[13px] font-mono whitespace-pre-wrap bg-[#050505] leading-relaxed text-gray-300 border-t border-white/5" id="console-output">
          <span class="text-gray-600">Awaiting execution trace...</span>
        </div>
      </div>
    </div>
  </div>

  <script id="server-data" type="application/json">
    <%- JSON.stringify({
      testId: test._id,
      challenges: test.codingBank.challenges.map(c => ({
        id: c._id, title: c.title, difficulty: c.difficulty, 
        description: c.description,
        sampleTest: c.testCases.find(tc => !tc.isHidden) || null
      }))
    }) %>
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const data = JSON.parse(document.getElementById('server-data').textContent);
      const testId = data.testId;
      const challenges = data.challenges;

      const submissions = {};
      challenges.forEach(c => {
        submissions[c.id] = { code: '// Enter entry-point logic here...\n', language: 'javascript' };
      });

      let activeChallengeId = challenges[0].id;

      const editor = CodeMirror(document.getElementById('editor-container'), {
        lineNumbers: true, theme: 'dracula', mode: 'javascript', indentUnit: 4, tabSize: 4, lineWrapping: true
      });

      const langSelect = document.getElementById('language-select');
      const currentTitle = document.getElementById('current-q-title');
      const currentDiff = document.getElementById('current-q-diff');
      const currentDesc = document.getElementById('current-q-desc');
      const tabs = document.querySelectorAll('.challenge-tab');
      
      const consoleDrawer = document.getElementById('console-drawer');
      const consoleToggle = document.getElementById('console-toggle');
      const consoleIcon = document.getElementById('console-icon');
      const statusBadge = document.getElementById('status-badge');
      const outputDiv = document.getElementById('console-output');

      function loadChallenge(id) {
        submissions[activeChallengeId].code = editor.getValue();
        submissions[activeChallengeId].language = langSelect.value;

        activeChallengeId = id;
        const chal = challenges.find(c => c.id === id);
        
        tabs.forEach(t => t.classList.toggle('active', t.dataset.id === id));
        currentTitle.textContent = chal.title;
        currentDiff.textContent = chal.difficulty;

        let diffClass = 'border-gray-500/30 text-gray-400 bg-gray-500/10';
        if(chal.difficulty === 'Easy') diffClass = 'border-green-500/30 text-green-400 bg-green-500/10';
        if(chal.difficulty === 'Medium') diffClass = 'border-orange-500/30 text-orange-400 bg-orange-500/10';
        if(chal.difficulty === 'Hard') diffClass = 'border-red-500/30 text-red-400 bg-red-500/10';
        
        currentDiff.className = `text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono ${diffClass}`;
        
        currentDesc.innerHTML = marked.parse(chal.description);

        langSelect.value = submissions[id].language;
        updateCodeMirrorMode(submissions[id].language);
        editor.setValue(submissions[id].code);

        if(consoleIcon.textContent === 'expand_more') consoleToggle.click();
        statusBadge.classList.add('hidden');
        outputDiv.innerHTML = '<span class="text-gray-600">Awaiting execution trace...</span>';
      }

      function updateCodeMirrorMode(lang) {
        let mode = 'javascript';
        if (lang === 'python') mode = 'python';
        if (['cpp', 'c', 'java'].includes(lang)) mode = 'text/x-c++src';
        editor.setOption('mode', mode);
      }

      langSelect.addEventListener('change', (e) => updateCodeMirrorMode(e.target.value));
      tabs.forEach(t => t.addEventListener('click', () => loadChallenge(t.dataset.id)));
      loadChallenge(activeChallengeId);

      consoleToggle.addEventListener('click', () => {
        if (consoleDrawer.style.height === '40%') {
          consoleDrawer.style.height = '45px'; consoleIcon.textContent = 'expand_less';
        } else {
          consoleDrawer.style.height = '40%'; consoleIcon.textContent = 'expand_more';
        }
      });
      function forceOpenConsole() { if(consoleDrawer.style.height !== '40%') consoleToggle.click(); }
      function setStatus(msg, type) {
        statusBadge.textContent = msg;
        statusBadge.classList.remove('hidden');
        statusBadge.className = `text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono ${type==='err'?'border-red-500/30 bg-red-500/10 text-red-400':(type==='ok'?'border-green-500/30 bg-green-500/10 text-green-400':'border-white/30 bg-white/10 text-white')}`;
      }

      document.getElementById('run-btn').addEventListener('click', async () => {
        forceOpenConsole();
        outputDiv.innerHTML = '<span class="text-white animate-pulse font-mono tracking-widest">Executing on container...</span>';
        setStatus('Running', 'warn');
        document.getElementById('run-btn').disabled = true;

        const code = editor.getValue();
        const chal = challenges.find(c => c.id === activeChallengeId);
        const input = chal.sampleTest ? chal.sampleTest.input : '';

        try {
          const res = await fetch('/api/coding/student/execute', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, language: langSelect.value, input })
          });
          const data = await res.json();

          if(data.status === 'Compilation Error') {
            outputDiv.innerHTML = `<span class="text-red-400"><strong>Compilation Error:</strong>\n${escapeHtml(data.output)}</span>`;
            setStatus('Error', 'err');
          } else {
             let expected = chal.sampleTest ? chal.sampleTest.expectedOutput.trim() : '';
             let got = (data.output || '').trim();
             let out = `<strong class="text-gray-400">Standard Output:</strong>\n<span class="text-white">${escapeHtml(got || '(No Output)')}</span>\n\n`;
             if(chal.sampleTest) {
               if(expected === got) {
                 out += `<span class="text-green-400 font-mono text-xs block mt-2 border border-green-500/20 bg-green-500/10 px-3 py-2 rounded">✓ Passed I/O Match</span>`;
                 setStatus('Passed', 'ok');
               } else {
                 out += `<span class="text-red-400 mt-2 block font-mono text-xs border border-red-500/20 bg-red-500/10 px-3 py-2 rounded">✗ Output Mismatch\n<span class="text-gray-500 mt-1 block">Expected Control: ${escapeHtml(expected)}</span></span>`;
                 setStatus('Failed', 'err');
               }
             } else {
                 setStatus('Success', 'ok');
             }
             outputDiv.innerHTML = out;
          }
        } catch(e) {
          outputDiv.innerHTML = `<span class="text-red-400">Network Trace Error: ${e.message}</span>`;
          setStatus('Error', 'err');
        } finally {
          document.getElementById('run-btn').disabled = false;
        }
      });

      document.getElementById('final-submit-btn').addEventListener('click', async () => {
        const rollNo = document.getElementById('roll-no').value.trim();
        if(!rollNo) return alert('Enter your Candidate ID to commit.');
        if(!confirm('Acknowledge: Committing this payload will lock all buffers permanently.')) return;

        submissions[activeChallengeId].code = editor.getValue();
        submissions[activeChallengeId].language = langSelect.value;
        
        forceOpenConsole();
        outputDiv.innerHTML = '<span class="text-white animate-pulse font-mono tracking-widest">Grading buffers against hidden I/O records...</span>';
        setStatus('Commit', 'warn');
        document.getElementById('final-submit-btn').disabled = true;

        const payload = Object.keys(submissions).map(id => ({
          challengeId: id, code: submissions[id].code, language: submissions[id].language
        }));

        try {
          const res = await fetch('/api/coding/student/submit', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ studentRollNo: rollNo, testId: testId, submissions: payload })
          });
          
          if(res.ok) {
            outputDiv.innerHTML = `<span class="text-green-400 font-medium block mb-2">Payload successfully archived.</span><div class="text-gray-500 text-xs">Final execution grade mapped to candidate footprint.</div>`;
            setStatus('Archived', 'ok');
            setTimeout(() => { document.body.innerHTML = `<div class="h-screen w-full flex items-center justify-center bg-[#000] relative"><div class="absolute inset-0 grid-bg pointer-events-none z-0"></div><div class="text-center p-12 bg-[#0a0a0a] shadow-2xl rounded-2xl border border-white/10 relative z-10"><span class="material-symbols-outlined text-white text-4xl mb-6 block bg-white/5 border border-white/10 w-20 h-20 rounded-xl mx-auto flex items-center justify-center">task_alt</span><h1 class="text-2xl font-semibold text-white tracking-tight">Session Committed</h1><p class="text-gray-500 font-mono text-xs uppercase tracking-widest mt-4">Safe terminal closure permitted</p></div></div>`; }, 3000);
          } else {
            const data = await res.json();
            outputDiv.innerHTML = `<span class="text-red-400">${data.message || 'System fault during commit.'}</span>`;
            setStatus('Error', 'err');
          }
        } catch(e) {
          outputDiv.innerHTML = `<span class="text-red-400">Network fault: ${e.message}</span>`;
          setStatus('Error', 'err');
        } finally {
          document.getElementById('final-submit-btn').disabled = false;
        }
      });

      function escapeHtml(unsafe) { return unsafe.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
    });
  </script>
</body>
</html>
