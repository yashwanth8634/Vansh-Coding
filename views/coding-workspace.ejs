<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= test.codingBank.title %> | Mr & Ms Coder Coding Round
  </title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/dracula.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/javascript/javascript.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/python/python.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/clike/clike.min.js"></script>
    <link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/addon/hint/show-hint.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/addon/hint/show-hint.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/addon/hint/javascript-hint.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/addon/hint/anyword-hint.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
      .CodeMirror {
        height: 100% !important;
        font-family: 'Fira Code', monospace;
        padding-bottom: 50px;
        /* Pre-allocate space for console drawer on mobile */
      }
    </style>
</head>

<body
  class="vc-app min-h-screen md:h-screen overflow-x-hidden md:overflow-hidden flex flex-col p-3 md:p-5 gap-4 relative selection:bg-white/30 text-white">

  <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

  <div id="start-modal"
    class="fixed inset-0 bg-black/80 backdrop-blur-md z-[100] flex items-center justify-center p-4 md:p-6 overflow-y-auto">
    <div
      class="glass-card rounded-2xl p-6 md:p-10 lg:p-12 w-full max-w-md md:max-w-3xl relative overflow-hidden max-h-[calc(100vh-2rem)] md:max-h-[calc(100vh-3rem)] overflow-y-auto my-auto">
      <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="text-center mb-10 relative z-10">
        <div
          class="mx-auto w-12 h-12 border border-white/20 bg-white/5 rounded-xl flex items-center justify-center mb-6 shadow-inner">
          <span class="material-symbols-outlined text-white text-[24px]">schedule</span>
        </div>
        <h1 class="text-2xl font-semibold text-white tracking-tight mb-2">Mr & Ms Coder Coding Round</h1>
        <p class="text-gray-400 font-light text-sm">Enter details to begin your Vansh2k26 attempt</p>
      </div>

      <div id="coding-details-form" class="grid grid-cols-1 md:grid-cols-2 gap-4 relative z-10">
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-gray-500 text-[18px]">person</span>
          </div>
          <input id="start-name" type="text" placeholder="Student Name"
            class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none"
            required>
        </div>

        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-gray-500 text-[18px]">badge</span>
          </div>
          <input id="start-roll-no" type="text" placeholder="Roll Number"
            class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none"
            required>
        </div>

        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-gray-500 text-[18px]">apartment</span>
          </div>
          <select id="start-department"
            class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none appearance-none"
            required>
            <option value="">Select Department</option>
            <option value="CSE">CSE</option>
            <option value="CSE(AI&ML)">CSE(AI&amp;ML)</option>
            <option value="CSE(DS)">CSE(DS)</option>
            <option value="IT">IT</option>
            <option value="ECE">ECE</option>
            <option value="EEE">EEE</option>
            <option value="CIVIL">CIVIL</option>
            <option value="MECH">MECH</option>
            <option value="EIE">EIE</option>
            <option value="AI&DS">AI&amp;DS</option>
            <option value="AI&ML">AI&amp;ML</option>
          </select>
        </div>

        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-gray-500 text-[18px]">school</span>
          </div>
          <select id="start-year"
            class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none appearance-none"
            required>
            <option value="">Select Year</option>
            <option value="1">1st Year</option>
            <option value="2">2nd Year</option>
            <option value="3">3rd Year</option>
            <option value="4">4th Year</option>
          </select>
        </div>

        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-gray-500 text-[18px]">groups</span>
          </div>
          <input id="start-section" type="text" placeholder="Section (Optional)"
            class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none">
        </div>

        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <span class="material-symbols-outlined text-gray-500 text-[18px]">school</span>
          </div>
          <input id="start-college" type="text" placeholder="College Name (leave blank if Vignan)"
            class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none">
        </div>

        <button id="start-session-btn" class="btn-primary w-full md:col-span-2 py-3 px-4">
          Start Test <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        </button>
      </div>

      <div id="coding-rules-screen" class="hidden relative z-10">
        <div class="rounded-2xl border border-white/10 bg-[#0a0a0a] p-5 md:p-6 lg:p-7 shadow-inner">
          <div class="flex items-start gap-3 max-w-2xl">
            <div
              class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-amber-500/20 bg-amber-500/10 text-amber-400">
              <span class="material-symbols-outlined text-[20px]">gavel</span>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Rules & Instructions</p>
              <h2 class="mt-2 text-xl font-semibold text-white tracking-tight">Read carefully before you begin</h2>
              <p class="mt-2 text-sm text-gray-400 leading-relaxed">Your coding test will start only after you accept
                these instructions.</p>
            </div>
          </div>

          <div class="mt-5 rounded-2xl border border-[#fda29b] bg-[#fff1f0] p-4 md:p-5">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#d92d20] text-[20px]">warning</span>
              <div>
                <p class="text-sm font-semibold text-[#d92d20]">Important fullscreen warning</p>
                <p class="mt-1 text-sm leading-relaxed text-[#b42318]">
                  If you press <strong>Esc</strong>, leave fullscreen, switch tabs, or come back from fullscreen during
                  the test, your test may be automatically submitted. Please be careful.
                </p>
              </div>
            </div>
          </div>

          <ul class="mt-5 grid grid-cols-1 lg:grid-cols-2 gap-3">
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Enter only your correct details. You will have only
                  one valid attempt.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">The timer starts only after you agree and begin the
                  coding session.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Do not switch tabs, leave fullscreen, or minimize the
                  window during the test.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Use only the allowed editor and tools inside the
                  platform. External help is not allowed.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5 lg:col-span-2">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Once submitted, your coding answers are locked and
                  cannot be changed.</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="mt-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <button type="button" id="edit-coding-details-btn" class="btn-ghost w-full md:w-auto py-3 px-5">
            Edit Details
          </button>
          <button type="button" id="confirm-coding-rules-btn"
            class="btn-secondary w-full md:w-auto md:min-w-[240px] py-3.5 px-6">
            I Agree, Start Test
            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          </button>
        </div>
        <p id="start-modal-error" class="hidden text-red-400 text-xs text-center font-medium"></p>
      </div>
    </div>
  </div>

  <div id="security-warning-modal"
    class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[100] items-center justify-center p-6">
    <div class="glass-card rounded-2xl shadow-2xl p-8 md:p-10 w-full max-w-md text-center border border-red-500/30">
      <div
        class="w-16 h-16 bg-red-500/10 border border-red-500/20 text-red-400 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-[32px]">security</span>
      </div>

      <h2 class="text-2xl font-semibold text-white tracking-tight mb-2">Warning!</h2>
      <p class="text-sm font-light text-gray-400 mb-6 leading-relaxed">You left fullscreen or switched tabs.</p>

      <div class="bg-red-500/10 border border-red-500/20 p-4 rounded-xl mb-8">
        <p class="text-[11px] text-red-400 uppercase tracking-widest leading-relaxed">If this happens again, your coding
          session will be automatically submitted.</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button id="return-to-coding" class="btn-secondary flex-1 py-3 px-4">
          Return to Session
        </button>
        <button id="submit-coding-now" class="btn-ghost w-full sm:w-max py-3 px-4">
          Submit Now
        </button>
      </div>
    </div>
  </div>

  <!-- Top Nav Pill -->
  <nav
    class="glass-nav rounded-2xl px-4 md:px-6 py-4 md:py-0 md:h-20 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 shrink-0 z-10 shadow-lg relative overflow-hidden">
    <div class="absolute top-0 right-1/2 w-48 h-10 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="flex items-center gap-3 md:gap-4 relative z-10 w-full md:w-auto">
      <div class="border border-white/10 bg-white/5 w-10 h-10 rounded-xl flex items-center justify-center">
        <span class="material-symbols-outlined text-white text-[20px]">terminal</span>
      </div>
      <div>
        <h1 class="font-semibold text-sm md:text-base tracking-tight leading-none text-white">
          <%= test.codingBank.title %>
        </h1>
        <p id="student-session-meta" class="text-gray-500 text-[10px] font-mono uppercase tracking-widest mt-1">
          Vansh2k26 Coding Arena</p>
      </div>
    </div>
    <div class="flex w-full md:w-auto flex-wrap items-center gap-3 md:gap-4 relative z-10">
      <div id="session-timer"
        class="bg-[#0a0a0a] text-white border border-white/10 rounded-lg px-4 py-2 text-sm font-mono tracking-widest min-w-[88px] text-center">
        --:--
      </div>
      <input type="text" id="roll-no" placeholder="Roll Number"
        class="flex-1 md:flex-none min-w-[150px] bg-[#0a0a0a] text-white placeholder-gray-600 border border-white/10 rounded-lg px-4 py-2 text-sm font-medium outline-none transition-all uppercase tracking-widest text-center w-full md:w-48 shadow-inner"
        readonly>
      <button id="final-submit-btn" class="btn-secondary w-full sm:w-auto px-6 py-2">
        <span class="material-symbols-outlined text-[18px]">publish</span> <span class="hidden sm:inline">Submit Final
          Test</span>
      </button>
    </div>
  </nav>

  <!-- Complete Workspace Split Panes -->
  <div class="flex-1 min-h-0 flex flex-col md:flex-row gap-4 overflow-visible md:overflow-hidden z-10 relative">

    <!-- LEFT MOST: Question Navigator -->
    <div
      class="w-full h-28 md:h-full md:w-20 lg:w-64 glass-card rounded-2xl flex flex-col shrink-0 overflow-hidden shadow-2xl">
      <div class="px-5 py-4 border-b border-white/10 bg-[#050505] shrink-0 hidden lg:flex items-center justify-between">
        <h3 class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest">Question Bank</h3>
        <span class="material-symbols-outlined text-[16px] text-gray-500">format_list_bulleted</span>
      </div>
      <div class="flex-1 overflow-x-auto md:overflow-x-hidden md:overflow-y-auto p-3 flex md:flex-col gap-2"
        id="question-tabs">
        <% test.codingBank.challenges.forEach((c, index)=> { %>
          <button data-id="<%= c._id %>"
            class="challenge-tab shrink-0 md:shrink w-auto md:w-full text-left p-3 rounded-xl border border-transparent hover:bg-white/5 transition-all flex items-center gap-3 group">
            <div
              class="w-8 h-8 rounded-lg shrink-0 bg-[#0a0a0a] border border-white/10 group-[.active]:bg-white group-[.active]:text-black text-gray-400 flex items-center justify-center font-mono text-sm transition-colors">
              <%= index + 1 %>
            </div>
            <div class="hidden lg:block truncate">
              <div class="text-sm font-medium text-gray-300 group-[.active]:text-white truncate mb-0.5">
                <%= c.title %>
              </div>
              <div class="text-[10px] font-mono uppercase tracking-widest text-gray-500 group-[.active]:text-gray-400">
                <%= c.difficulty %>
              </div>
            </div>
          </button>
          <% }); %>
      </div>
    </div>

    <!-- MIDDLE: Problem Description -->
    <div
      class="flex flex-col w-full md:w-1/3 xl:w-[35%] min-h-[260px] md:min-h-0 rounded-2xl border border-white/10 overflow-hidden shrink-0 bg-[#0a0a0a]">
      <div class="px-6 py-5 border-b border-white/10 bg-transparent shrink-0">
        <div class="flex items-center gap-3 mb-2">
          <span id="current-q-diff"
            class="text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono">--</span>
        </div>
        <h2 id="current-q-title" class="text-xl font-semibold text-white tracking-tight">Loading...</h2>
      </div>
      <div id="current-q-desc"
        class="p-5 md:p-8 overflow-y-auto flex-1 max-w-none text-gray-300 font-normal leading-relaxed whitespace-pre-wrap">
        <!-- Markdown -->
      </div>
    </div>

    <!-- RIGHT: Code Editor & Console -->
    <div
      class="flex-1 min-h-[480px] md:min-h-0 flex flex-col bg-[#050505] rounded-2xl border border-white/10 overflow-hidden relative shadow-2xl">
      <div
        class="bg-[#0a0a0a] border-b border-white/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 px-4 py-3 shrink-0">
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <span class="material-symbols-outlined text-[16px] text-gray-500">code</span>
          <select id="language-select"
            class="bg-transparent text-gray-300 text-xs font-mono outline-none hover:text-white transition-colors cursor-pointer appearance-none border border-transparent hover:border-white/10 px-2 py-1 rounded w-full sm:w-auto">
            <option value="javascript" class="bg-[#111]">JavaScript (Node.js 20)</option>
            <option value="python" class="bg-[#111]">Python 3.12</option>
            <option value="java" class="bg-[#111]">Java 22</option>
            <option value="cpp" class="bg-[#111]">C++ (GCC 13)</option>
            <option value="c" class="bg-[#111]">C (GCC 13)</option>
          </select>
        </div>
        <button id="run-btn" class="btn-ghost w-full sm:w-auto px-4 py-2 text-xs">
          <span class="material-symbols-outlined text-[16px]">play_arrow</span> Run <span
            class="hidden xl:inline">Code</span>
        </button>
      </div>

      <!-- Editor -->
      <div class="flex-1 relative p-0" id="editor-container"></div>

      <!-- Console Drawer -->
      <div id="console-drawer"
        class="h-[45px] bg-[#0a0a0a] border-t border-white/10 flex flex-col shrink-0 transition-all duration-300 z-10 relative">
        <div
          class="flex items-center justify-between px-6 h-[45px] cursor-pointer select-none group hover:bg-[#111] transition-colors"
          id="console-toggle">
          <h3
            class="text-gray-400 hover:text-white text-xs font-semibold flex items-center gap-2 uppercase tracking-widest transition-colors">
            <span class="material-symbols-outlined text-[16px]">terminal</span> Execution Console
          </h3>
          <div class="flex items-center gap-4">
            <span id="status-badge"
              class="hidden text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono"></span>
            <span class="material-symbols-outlined text-[16px] text-gray-500 group-hover:text-white transition-colors"
              id="console-icon">expand_less</span>
          </div>
        </div>
        <div
          class="flex-1 overflow-y-auto p-4 md:p-6 text-[13px] font-mono whitespace-pre-wrap bg-[#050505] leading-relaxed text-gray-300 border-t border-white/5"
          id="console-output">
          <span class="text-gray-600">Waiting for execution...</span>
        </div>
      </div>
    </div>
  </div>

  <script id="server-data" type="application/json">
    <%- JSON.stringify({
      testId: test._id,
      challenges: test.codingBank.challenges.map(c => ({
        id: c._id, title: c.title, difficulty: c.difficulty, 
        description: c.description,
        sampleTest: c.testCases.find(tc => !tc.isHidden) || null
      }))
    }) %>
  </script>

  <div id="submit-confirm-modal"
    class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[110] hidden items-center justify-center p-4">
    <div class="glass-card rounded-2xl p-6 max-w-sm w-full text-center relative overflow-hidden">
      <div
        class="mx-auto w-12 h-12 rounded-full bg-blue-500/10 border border-blue-500/30 flex items-center justify-center mb-4">
        <span class="material-symbols-outlined text-blue-500">publish</span>
      </div>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">Submit Final Test?</h2>
      <p class="text-gray-600 text-sm mb-6">Are you absolutely certain? This will lock your answers and submit the test.
      </p>
      <div class="flex gap-3">
        <button id="cancel-submit-btn" class="btn-ghost flex-1 py-3 px-4 !m-0">Cancel</button>
        <button id="confirm-submit-btn" class="btn-primary flex-1 py-3 px-4 !m-0">Submit</button>
      </div>
    </div>
  </div>

  <div id="success-overlay"
    class="fixed inset-0 bg-white/60 backdrop-blur-md z-[120] hidden items-center justify-center px-6 transition-opacity duration-500 opacity-0">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>
    <div
      class="w-full max-w-lg text-center p-10 md:p-12 glass-card rounded-3xl relative z-10 transition-transform duration-500 translate-y-4 scale-95"
      id="success-content">
      <div
        class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-2xl border border-green-500/30 bg-green-500/10">
        <span class="material-symbols-outlined text-green-600 text-[34px] leading-none">task_alt</span>
      </div>
      <h1 class="text-3xl font-semibold text-gray-900 tracking-tight">Assessment Complete</h1>
      <p class="mt-4 text-gray-600 text-sm leading-relaxed">Your coding test has been submitted successfully.</p>
      <a href="/" class="btn-primary mt-8 inline-flex w-full sm:w-auto px-8 py-3">
        <span class="material-symbols-outlined text-[18px]">home</span> Return to Home
      </a>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const serverDataNode = document.getElementById('server-data');
      const data = serverDataNode && serverDataNode.textContent ? JSON.parse(serverDataNode.textContent) : { testId: null, challenges: [] };
      const testId = data.testId;
      const uniqueLink = window.location.pathname.split('/').pop();
      let challenges = data.challenges || [];
      let sessionDurationMinutes = <%= Number(test.durationMinutes || 30) %>;

      const STARTER_TEMPLATES = {
        javascript: `// Read input
const input = require('fs').readFileSync(0, 'utf8').trim();
const lines = input.split('\\n');

// Write your solution here


`,
        python: `# Read input
import sys
input_data = sys.stdin.read().strip()
lines = input_data.split('\\n')

# Write your solution here


`,
        java: `import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Write your solution here


        sc.close();
    }
}
`,
        cpp: `#include <iostream>
using namespace std;

int main() {
    // Write your solution here


    return 0;
}
`,
        c: `#include <stdio.h>

int main() {
    // Write your solution here


    return 0;
}
`,
      };

      const submissions = {};
      challenges.forEach((c) => {
        submissions[c.id] = {
          code: STARTER_TEMPLATES.javascript,
          language: 'javascript',
          templateLanguage: 'javascript',
        };
      });

      let activeChallengeId = challenges.length > 0 ? challenges[0].id : null;

      const editor = CodeMirror(document.getElementById('editor-container'), {
        lineNumbers: true, theme: 'dracula', mode: 'javascript', indentUnit: 4, tabSize: 4, lineWrapping: true,
        extraKeys: { "Ctrl-Space": "autocomplete" }
      });

      const langSelect = document.getElementById('language-select');
      const currentTitle = document.getElementById('current-q-title');
      const currentDiff = document.getElementById('current-q-diff');
      const currentDesc = document.getElementById('current-q-desc');
      const questionTabsContainer = document.getElementById('question-tabs');
      let tabs = document.querySelectorAll('.challenge-tab');

      function renderQuestionTabs() {
        questionTabsContainer.innerHTML = '';
        challenges.forEach((c, index) => {
          const btn = document.createElement('button');
          btn.dataset.id = c.id;
          btn.className = `challenge-tab shrink-0 md:shrink w-auto md:w-full text-left p-3 rounded-xl border border-transparent hover:bg-white/5 transition-all flex items-center gap-3 group ${activeChallengeId === c.id ? 'active' : ''}`;
          
          btn.innerHTML = `
            <div class="w-8 h-8 rounded-lg shrink-0 bg-[#0a0a0a] border border-white/10 group-[.active]:bg-white group-[.active]:text-black text-gray-400 flex items-center justify-center font-mono text-sm transition-colors">
              ${index + 1}
            </div>
            <div class="hidden lg:block truncate">
              <div class="text-sm font-medium text-gray-300 group-[.active]:text-white truncate mb-0.5">
                ${c.title}
              </div>
              <div class="text-[10px] font-mono uppercase tracking-widest text-gray-500 group-[.active]:text-gray-400">
                ${c.difficulty}
              </div>
            </div>
          `;
          
          btn.addEventListener('click', () => loadChallenge(c.id));
          questionTabsContainer.appendChild(btn);
        });
        tabs = document.querySelectorAll('.challenge-tab');
      }

      const consoleDrawer = document.getElementById('console-drawer');
      const consoleToggle = document.getElementById('console-toggle');
      const consoleIcon = document.getElementById('console-icon');
      const statusBadge = document.getElementById('status-badge');
      const outputDiv = document.getElementById('console-output');
      const sessionTimerEl = document.getElementById('session-timer');
      const studentSessionMeta = document.getElementById('student-session-meta');
      const rollNoInput = document.getElementById('roll-no');
      const startModal = document.getElementById('start-modal');
      const codingDetailsForm = document.getElementById('coding-details-form');
      const codingRulesScreen = document.getElementById('coding-rules-screen');
      const startNameInput = document.getElementById('start-name');
      const startRollNoInput = document.getElementById('start-roll-no');
      const startDepartmentInput = document.getElementById('start-department');
      const startYearInput = document.getElementById('start-year');
      const startSectionInput = document.getElementById('start-section');
      const startCollegeInput = document.getElementById('start-college');
      const startSessionBtn = document.getElementById('start-session-btn');
      const editCodingDetailsBtn = document.getElementById('edit-coding-details-btn');
      const confirmCodingRulesBtn = document.getElementById('confirm-coding-rules-btn');
      const startModalError = document.getElementById('start-modal-error');
      const runBtn = document.getElementById('run-btn');
      const finalSubmitBtn = document.getElementById('final-submit-btn');
      const securityWarningModal = document.getElementById('security-warning-modal');
      const returnToCodingBtn = document.getElementById('return-to-coding');
      const submitCodingNowBtn = document.getElementById('submit-coding-now');
      const STATE = { IDLE: 0, RUNNING: 1, SUBMITTING: 2, FINISHED: 3 };
      let currentState = STATE.IDLE;
      let sessionTimeLeftSeconds = Math.max(1, sessionDurationMinutes) * 60;
      let sessionTimerId = null;
      let hasStarted = false;
      let warningCount = 0;
      let warningDebounceToken = 0;
      let studentProfile = null;
      let pendingStudentProfile = null;

      const IDLE_RUN_HTML = '<span class="material-symbols-outlined text-[16px]">play_arrow</span> Run <span class="hidden xl:inline">Code</span>';
      const IDLE_SUBMIT_HTML = '<span class="material-symbols-outlined text-[18px]">publish</span> <span class="hidden sm:inline">Submit Final Test</span>';

      function setBusyState(button, isBusy, idleMarkup, busyMarkup) {
        button.disabled = isBusy;
        button.classList.toggle('opacity-70', isBusy);
        button.classList.toggle('cursor-not-allowed', isBusy);
        button.innerHTML = isBusy ? busyMarkup : idleMarkup;
      }

      function getStarterTemplate(language) {
        return STARTER_TEMPLATES[language] || STARTER_TEMPLATES.javascript;
      }

      function syncActiveSubmission() {
        if (!activeChallengeId) return;
        submissions[activeChallengeId].code = editor.getValue();
        submissions[activeChallengeId].language = langSelect.value;
      }

      function loadChallenge(id, isInitialLoad = false) {
        if (!id) return;
        if (!isInitialLoad) syncActiveSubmission();

        activeChallengeId = id;
        const chal = challenges.find(c => c.id === id);
        if (!chal) return;

        tabs.forEach(t => t.classList.toggle('active', t.dataset.id === id));
        currentTitle.textContent = chal.title;
        currentDiff.textContent = chal.difficulty;

        let diffClass = 'border-gray-500/30 text-gray-400 bg-gray-500/10';
        if (chal.difficulty === 'Easy') diffClass = 'border-green-500/30 text-green-400 bg-green-500/10';
        if (chal.difficulty === 'Medium') diffClass = 'border-orange-500/30 text-orange-400 bg-orange-500/10';
        if (chal.difficulty === 'Hard') diffClass = 'border-red-500/30 text-red-400 bg-red-500/10';

        currentDiff.className = `text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono ${diffClass}`;

        currentDesc.textContent = chal.description;

        langSelect.value = submissions[id].language;
        updateCodeMirrorMode(submissions[id].language);
        editor.setValue(submissions[id].code);

        if (consoleIcon.textContent === 'expand_more') consoleToggle.click();
        statusBadge.classList.add('hidden');
        outputDiv.innerHTML = '<span class="text-gray-600">Awaiting execution trace...</span>';
      }

      function updateCodeMirrorMode(lang) {
        let mode = 'javascript';
        if (lang === 'python') mode = 'python';
        if (lang === 'java') mode = 'text/x-java';
        if (['cpp', 'c'].includes(lang)) mode = 'text/x-c++src';
        editor.setOption('mode', mode);
      }

      function renderSessionTimer() {
        const minutes = Math.floor(sessionTimeLeftSeconds / 60);
        const seconds = sessionTimeLeftSeconds % 60;
        sessionTimerEl.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
      }

      function startSessionTimer() {
        renderSessionTimer();
        sessionTimerId = setInterval(() => {
          if (currentState === STATE.FINISHED) {
            clearInterval(sessionTimerId);
            return;
          }

          sessionTimeLeftSeconds -= 1;
          if (sessionTimeLeftSeconds <= 0) {
            clearInterval(sessionTimerId);
            sessionTimeLeftSeconds = 0;
            renderSessionTimer();
            submitFinal(true);
            return;
          }

          renderSessionTimer();
        }, 1000);
      }

      function lockWorkspaceUntilStart() {
        tabs.forEach((tab) => {
          tab.disabled = true;
          tab.classList.add('opacity-50', 'cursor-not-allowed');
        });
        langSelect.disabled = true;
        runBtn.disabled = true;
        finalSubmitBtn.disabled = true;
        rollNoInput.readOnly = true;
        editor.setOption('readOnly', 'nocursor');
        sessionTimerEl.textContent = '--:--';
      }

      function unlockWorkspaceAfterStart() {
        tabs.forEach((tab) => {
          tab.disabled = false;
          tab.classList.remove('opacity-50', 'cursor-not-allowed');
        });
        langSelect.disabled = false;
        runBtn.disabled = false;
        finalSubmitBtn.disabled = false;
        editor.setOption('readOnly', false);
      }

      function addSecurityListeners() {
        window.addEventListener('beforeunload', (event) => {
          if (currentState !== STATE.FINISHED && hasStarted) {
            event.preventDefault();
            event.returnValue = '';
          }
        });

        const handleVisibilityChange = () => {
          if (hasStarted && currentState !== STATE.FINISHED && document.hidden) {
            handleWarning();
          }
        };

        const handleFullscreenChange = () => {
          if (hasStarted && currentState !== STATE.FINISHED && !document.fullscreenElement) {
            handleWarning();
          }
        };

        document.addEventListener('visibilitychange', handleVisibilityChange);
        document.addEventListener('fullscreenchange', handleFullscreenChange);
      }

      function handleWarning() {
        if (currentState === STATE.FINISHED) return;

        const now = Date.now();
        if (now - warningDebounceToken < 500) return;
        warningDebounceToken = now;

        warningCount += 1;

        if (warningCount === 1) {
          securityWarningModal.classList.remove('hidden');
          securityWarningModal.classList.add('flex');
          return;
        }

        submitFinal(true);
      }

      window.addEventListener('pagehide', () => {
        if (!hasStarted || currentState === STATE.FINISHED || currentState === STATE.SUBMITTING || !studentProfile || !studentProfile.rollNo) {
          return;
        }
        syncActiveSubmission();
        const payload = Object.keys(submissions).map((id) => ({
          challengeId: id,
          code: submissions[id].code,
          language: submissions[id].language,
        }));
        const data = JSON.stringify({
          studentName: studentProfile.name,
          studentRollNo: studentProfile.rollNo,
          studentDepartment: studentProfile.department,
          studentYear: studentProfile.year,
          studentSection: studentProfile.section,
          studentCollege: studentProfile.collegeName,
          testId,
          submissions: payload,
        });
        navigator.sendBeacon('/api/coding/student/submit', new Blob([data], { type: 'application/json' }));
      });

      langSelect.addEventListener('change', (e) => {
        const nextLanguage = e.target.value;
        const submission = submissions[activeChallengeId];
        const currentCode = editor.getValue();
        const previousTemplate = getStarterTemplate(submission.templateLanguage || submission.language);
        const shouldInjectTemplate = !currentCode.trim() || currentCode === previousTemplate;

        submission.language = nextLanguage;
        submission.templateLanguage = nextLanguage;
        updateCodeMirrorMode(nextLanguage);

        if (shouldInjectTemplate) {
          const nextTemplate = getStarterTemplate(nextLanguage);
          submission.code = nextTemplate;
          submission.templateLanguage = nextLanguage;
          editor.setValue(nextTemplate);
        } else {
          submission.code = currentCode;
        }
      });
      tabs.forEach(t => t.addEventListener('click', () => loadChallenge(t.dataset.id)));
      if (activeChallengeId) {
        loadChallenge(activeChallengeId, true);
      } else {
        currentTitle.textContent = 'Click Start Test to load your coding questions';
        currentDiff.textContent = 'Pending';
        currentDiff.className = 'text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono border-gray-500/30 text-gray-400 bg-gray-500/10';
        currentDesc.textContent = 'Questions are assigned after student verification.';
      }
      lockWorkspaceUntilStart();

      startSessionBtn.addEventListener('click', () => {
        const enteredName = startNameInput.value.trim();
        const enteredRollNo = startRollNoInput.value.trim();
        const enteredDepartment = startDepartmentInput.value.trim();
        const enteredYear = startYearInput.value.trim();
        const enteredSection = startSectionInput.value.trim();
        const enteredCollege = startCollegeInput.value.trim();

        if (!enteredName || !enteredRollNo || !enteredDepartment || !enteredYear) {
          startModalError.textContent = 'Name, roll number, department, and year are required to start.';
          startModalError.classList.remove('hidden');
          return;
        }

        startModalError.classList.add('hidden');
        pendingStudentProfile = {
          uniqueLink,
          name: enteredName,
          rollNo: enteredRollNo,
          department: enteredDepartment,
          year: enteredYear,
          section: enteredSection,
          collegeName: enteredCollege,
        };
        codingDetailsForm.classList.add('hidden');
        codingRulesScreen.classList.remove('hidden');
      });

      editCodingDetailsBtn.addEventListener('click', () => {
        codingRulesScreen.classList.add('hidden');
        codingDetailsForm.classList.remove('hidden');
      });

      confirmCodingRulesBtn.addEventListener('click', async () => {
        if (confirmCodingRulesBtn.disabled || !pendingStudentProfile) {
          return;
        }

        startModalError.classList.add('hidden');
        const idleMarkup = 'I Agree, Start Test <span class="material-symbols-outlined text-[18px]">arrow_forward</span>';
        confirmCodingRulesBtn.disabled = true;
        confirmCodingRulesBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px] align-middle">sync</span> Please wait...';

        try {
          const response = await fetch('/api/coding/student/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(pendingStudentProfile),
          });
          let result = {};
          try {
            result = await response.json();
          } catch (parseErr) {
            result = {};
          }

          if (!response.ok) {
            startModalError.textContent = result.message || 'Unable to start coding test.';
            startModalError.classList.remove('hidden');
            codingRulesScreen.classList.add('hidden');
            codingDetailsForm.classList.remove('hidden');
            return;
          }

          studentProfile = result.student;
          hasStarted = true;
          
          // Update challenges from API response
          if (result.challenges && result.challenges.length > 0) {
            challenges = result.challenges;
            activeChallengeId = challenges[0] ? challenges[0].id : null;
            
            // Re-initialize submissions object for the new challenges
            challenges.forEach((c) => {
              if (!submissions[c.id]) {
                submissions[c.id] = {
                  code: STARTER_TEMPLATES.javascript,
                  language: 'javascript',
                  templateLanguage: 'javascript',
                };
              }
            });
            
            renderQuestionTabs();
            if (activeChallengeId) loadChallenge(activeChallengeId, true);
          }

          if (result.durationMinutes) {
            sessionDurationMinutes = result.durationMinutes;
            sessionTimeLeftSeconds = Math.max(1, sessionDurationMinutes) * 60;
          }

          rollNoInput.value = studentProfile.rollNo.toUpperCase();
          studentSessionMeta.textContent = `${studentProfile.name} • ${studentProfile.department} • ${studentProfile.year}${studentProfile.section ? ` • ${studentProfile.section}` : ''}`;
          startModal.classList.add('hidden');
          unlockWorkspaceAfterStart();
          setTimeout(() => { editor.refresh(); }, 50);
          document.documentElement.requestFullscreen().catch(() => { });
          addSecurityListeners();
          startSessionTimer();
        } catch (error) {
          console.error('Start error:', error);
          startModalError.textContent = 'A network error occurred while starting the coding test.';
          startModalError.classList.remove('hidden');
          codingRulesScreen.classList.add('hidden');
          codingDetailsForm.classList.remove('hidden');
        } finally {
          confirmCodingRulesBtn.disabled = false;
          confirmCodingRulesBtn.innerHTML = idleMarkup;
        }
      });

      returnToCodingBtn.addEventListener('click', () => {
        securityWarningModal.classList.add('hidden');
        securityWarningModal.classList.remove('flex');
        document.documentElement.requestFullscreen().catch(() => { });
      });

      submitCodingNowBtn.addEventListener('click', async () => {
        securityWarningModal.classList.add('hidden');
        securityWarningModal.classList.remove('flex');
        await submitFinal(true);
      });

      [startNameInput, startRollNoInput, startDepartmentInput, startYearInput, startSectionInput, startCollegeInput].forEach((input) => {
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            startSessionBtn.click();
          }
        });
      });

      consoleToggle.addEventListener('click', () => {
        if (consoleDrawer.style.height === '40%') {
          consoleDrawer.style.height = '45px'; consoleIcon.textContent = 'expand_less';
        } else {
          consoleDrawer.style.height = '40%'; consoleIcon.textContent = 'expand_more';
        }
      });
      function forceOpenConsole() { if (consoleDrawer.style.height !== '40%') consoleToggle.click(); }
      function setStatus(msg, type) {
        statusBadge.textContent = msg;
        statusBadge.classList.remove('hidden');
        statusBadge.className = `text-[10px] px-2 py-0.5 border rounded uppercase tracking-widest font-mono ${type === 'err' ? 'border-red-500/30 bg-red-500/10 text-red-400' : (type === 'ok' ? 'border-green-500/30 bg-green-500/10 text-green-400' : 'border-white/30 bg-white/10 text-white')}`;
      }

      document.getElementById('run-btn').addEventListener('click', async () => {
        if (!hasStarted || currentState !== STATE.IDLE) return;
        currentState = STATE.RUNNING;
        forceOpenConsole();
        outputDiv.innerHTML = '<span class="text-white animate-pulse font-mono tracking-widest">Executing code...</span>';
        setStatus('Running', 'warn');
        setBusyState(
          runBtn,
          true,
          IDLE_RUN_HTML,
          '<span class="material-symbols-outlined animate-spin text-[16px]">sync</span> Please wait',
        );

        const code = editor.getValue();
        const chal = challenges.find(c => c.id === activeChallengeId);
        const input = chal.sampleTest ? chal.sampleTest.input : '';

        try {
          const res = await fetch('/api/coding/student/execute', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, language: langSelect.value, input })
          });

          let data;
          try {
            data = await res.json();
          } catch (parseErr) {
            outputDiv.innerHTML = `<span class="text-red-400"><strong>Server Error:</strong>\nReceived a non-JSON response (HTTP ${res.status}). The execution service may be temporarily unavailable.</span>`;
            setStatus('Error', 'err');
            return;
          }

          if (!res.ok) {
            outputDiv.innerHTML = `<span class="text-red-400"><strong>System Error:</strong>\n${escapeHtml(data.error || data.message || 'Execution Failed')}</span>`;
            setStatus('Error', 'err');
          } else if (data.status === 'Compilation Error' || data.status === 'Time Limit Exceeded' || data.status === 'Runtime Error') {
            outputDiv.innerHTML = `<span class="text-red-400"><strong>${escapeHtml(data.status)}:</strong>\n${escapeHtml(data.output)}</span>`;
            setStatus('Error', 'err');
          } else {
            let expected = chal.sampleTest ? chal.sampleTest.expectedOutput.trim() : '';
            let got = (data.output || '').trim();
            let out = `<strong class="text-gray-400">Standard Output:</strong>\n<span class="text-white">${escapeHtml(got || '(No Output)')}</span>\n\n`;
            if (chal.sampleTest) {
              if (expected === got) {
                out += `<span class="text-green-400 font-mono text-xs block mt-2 border border-green-500/20 bg-green-500/10 px-3 py-2 rounded">✓ Passed I/O Match</span>`;
                setStatus('Passed', 'ok');
              } else {
                out += `<span class="text-red-400 mt-2 block font-mono text-xs border border-red-500/20 bg-red-500/10 px-3 py-2 rounded">✗ Output Mismatch\n<span class="text-gray-500 mt-1 block">Expected Control: ${escapeHtml(expected)}</span></span>`;
                setStatus('Failed', 'err');
              }
            } else {
              setStatus('Success', 'ok');
            }
            outputDiv.innerHTML = out;
          }
        } catch (e) {
          outputDiv.innerHTML = `<span class="text-red-400">Network Trace Error: ${e.message}</span>`;
          setStatus('Error', 'err');
        } finally {
          outputDiv.scrollTop = outputDiv.scrollHeight;
          if (currentState === STATE.RUNNING) {
            currentState = STATE.IDLE;
          }
          setBusyState(
            runBtn,
            false,
            IDLE_RUN_HTML,
            '',
          );
        }
      });

      document.getElementById('final-submit-btn').addEventListener('click', async () => {
        if (!hasStarted || currentState !== STATE.IDLE) return;
        document.getElementById('submit-confirm-modal').classList.remove('hidden');
        document.getElementById('submit-confirm-modal').classList.add('flex');
      });

      document.getElementById('cancel-submit-btn').addEventListener('click', () => {
        document.getElementById('submit-confirm-modal').classList.add('hidden');
        document.getElementById('submit-confirm-modal').classList.remove('flex');
      });

      document.getElementById('confirm-submit-btn').addEventListener('click', async () => {
        document.getElementById('submit-confirm-modal').classList.add('hidden');
        document.getElementById('submit-confirm-modal').classList.remove('flex');
        await submitFinal(true);
      });

      async function submitFinal(isAutoSubmit) {
        if (!hasStarted) return;
        if (currentState === STATE.FINISHED || currentState === STATE.SUBMITTING) return;

        if (!studentProfile || !studentProfile.rollNo) {
          forceOpenConsole();
          outputDiv.innerHTML = '<span class="text-red-400">Student details are missing. Please start the coding session again.</span>';
          setStatus('Error', 'err');
          return;
        }

        currentState = STATE.SUBMITTING;
        if (sessionTimerId) clearInterval(sessionTimerId);

        syncActiveSubmission();

        forceOpenConsole();
        outputDiv.innerHTML = '<span class="text-white animate-pulse font-mono tracking-widest">Grading submission against hidden server test cases...</span>';
        setStatus('Commit', 'warn');
        setBusyState(
          finalSubmitBtn,
          true,
          IDLE_SUBMIT_HTML,
          '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> <span class="hidden sm:inline">Submitting...</span>',
        );
        runBtn.disabled = true;

        // ADD JITTER: Random delay (0-3s) to spread server load during spikes
        await new Promise(r => setTimeout(r, Math.random() * 3000));

        const payload = Object.keys(submissions).map(id => ({
          challengeId: id, code: submissions[id].code, language: submissions[id].language
        }));

        try {
          const res = await fetch('/api/coding/student/submit', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              studentName: studentProfile.name,
              studentRollNo: studentProfile.rollNo,
              studentDepartment: studentProfile.department,
              studentYear: studentProfile.year,
              studentSection: studentProfile.section,
              studentCollege: studentProfile.collegeName,
              testId: testId,
              submissions: payload,
            })
          });

          if (res.ok) {
            currentState = STATE.FINISHED;
            if (document.fullscreenElement) {
              document.exitFullscreen().catch(() => { });
            }
            outputDiv.innerHTML = `<span class="text-green-400 font-medium block mb-2">Test Successfully Archived! 🎉</span><div class="text-gray-500 text-xs">Your final score has been logged. You may close this window.</div>`;
            setStatus('Archived', 'ok');
            outputDiv.scrollTop = outputDiv.scrollHeight;

            const overlay = document.getElementById('success-overlay');
            const content = document.getElementById('success-content');
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');

            // Trigger animation
            setTimeout(() => {
              overlay.classList.remove('opacity-0');
              content.classList.remove('translate-y-4', 'scale-95');
            }, 50);

            lockWorkspaceUntilStart();
          } else {
            const data = await res.json();
            outputDiv.innerHTML = `<span class="text-red-400">${data.message || 'System fault during commit.'}</span>`;
            setStatus('Error', 'err');
            currentState = STATE.IDLE;
          }
        } catch (e) {
          outputDiv.innerHTML = `<span class="text-red-400">Network fault: ${e.message}</span>`;
          setStatus('Error', 'err');
          currentState = STATE.IDLE;
        } finally {
          if (currentState !== STATE.FINISHED) {
            setBusyState(
              finalSubmitBtn,
              false,
              IDLE_SUBMIT_HTML,
              '',
            );
            runBtn.disabled = false;
          }
        }
      }
      function escapeHtml(unsafe) {
        return String(unsafe)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;")
          .replace(/`/g, "&#x60;");
      }
    });
  </script>
</body>

</html>
