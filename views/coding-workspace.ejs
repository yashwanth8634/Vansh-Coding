<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= test.codingBank.title %> | Coding Test</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/theme/dracula.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/javascript/javascript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/python/python.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.13/mode/clike/clike.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <style>
    body { font-family: 'Albert Sans', sans-serif; height: 100vh; overflow: hidden; }
    .CodeMirror { height: 100%; font-family: 'Fira Code', monospace; font-size: 14px; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    .dracula-scroll::-webkit-scrollbar-track { background: #282a36; }
    .dracula-scroll::-webkit-scrollbar-thumb { background: #44475a; }
    
    .challenge-tab.active { background-color: #4f46e5; color: white; border-color: #4f46e5; }
  </style>
</head>
<body class="bg-gray-50 flex flex-col">

  <!-- Top Nav -->
  <nav class="bg-gray-900 text-white h-14 flex items-center justify-between px-6 shrink-0 z-10 shadow-md">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-indigo-400">code</span>
      <h1 class="font-bold text-lg hidden sm:block"><%= test.codingBank.title %></h1>
    </div>
    <div class="flex items-center gap-4">
      <input type="text" id="roll-no" placeholder="Enter Roll Number" class="bg-gray-800 text-white border border-gray-700 rounded px-3 py-1.5 text-sm focus:border-indigo-500 font-mono focus:outline-none" required>
      <button id="final-submit-btn" class="bg-green-600 hover:bg-green-700 text-white px-4 py-1.5 rounded text-sm font-bold shadow transition-colors flex items-center gap-1.5">
        <span class="material-symbols-outlined" style="font-size: 16px;">publish</span> Submit Final Test
      </button>
    </div>
  </nav>

  <!-- Complete Workspace -->
  <div class="flex-1 flex overflow-hidden">
    
    <!-- LEFT MOST: Question Navigator (Sidebar) -->
    <div class="w-16 sm:w-64 bg-white border-r border-gray-200 flex flex-col shrink-0 relative z-20 shadow-[1px_0_4px_rgba(0,0,0,0.05)]">
      <div class="p-4 border-b border-gray-100 bg-gray-50 shrink-0 hidden sm:block">
        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider">Questions</h3>
      </div>
      <div class="flex-1 overflow-y-auto p-2 space-y-2" id="question-tabs">
        <% test.codingBank.challenges.forEach((c, index) => { %>
          <button data-id="<%= c._id %>" class="challenge-tab w-full text-left p-3 rounded-lg border border-gray-200 bg-white hover:border-indigo-300 transition-all flex items-center gap-3 group">
            <div class="w-8 h-8 rounded shrink-0 bg-gray-100 group-[.active]:bg-indigo-500 group-[.active]:text-white text-gray-700 flex items-center justify-center font-bold text-sm">
              <%= index + 1 %>
            </div>
            <div class="hidden sm:block truncate">
              <div class="text-sm font-medium text-gray-800 group-[.active]:text-white truncate"><%= c.title %></div>
              <div class="text-xs text-gray-400 group-[.active]:text-indigo-200"><%= c.difficulty %></div>
            </div>
          </button>
        <% }); %>
      </div>
    </div>

    <!-- MIDDLE: Problem Description -->
    <div class="w-full sm:w-1/3 lg:w-[28%] bg-white flex flex-col overflow-hidden shadow-[1px_0_4px_rgba(0,0,0,0.05)] relative z-10 shrink-0 border-r border-gray-200">
      <div class="p-4 sm:p-5 border-b border-gray-100 bg-gray-50 shrink-0">
        <h2 id="current-q-title" class="text-lg font-bold text-gray-900 mb-2">Loading...</h2>
        <span id="current-q-diff" class="text-xs px-2.5 py-1 rounded-full font-medium bg-gray-100 text-gray-600">--</span>
      </div>
      <div id="current-q-desc" class="p-4 sm:p-5 overflow-y-auto flex-1 prose prose-sm prose-indigo max-w-none">
        <!-- Markdown injected here -->
      </div>
    </div>

    <!-- RIGHT: Code Editor & Console -->
    <div class="flex-1 flex flex-col bg-[#282a36] overflow-hidden relative">
      <div class="h-12 bg-[#1e1e24] border-b border-gray-800 flex items-center justify-between px-4 shrink-0 shadow-md">
        <select id="language-select" class="bg-[#282a36] text-gray-300 text-sm rounded border border-gray-700 px-3 py-1.5 focus:border-indigo-500 outline-none hover:bg-gray-800 transition-colors">
          <option value="javascript">JavaScript (Node.js)</option>
          <option value="python">Python 3.10</option>
          <option value="java">Java 15</option>
          <option value="cpp">C++ (GCC 12)</option>
          <option value="c">C (GCC 12)</option>
        </select>
        <button id="run-btn" class="flex items-center gap-2 text-gray-300 hover:text-white bg-[#282a36] hover:bg-gray-700 px-4 py-1.5 rounded border border-gray-700 text-sm transition-all focus:ring-2 focus:ring-gray-600">
          <span class="material-symbols-outlined text-[18px]">play_arrow</span> Run (Visible Case)
        </button>
      </div>

      <div class="flex-1 relative dracula-scroll" id="editor-container"></div>

      <!-- Console Drawer -->
      <div id="console-drawer" class="h-[40px] bg-[#1e1e24] border-t border-gray-800 flex flex-col shrink-0 transition-all duration-300 z-10 shadow-[0_-4px_6px_rgba(0,0,0,0.2)] relative">
        <div class="flex items-center justify-between px-4 py-2.5 bg-[#282a36] border-b border-gray-800 cursor-pointer select-none" id="console-toggle">
          <h3 class="text-gray-300 text-sm font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-[16px]">terminal</span> Execution Console
          </h3>
          <div class="flex items-center gap-3">
            <span id="status-badge" class="hidden text-xs px-2.5 py-1 rounded font-medium shadow-sm"></span>
            <span class="material-symbols-outlined text-gray-400" id="console-icon">expand_less</span>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto p-4 dracula-scroll text-[13px] font-mono whitespace-pre-wrap bg-[#1e1e24]" id="console-output">
          <span class="text-gray-500">Run code to see standard output...</span>
        </div>
      </div>
    </div>
  </div>

  <script id="server-data" type="application/json">
    <%- JSON.stringify({
      testId: test._id,
      challenges: test.codingBank.challenges.map(c => ({
        id: c._id, title: c.title, difficulty: c.difficulty, 
        description: c.description,
        sampleTest: c.testCases.find(tc => !tc.isHidden) || null
      }))
    }) %>
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const data = JSON.parse(document.getElementById('server-data').textContent);
      const testId = data.testId;
      const challenges = data.challenges;

      // Local State: stores code strings & language for each challenge to persist across tab switching
      const submissions = {};
      challenges.forEach(c => {
        submissions[c.id] = { code: '// Write your code here...\n', language: 'javascript' };
      });

      let activeChallengeId = challenges[0].id;

      // Editor
      const editor = CodeMirror(document.getElementById('editor-container'), {
        lineNumbers: true, theme: 'dracula', mode: 'javascript', indentUnit: 4, tabSize: 4, lineWrapping: true
      });

      // Elements
      const langSelect = document.getElementById('language-select');
      const currentTitle = document.getElementById('current-q-title');
      const currentDiff = document.getElementById('current-q-diff');
      const currentDesc = document.getElementById('current-q-desc');
      const tabs = document.querySelectorAll('.challenge-tab');
      
      const consoleDrawer = document.getElementById('console-drawer');
      const consoleToggle = document.getElementById('console-toggle');
      const consoleIcon = document.getElementById('console-icon');
      const statusBadge = document.getElementById('status-badge');
      const outputDiv = document.getElementById('console-output');

      // --- Switch Challenge Logic ---
      function loadChallenge(id) {
        // Save current editor state before switching
        submissions[activeChallengeId].code = editor.getValue();
        submissions[activeChallengeId].language = langSelect.value;

        // Switch
        activeChallengeId = id;
        const chal = challenges.find(c => c.id === id);
        
        // Update UI
        tabs.forEach(t => t.classList.toggle('active', t.dataset.id === id));
        currentTitle.textContent = chal.title;
        currentDiff.textContent = chal.difficulty;
        currentDiff.className = `text-xs px-2.5 py-1 rounded-full font-medium ${chal.difficulty==='Easy'?'bg-green-100 text-green-700':(chal.difficulty==='Medium'?'bg-yellow-100 text-yellow-700':'bg-red-100 text-red-700')}`;
        currentDesc.innerHTML = marked.parse(chal.description);

        // Load targeted state
        langSelect.value = submissions[id].language;
        updateCodeMirrorMode(submissions[id].language);
        editor.setValue(submissions[id].code);

        // Close console gently
        if(consoleIcon.textContent === 'expand_more') consoleToggle.click();
        statusBadge.classList.add('hidden');
        outputDiv.innerHTML = '<span class="text-gray-500">Run code to see standard output...</span>';
      }

      function updateCodeMirrorMode(lang) {
        let mode = 'javascript';
        if (lang === 'python') mode = 'python';
        if (['cpp', 'c', 'java'].includes(lang)) mode = 'text/x-c++src';
        editor.setOption('mode', mode);
      }

      langSelect.addEventListener('change', (e) => updateCodeMirrorMode(e.target.value));

      tabs.forEach(t => {
        t.addEventListener('click', () => loadChallenge(t.dataset.id));
      });

      // Load initial
      loadChallenge(activeChallengeId);

      // --- Console Toggle ---
      consoleToggle.addEventListener('click', () => {
        if (consoleDrawer.style.height === '33.3333%') {
          consoleDrawer.style.height = '40px'; consoleIcon.textContent = 'expand_less';
        } else {
          consoleDrawer.style.height = '33.3333%'; consoleIcon.textContent = 'expand_more';
        }
      });
      function forceOpenConsole() {
        if(consoleDrawer.style.height !== '33.3333%') consoleToggle.click();
      }
      function setStatus(msg, type) {
        statusBadge.textContent = msg;
        statusBadge.className = `text-xs px-2.5 py-1 rounded font-medium shadow-sm ${type==='err'?'bg-red-500/20 text-red-400':(type==='ok'?'bg-green-500/20 text-green-400':'bg-yellow-500/20 text-yellow-400')}`;
      }

      // --- Run Logic ---
      document.getElementById('run-btn').addEventListener('click', async () => {
        forceOpenConsole();
        outputDiv.innerHTML = '<span class="text-gray-400 animate-pulse">Running test code on secure cloud container...</span>';
        setStatus('Executing...', 'warn');
        document.getElementById('run-btn').disabled = true;

        const code = editor.getValue();
        const chal = challenges.find(c => c.id === activeChallengeId);
        const input = chal.sampleTest ? chal.sampleTest.input : '';

        try {
          const res = await fetch('/api/coding/student/execute', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, language: langSelect.value, input })
          });
          const data = await res.json();

          if(data.status === 'Compilation Error') {
            outputDiv.innerHTML = `<span class="text-red-400"><strong>Compilation Error:</strong>\n${escapeHtml(data.output)}</span>`;
            setStatus('Compile Error', 'err');
          } else {
             let expected = chal.sampleTest ? chal.sampleTest.expectedOutput.trim() : '';
             let got = (data.output || '').trim();
             let out = `<strong class="text-white">Stdout:</strong>\n${escapeHtml(got || '(No Output)')}\n\n`;
             if(chal.sampleTest) {
               if(expected === got) {
                 out += `<span class="text-green-400 font-bold block mt-2">✓ Passed Sample Test Case</span>`;
                 setStatus('Passed', 'ok');
               } else {
                 out += `<span class="text-red-400 mt-2 block">✗ Failed Sample Test Case\n<span class="text-gray-400 font-normal">Expected:</span> ${escapeHtml(expected)}</span>`;
                 setStatus('Wrong Output', 'err');
               }
             } else {
                 setStatus('Compiled', 'ok');
             }
             outputDiv.innerHTML = out;
          }
        } catch(e) {
          outputDiv.innerHTML = `<span class="text-red-400">Network Error: ${e.message}</span>`;
          setStatus('Error', 'err');
        } finally {
          document.getElementById('run-btn').disabled = false;
        }
      });

      // --- Final Submit Logic ---
      document.getElementById('final-submit-btn').addEventListener('click', async () => {
        const rollNo = document.getElementById('roll-no').value.trim();
        if(!rollNo) return alert('Enter your Roll Number first to submit the test!');
        if(!confirm('Are you sure you want to completely finish this test? Your current code for ALL challenges will be locked and saved.')) return;

        // Save last state
        submissions[activeChallengeId].code = editor.getValue();
        submissions[activeChallengeId].language = langSelect.value;
        
        forceOpenConsole();
        outputDiv.innerHTML = '<span class="text-gray-400 animate-pulse">Grading all submissions against hidden test cases. Please wait...</span>';
        setStatus('Grading...', 'warn');
        document.getElementById('final-submit-btn').disabled = true;

        // Flatten payload
        const payload = Object.keys(submissions).map(id => ({
          challengeId: id, code: submissions[id].code, language: submissions[id].language
        }));

        try {
          const res = await fetch('/api/coding/student/submit', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ studentRollNo: rollNo, testId: testId, submissions: payload })
          });
          const data = await res.json();
          if(res.ok) {
            outputDiv.innerHTML = `<span class="text-green-400 text-lg font-bold block mb-2">Test Submitted Successfully! 🎉</span><div class="text-gray-300">Your score has been saved to the database.</div>`;
            setStatus('Submitted', 'ok');
            setTimeout(() => { document.body.innerHTML = `<div class="h-screen w-full flex items-center justify-center bg-gray-50"><div class="text-center p-8 bg-white shadow rounded-xl border border-gray-100"><span class="material-symbols-outlined text-green-500 text-5xl mb-4 block">check_circle</span><h1 class="text-2xl font-bold text-gray-800">Test Completed</h1><p class="text-gray-500 mt-2">You can close this tab now.</p></div></div>`; }, 3000);
          } else {
            outputDiv.innerHTML = `<span class="text-red-400">${data.message || 'Error submitting test.'}</span>`;
            setStatus('Error', 'err');
          }
        } catch(e) {
          outputDiv.innerHTML = `<span class="text-red-400">Network Error: ${e.message}</span>`;
          setStatus('Error', 'err');
        } finally {
          document.getElementById('final-submit-btn').disabled = false;
        }
      });

      function escapeHtml(unsafe) { return unsafe.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
    });
  </script>
</body>
</html>
