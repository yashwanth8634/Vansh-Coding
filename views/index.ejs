<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mr & Ms Coder | Vansh2k26</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <%- include('partials/tailwind-setup') %>
</head>
<body class="font-brand bg-[radial-gradient(1200px_700px_at_-10%_-20%,rgba(239,77,141,0.16),transparent_50%),radial-gradient(1000px_600px_at_110%_-10%,rgba(33,197,165,0.16),transparent_55%),radial-gradient(900px_500px_at_50%_120%,rgba(127,109,255,0.14),transparent_55%),#f7f6f3] text-[#1c1a18] selection:bg-emerald-200/70">

  <div class="fixed inset-0 soft-grid pointer-events-none z-0"></div>

  <nav class="sticky top-0 z-40 border-b border-black/5 bg-white/50 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-4 md:py-0 min-h-24 flex flex-wrap items-center justify-between gap-3">
      <div class="flex items-center w-20 md:w-52">
        <img src="/images/1.png" alt="Vansh2k26 Logo" class="h-12 md:h-20 w-auto object-contain">
      </div>

      <div class="hidden md:flex items-center gap-8 text-sm font-bold text-stone-700">
        <a href="#about" class="hover:text-stone-900 transition-colors">About</a>
        <a href="#format" class="hover:text-stone-900 transition-colors">Format</a>
        <a href="#rules" class="hover:text-stone-900 transition-colors">Rules</a>
        <a href="#highlights" class="hover:text-stone-900 transition-colors">Highlights</a>
      </div>

      <div class="flex items-center justify-end gap-3 ml-auto md:ml-0 md:w-52 lg:w-56">
        <a
          href="/active-tests"
          class="btn-pill"
        >
          Active Tests
        </a>
      </div>
    </div>
  </nav>

  <main class="relative z-10">
    <section class="px-5 md:px-8 pt-8 md:pt-12 pb-20">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <div class="fade-up inline-flex items-center gap-2 rounded-full border border-stone-300/70 bg-white/80 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-stone-600">
            <span class="w-2 h-2 rounded-full bg-[#ef4d8d]"></span>
            Signature Competition
          </div>

          <h1 class="fade-up fade-up-delay-1 mt-6 text-5xl md:text-7xl leading-[1.05] font-extrabold tracking-tight hero-title">
            Mr & Ms Coder
          </h1>
          <p class="fade-up fade-up-delay-2 mt-4 font-subtitle text-2xl md:text-3xl text-stone-700">
            Vansh2k26 flagship coding championship.
          </p>

          <p class="fade-up fade-up-delay-2 mt-7 max-w-xl text-stone-600 text-lg leading-relaxed">
            A high-intensity arena for logic, speed, and clean problem solving. Compete across curated quizzes and coding rounds to claim the crown.
          </p>

          <p class="fade-up fade-up-delay-3 mt-5 inline-flex items-center rounded-full border border-stone-300/70 bg-white/80 px-4 py-2 text-sm font-semibold text-stone-700">
            Organized by Computer Science Department
          </p>

          <div class="fade-up fade-up-delay-3 mt-10 flex flex-col sm:flex-row gap-3">
            <a href="/active-tests" class="btn-secondary px-6 py-3.5">
              View Active Tests
              <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </a>
          </div>
        </div>

        <div class="fade-up fade-up-delay-3">
          <div class="glass rounded-3xl p-6 md:p-8 relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full blur-3xl bg-pink-300/50 pointer-events-none"></div>
            <div class="absolute -bottom-12 -left-10 w-40 h-40 rounded-full blur-3xl bg-emerald-300/50 pointer-events-none"></div>

            

            <div class="mt-5 rounded-2xl border border-stone-200 bg-white/80 p-3">
              <img src="/images/2.png" alt="Mr and Ms Coder Hero" class="w-full h-auto object-cover rounded-xl">
            </div>

            <div class="mt-6 grid grid-cols-2 gap-3">
              <div class="rounded-xl bg-white/75 border border-stone-200 px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-stone-500 font-semibold">Rounds</p>
                <p class="mt-1 text-xl font-extrabold text-stone-900">2 Tracks</p>
              </div>
              <div class="rounded-xl bg-white/75 border border-stone-200 px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-stone-500 font-semibold">Proctoring</p>
                <p class="mt-1 text-xl font-extrabold text-stone-900">Strict</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="scroll-mt-24 px-5 md:px-8 pb-14">
      <div class="max-w-7xl mx-auto mb-8">
        <div class="glass rounded-2xl p-6 md:p-8">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Technical Events · Solo</p>
              <h2 class="mt-2 text-3xl md:text-4xl font-extrabold text-stone-900">Mr./Ms. Coder</h2>
              <p class="mt-2 text-stone-600">Compete in coding rounds to prove your programming skills.</p>
            </div>
          </div>

          <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <div class="rounded-xl bg-white/75 border border-stone-200 px-4 py-3">
              <p class="text-[11px] uppercase tracking-wider text-stone-500 font-semibold">Date</p>
              <p class="mt-1 text-sm font-bold text-stone-900">April 2, 2026</p>
            </div>
            <div class="rounded-xl bg-white/75 border border-stone-200 px-4 py-3">
              <p class="text-[11px] uppercase tracking-wider text-stone-500 font-semibold">Time</p>
              <p class="mt-1 text-sm font-bold text-stone-900">TBD</p>
            </div>
            <div class="rounded-xl bg-white/75 border border-stone-200 px-4 py-3">
              <p class="text-[11px] uppercase tracking-wider text-stone-500 font-semibold">Venue</p>
              <p class="mt-1 text-sm font-bold text-stone-900">TBA</p>
            </div>
            <div class="rounded-xl bg-white/75 border border-stone-200 px-4 py-3">
              <p class="text-[11px] uppercase tracking-wider text-stone-500 font-semibold">Entry Fee</p>
              <p class="mt-1 text-sm font-bold text-stone-900">&#8377;100</p>
            </div>
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-4 md:gap-5">
        <article class="glass rounded-2xl p-6">
          <span class="material-symbols-outlined text-[24px] text-[#7f6dff]">model_training</span>
          <h3 class="mt-4 text-lg font-bold text-stone-900">Precision Evaluation</h3>
          <p class="mt-2 text-sm text-stone-600 leading-relaxed">Balanced scoring across MCQ aptitude and practical coding clarity.</p>
        </article>
        <article class="glass rounded-2xl p-6">
          <span class="material-symbols-outlined text-[24px] text-[#ef4d8d]">monitoring</span>
          <h3 class="mt-4 text-lg font-bold text-stone-900">Live Monitoring</h3>
          <p class="mt-2 text-sm text-stone-600 leading-relaxed">Real-time attempt visibility, anti-switch enforcement, and timed sessions.</p>
        </article>
        <article class="glass rounded-2xl p-6">
          <span class="material-symbols-outlined text-[24px] text-[#21c5a5]">emoji_events</span>
          <h3 class="mt-4 text-lg font-bold text-stone-900">Fest Prestige</h3>
          <p class="mt-2 text-sm text-stone-600 leading-relaxed">Built for Vansh2k26 with premium candidate experience and elite branding.</p>
        </article>
      </div>
    </section>

    <section id="format" class="scroll-mt-24 px-5 md:px-8 py-16">
      <div class="max-w-7xl mx-auto">
        <div class="mb-10">
          <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Competition Structure</p>
          <h2 class="display-font text-4xl md:text-5xl mt-2 text-stone-900">Two rounds. One title.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          <div class="glass rounded-2xl p-7 md:p-8">
            <p class="text-xs uppercase tracking-[0.2em] text-pink-600 font-semibold">Round 1</p>
            <h3 class="mt-3 text-2xl font-extrabold text-stone-900">Quiz Sprint</h3>
            <p class="mt-3 text-stone-600">Timed conceptual challenge with question navigation and autosubmit at timeout.</p>
          </div>

          <div class="glass rounded-2xl p-7 md:p-8">
            <p class="text-xs uppercase tracking-[0.2em] text-emerald-600 font-semibold">Round 2</p>
            <h3 class="mt-3 text-2xl font-extrabold text-stone-900">Coding Arena</h3>
            <p class="mt-3 text-stone-600">Multi-problem coding session with language flexibility, hidden test cases, and strict proctoring.</p>
          </div>
        </div>

        <div class="mt-6 glass rounded-2xl p-7 md:p-8">
          <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">About the Event</p>
          <h3 class="mt-3 text-2xl font-extrabold text-stone-900">Overview & details</h3>
          <p class="mt-3 text-stone-600 leading-relaxed">The official search for Mr. Coder and Miss Coder. A two-round technical challenge featuring a fast-paced MCQ sprint followed by intensive individual problem-solving to identify the most efficient and logical programmers.</p>
          <div class="mt-5">
            <a href="#team" class="inline-flex items-center gap-2 text-sm font-bold text-[#ef4d8d] hover:text-[#d43773] transition-colors">
              View Organizing Team <span class="material-symbols-outlined text-[18px]">arrow_downward</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="rules" class="scroll-mt-24 px-5 md:px-8 pt-2 pb-8">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-5">
        <div class="lg:col-span-2 glass rounded-2xl p-7 md:p-8">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Rules & Guidelines</p>
              <h3 class="mt-2 text-2xl font-extrabold text-stone-900">9 rules</h3>
            </div>
          </div>

          <div class="mt-6 space-y-3">
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>01</strong> · Round 1 (MCQ): 30 Questions | 15 Minutes | 1 mark each | No negative marking.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>02</strong> · Topics (R1): Programming Fundamentals, DBMS, Aptitude and Logical Reasoning.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>03</strong> · Advancement: Top performers (Top 5 or 10) will advance to Round 2.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>04</strong> · Round 2 (Coding): 2 Problems | 60 Minutes | Languages: C, C++, Java, Python, etc.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>05</strong> · Malpractice: Mobile phones/external assistance will result in immediate disqualification.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>06</strong> · Time Regulations: Entry not permitted once a round has started. No additional time.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>07</strong> · Winner Selection: Based on combined performance in Round 1 and Round 2.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>08</strong> · Tie-breaker: Submission time for R1; higher weightage to Coding Round for overall scores.</div>
            <div class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3 text-sm text-stone-700"><strong>09</strong> · Judges' decisions are final and binding.</div>
          </div>
        </div>

        <div class="glass rounded-2xl p-7 md:p-8 h-max">
          <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Judging Criteria</p>
          <h3 class="mt-2 text-2xl font-extrabold text-stone-900">How you are evaluated</h3>
          <ul class="mt-5 space-y-3 text-sm text-stone-700">
            <li class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3">Correctness of the solution</li>
            <li class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3">Efficiency of the code</li>
            <li class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3">Problem-solving approach and logic</li>
            <li class="rounded-xl border border-stone-200 bg-white/70 px-4 py-3">Code readability and structure</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="highlights" class="scroll-mt-24 px-5 md:px-8 pt-6 pb-20">
      <div class="max-w-7xl mx-auto glass rounded-3xl p-8 md:p-10">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Ready for Vansh2k26?</p>
            <h2 class="mt-2 text-3xl md:text-4xl font-extrabold text-stone-900">Launch the competition console.</h2>
          </div>
        </div>
      </div>
    </section>
    <section id="team" class="scroll-mt-24 px-5 md:px-8 pt-6 pb-20">
      <div class="max-w-7xl mx-auto glass rounded-3xl p-8 md:p-12 flex flex-col items-center">
        <!-- Organized By Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-stone-300/70 bg-white/80 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-stone-600">
          <span class="w-2 h-2 rounded-full bg-[#7f6dff]"></span>
          Organized by CSE Department
        </div>

        <!-- Event Head -->
        <div class="mt-10 text-center">
          <h3 class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Event Head</h3>
          <div class="mt-3 flex items-center justify-center gap-2 text-2xl md:text-3xl font-extrabold text-stone-900">
            <span class="material-symbols-outlined text-[28px] text-[#ef4d8d]">groups</span>
            Mr. Lanka. Balaji
          </div>
        </div>

        <!-- Event Coordinators -->
        <div class="mt-12 w-full max-w-4xl mx-auto text-center">
          <h3 class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold mb-6">Event Coordinators</h3>
          
          <div class="flex flex-wrap justify-center gap-3">
            <!-- Coordinator 1 -->
            <div class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-stone-200 bg-white/70 hover:bg-white/90 transition-colors">
              <div class="w-7 h-7 rounded-full bg-[#7f6dff] text-white flex items-center justify-center text-[11px] font-bold">D</div>
              <span class="text-sm md:text-base font-semibold text-stone-800">Deepthi | 3rd Year | CSE</span>
            </div>
            <!-- Coordinator 2 -->
            <div class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-stone-200 bg-white/70 hover:bg-white/90 transition-colors">
              <div class="w-7 h-7 rounded-full bg-[#21c5a5] text-white flex items-center justify-center text-[11px] font-bold">S</div>
              <span class="text-sm md:text-base font-semibold text-stone-800">Saniya | 3rd Year | CSE</span>
            </div>
            <!-- Coordinator 3 -->
            <div class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-stone-200 bg-white/70 hover:bg-white/90 transition-colors">
              <div class="w-7 h-7 rounded-full bg-[#7f6dff] text-white flex items-center justify-center text-[11px] font-bold">K</div>
              <span class="text-sm md:text-base font-semibold text-stone-800">K.Yashwanth reddy | 2nd Year | CSE</span>
            </div>
            <div class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-stone-200 bg-white/70 hover:bg-white/90 transition-colors">
              <div class="w-7 h-7 rounded-full bg-[#ef4d8d] text-white flex items-center justify-center text-[11px] font-bold">K</div>
              <span class="text-sm md:text-base font-semibold text-stone-800">Karthik Sai | 2nd Year | CSE</span>
            </div>
            <!-- Coordinator 4 -->
            <!-- Coordinator 5 -->
            <div class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-stone-200 bg-white/70 hover:bg-white/90 transition-colors">
              <div class="w-7 h-7 rounded-full bg-[#21c5a5] text-white flex items-center justify-center text-[11px] font-bold">B</div>
              <span class="text-sm md:text-base font-semibold text-stone-800">B.Yashwanth Reddy | 2nd Year | CSE</span>
            </div>
            <!-- Coordinator 6 -->
            <div class="flex items-center gap-3 px-4 py-2.5 rounded-xl border border-stone-200 bg-white/70 hover:bg-white/90 transition-colors">
              <div class="w-7 h-7 rounded-full bg-[#ef4d8d] text-white flex items-center justify-center text-[11px] font-bold">R</div>
              <span class="text-sm md:text-base font-semibold text-stone-800">Raghupathi Shashank | 2nd Year | CSE</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-black/5 bg-white/50 backdrop-blur py-8">
    <div class="max-w-7xl mx-auto px-5 md:px-8 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-sm text-stone-600">© 2026 Vansh2k26 Fest · Mr & Ms Coder</p>
      <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Built by K.Yashwanth Reddy | CSE</p>
    </div>
  </footer>

</body>
</html>
