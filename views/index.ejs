<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VanshCoding | Premium Assessment Platform</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <style>
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background-color: #000000; color: #ffffff; overflow-x: hidden; }
    
    .glass-nav { 
      background: rgba(10, 10, 10, 0.6); 
      backdrop-filter: blur(20px); 
      -webkit-backdrop-filter: blur(20px); 
      border-bottom: 1px solid rgba(255, 255, 255, 0.08); 
    }
    
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
    }
    
    .hero-gradient {
      background: radial-gradient(circle at 50% -20%, rgba(59, 130, 246, 0.15), rgba(0, 0, 0, 0) 60%);
    }

    .accent-text-glow {
      background: linear-gradient(to right, #ffffff, #a1a1aa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtle-ring:focus { outline: none; box-shadow: 0 0 0 2px rgba(255,255,255,0.2); }
  </style>
</head>
<body class="antialiased selection:bg-white/30 selection:text-white">

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 w-full z-50 glass-nav transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-white text-[24px]">terminal</span>
        <span class="text-white font-semibold tracking-tight text-lg">VanshCoding</span>
      </div>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-400">
        <a href="#features" class="hover:text-white transition-colors">Platform</a>
        <a href="#testimonials" class="hover:text-white transition-colors">Testimonials</a>
        <a href="mailto:support@vanshcoding.com" class="hover:text-white transition-colors">Contact</a>
      </div>
      <div>
        <a href="/login" class="text-sm font-medium bg-white text-black px-5 py-2 rounded-full hover:bg-gray-200 transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)]">Sign In</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 px-6 overflow-hidden hero-gradient">
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 mb-8">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        <span class="text-xs font-semibold tracking-wide text-gray-300 uppercase">V3 Engine Now Live</span>
      </div>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter leading-[1.1] mb-8 accent-text-glow">
        Engineering assessments,<br class="hidden md:block"> perfectly refined.
      </h1>
      <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto font-light leading-relaxed mb-12">
        A premium infrastructure for evaluating engineering talent. Real-time compilation, anti-cheat mechanisms, and an editor developers actually want to use.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/login" class="w-full sm:w-auto text-black bg-white hover:bg-gray-200 px-8 py-3.5 rounded-full text-sm font-semibold transition-all">
          Get Started
        </a>
        <a href="#features" class="w-full sm:w-auto text-white bg-white/5 border border-white/10 hover:bg-white/10 px-8 py-3.5 rounded-full text-sm font-semibold transition-all backdrop-blur-sm">
          Explore Platform
        </a>
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section id="features" class="py-24 px-6 border-t border-white/10 relative">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">Precision-engineered tools.</h2>
        <p class="text-gray-400">Everything you need to conduct high-fidelity technical interviews at scale.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="glass-card rounded-2xl p-8 hover:bg-white/[0.05] transition-colors duration-300 group">
          <div class="w-12 h-12 rounded-full border border-white/10 bg-white/5 flex items-center justify-center mb-6 group-hover:border-blue-500/50 transition-colors">
             <span class="material-symbols-outlined text-gray-300 group-hover:text-blue-400">code_blocks</span>
          </div>
          <h3 class="text-xl font-medium mb-3">Cloud Compiler</h3>
          <p class="text-sm text-gray-400 leading-relaxed font-light">
            Secure, sandboxed environments executing C++, Java, Node.js, and Python natively in the browser with zero latency.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="glass-card rounded-2xl p-8 hover:bg-white/[0.05] transition-colors duration-300 group">
          <div class="w-12 h-12 rounded-full border border-white/10 bg-white/5 flex items-center justify-center mb-6 group-hover:border-yellow-500/50 transition-colors">
             <span class="material-symbols-outlined text-gray-300 group-hover:text-yellow-400">monitoring</span>
          </div>
          <h3 class="text-xl font-medium mb-3">Live Analytics</h3>
          <p class="text-sm text-gray-400 leading-relaxed font-light">
            Actionable insights, raw execution logs, and automated grading funneled directly into an elegant admin dashboard.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="glass-card rounded-2xl p-8 hover:bg-white/[0.05] transition-colors duration-300 group">
          <div class="w-12 h-12 rounded-full border border-white/10 bg-white/5 flex items-center justify-center mb-6 group-hover:border-purple-500/50 transition-colors">
             <span class="material-symbols-outlined text-gray-300 group-hover:text-purple-400">security</span>
          </div>
          <h3 class="text-xl font-medium mb-3">Proctoring</h3>
          <p class="text-sm text-gray-400 leading-relaxed font-light">
            Comprehensive tab-tracking, strict payload validation, and anti-abuse safeguards baked into the core engine.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="py-24 px-6 border-t border-white/10 bg-[radial-gradient(ellipse_at_bottom,_rgba(255,255,255,0.03),_transparent_60%)]">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-16">Trusted by innovators.</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
        <!-- Quote 1 -->
        <div class="glass-card rounded-2xl p-8 relative">
          <span class="material-symbols-outlined absolute top-8 right-8 text-white/10 text-4xl">format_quote</span>
          <p class="text-gray-300 text-lg leading-relaxed mb-8 relative z-10 font-light">
            "The minimalist IDE completely changed how our candidates perceive our engineering culture. It feels less like a test and more like a premium developer tool."
          </p>
          <div class="flex items-center gap-4 border-t border-white/10 pt-6">
            <div class="w-10 h-10 rounded-full bg-gray-800 border border-white/20"></div>
            <div>
              <div class="text-sm text-white font-medium">Sarah Jenkins</div>
              <div class="text-xs text-gray-500">VP of Engineering at Nexus</div>
            </div>
          </div>
        </div>

        <!-- Quote 2 -->
        <div class="glass-card rounded-2xl p-8 relative">
          <span class="material-symbols-outlined absolute top-8 right-8 text-white/10 text-4xl">format_quote</span>
          <p class="text-gray-300 text-lg leading-relaxed mb-8 relative z-10 font-light">
            "We migrated from LeetCode Enterprise to VanshCoding for the extreme control over custom environments and the breathtaking admin dashboard."
          </p>
          <div class="flex items-center gap-4 border-t border-white/10 pt-6">
            <div class="w-10 h-10 rounded-full bg-gray-800 border border-white/20"></div>
            <div>
              <div class="text-sm text-white font-medium">David Park</div>
              <div class="text-xs text-gray-500">Staff Recruiter at FinTech AI</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 border-t border-white/10 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(59,130,246,0.1),_transparent_50%)] mask-image-[linear-gradient(to_bottom,transparent,black,transparent)]"></div>
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6">Ready to elevate your hiring?</h2>
      <p class="text-gray-400 mb-10 text-lg font-light">Deploy your first custom sandbox environment in minutes.</p>
      <a href="/login" class="inline-flex items-center gap-2 text-black bg-white hover:bg-gray-200 px-8 py-4 rounded-full text-sm font-semibold transition-all">
        Enter Dashboard <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 py-12 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-gray-500">
        <span class="material-symbols-outlined text-[20px]">terminal</span>
        <span class="font-medium text-sm">© 2026 VanshCoding. All rights reserved.</span>
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-500">
        <a href="#" class="hover:text-white transition-colors">Privacy</a>
        <a href="#" class="hover:text-white transition-colors">Terms</a>
        <a href="#" class="hover:text-white transition-colors">Twitter</a>
        <a href="#" class="hover:text-white transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

</body>
</html>
