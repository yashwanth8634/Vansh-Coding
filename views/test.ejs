<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mr & Ms Coder Quiz | Vansh2k26</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-app min-h-screen relative selection:bg-white/30 selection:text-white pb-24 antialiased">
  <noscript>
    <div class="fixed inset-0 flex items-center justify-center bg-black z-[999] text-white text-center p-6">
      <p>JavaScript is required to take this test. Please enable it in your browser.</p>
    </div>
  </noscript>
  <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

  <!-- =============================== -->
  <!-- 1. STUDENT LOGIN CONTAINER      -->
  <!-- =============================== -->
  <div id="login-container" class="min-h-screen flex items-center justify-center p-6 relative z-10">
    <div class="glass-card rounded-2xl p-8 md:p-10 lg:p-12 w-full max-w-md md:max-w-3xl relative overflow-hidden">
      <!-- Ambient Glow -->
      <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="text-center mb-10 relative z-10">
        <div class="mx-auto w-12 h-12 border border-white/20 bg-white/5 rounded-xl flex items-center justify-center mb-6 shadow-inner">
          <span class="material-symbols-outlined text-white text-[24px]">vpn_key</span>
        </div>
        <h1 class="text-2xl font-semibold text-white tracking-tight mb-2">Mr & Ms Coder Quiz Round</h1>
        <p class="text-gray-400 font-light text-sm">Enter details to begin your Vansh2k26 attempt</p>
      </div>

      <form id="start-test-form" class="grid grid-cols-1 md:grid-cols-2 gap-4 relative z-10">
        <div>
          <label class="sr-only">Student Name</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">person</span>
            </div>
            <input type="text" id="student-name" required
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none"
              placeholder="Student Name">
          </div>
        </div>
        <div>
          <label class="sr-only">Roll Number</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">badge</span>
            </div>
            <input type="text" id="roll-no" required 
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
              placeholder="Roll Number">
          </div>
        </div>
        <div>
          <label class="sr-only">Department</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">apartment</span>
            </div>
            <select id="department" required
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none appearance-none">
              <option value="">Select Department</option>
              <option value="CSE">CSE</option>
              <option value="CSE(AI&ML)">CSE(AI&amp;ML)</option>
              <option value="CSE(DS)">CSE(DS)</option>
              <option value="IT">IT</option>
              <option value="ECE">ECE</option>
              <option value="EEE">EEE</option>
              <option value="CIVIL">CIVIL</option>
              <option value="MECH">MECH</option>
              <option value="EIE">EIE</option>
              <option value="AI&DS">AI&amp;DS</option>
              <option value="AI&ML">AI&amp;ML</option>
            </select>
          </div>
        </div>
        <div>
          <label class="sr-only">Year</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">school</span>
            </div>
            <select id="year" required
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none appearance-none">
              <option value="">Select Year</option>
              <option value="1">1st Year</option>
              <option value="2">2nd Year</option>
              <option value="3">3rd Year</option>
              <option value="4">4th Year</option>
            </select>
          </div>
        </div>
        <div>
          <label class="sr-only">Section</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">groups</span>
            </div>
            <input type="text" id="section"
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none"
              placeholder="Section (Optional)">
          </div>
        </div>
        <div>
          <label class="sr-only">College Name</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">school</span>
            </div>
            <input type="text" id="college-name"
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none"
              placeholder="College Name (leave blank if Vignan)">
          </div>
        </div>
        <input type="hidden" id="unique-link" value="<%= uniqueLink %>" />

        <button
          type="submit"
          id="start-test-btn"
          class="btn-primary group w-full py-3.5 md:col-span-2"
          data-idle-label="Start Test"
        >
          <span class="tracking-wide">Start Test</span>
          <span class="material-symbols-outlined text-[22px] transition-transform duration-200 group-hover:translate-x-0.5">arrow_forward</span>
        </button>
      </form>

      <div id="rules-screen" class="hidden relative z-10">
        <div class="rounded-2xl border border-white/10 bg-[#0a0a0a] p-5 md:p-6 lg:p-7 shadow-inner">
          <div class="flex items-start gap-3 max-w-2xl">
            <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-amber-500/20 bg-amber-500/10 text-amber-400">
              <span class="material-symbols-outlined text-[20px]">gavel</span>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">Rules & Instructions</p>
              <h2 class="mt-2 text-xl font-semibold text-white tracking-tight">Read carefully before you begin</h2>
              <p class="mt-2 text-sm text-gray-400 leading-relaxed">Your quiz will start only after you accept these instructions.</p>
            </div>
          </div>

          <div class="mt-5 rounded-2xl border border-[#fda29b] bg-[#fff1f0] p-4 md:p-5">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#d92d20] text-[20px]">warning</span>
              <div>
                <p class="text-sm font-semibold text-[#d92d20]">Important fullscreen warning</p>
                <p class="mt-1 text-sm leading-relaxed text-[#b42318]">
                  If you press <strong>Esc</strong>, leave fullscreen, switch tabs, or come back from fullscreen during the test, your test may be automatically submitted. Please be careful.
                </p>
              </div>
            </div>
          </div>

          <ul class="mt-5 grid grid-cols-1 lg:grid-cols-2 gap-3">
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Enter only your correct details. You will have only one valid attempt.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">The timer starts only after you agree and begin the test.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Do not switch tabs, leave fullscreen, or minimize the window during the test.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Any malpractice or external help can lead to immediate disqualification.</p>
              </div>
            </li>
            <li class="rounded-xl border border-black/10 bg-white px-4 py-3.5 lg:col-span-2">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-slate-700"></span>
                <p class="text-sm leading-relaxed text-slate-700">Once the test is submitted, answers cannot be changed.</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="mt-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <button type="button" id="edit-details-btn" class="btn-ghost w-full md:w-auto py-3 px-5">
            Edit Details
          </button>
          <button type="button" id="confirm-rules-btn" class="btn-secondary w-full md:w-auto md:min-w-[240px] py-3.5 px-6">
            I Agree, Start Test
            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          </button>
        </div>
      </div>
      <div id="login-error" class="hidden mt-6 bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-lg flex items-start gap-3 text-sm font-medium relative z-10"></div>
    </div>
  </div>

  <!-- =============================== -->
  <!-- 2. ACTIVE TEST CONTAINER        -->
  <!-- =============================== -->
  <div id="test-container" class="hidden relative z-10 pb-32">
    
    <!-- Header -->
    <div id="header" class="fixed top-0 left-0 w-full z-50 glass-header px-4 md:px-6 py-4 flex flex-col md:flex-row justify-between items-center transition-all gap-4">
      <div class="flex flex-col md:flex-row items-center text-center md:text-left gap-3 md:gap-4">
        <h2 id="test-title" class="text-lg font-semibold text-white tracking-tight">Mr & Ms Coder</h2>
        <div class="hidden md:block w-px h-4 bg-white/20"></div>
        <div class="flex items-center gap-2">
           <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
           <p id="progress-text" class="text-gray-400 font-mono text-xs uppercase tracking-widest hover:text-white transition-colors">Answered 0 / 0</p>
        </div>
      </div>
      <div id="timer" class="bg-white/5 border border-white/10 text-white px-5 py-2.5 rounded-full font-mono text-sm tracking-widest flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px] text-gray-400">timer</span><span id="timer-value">--:--</span>
      </div>
    </div>

    <!-- Main Content -->
    <div class="pt-36 sm:pt-32 px-4 max-w-5xl mx-auto flex flex-col lg:flex-row gap-6 md:gap-8 items-start relative">
      
      <!-- Questions Area -->
      <div id="question-area" class="w-full flex-1">
        <!-- Rendered dynamically -->
      </div>

      <!-- Quick Nav -->
      <div id="question-nav" class="hidden w-full lg:w-80 lg:sticky lg:top-28 glass-card rounded-2xl p-6 flex-shrink-0">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4 border-b border-white/10 pb-3">Question Navigator</h3>
        <div id="question-nav-buttons" class="grid grid-cols-4 sm:grid-cols-5 gap-2">
          <!-- Rendered dynamically -->
        </div>
      </div>

    </div>

    <!-- Floating Footer -->
    <div id="footer" class="fixed bottom-0 left-0 w-full z-40 bg-black/80 backdrop-blur-xl border-t border-white/10 p-4">
      <div class="max-w-5xl mx-auto flex justify-end">
        <button id="submit-test-btn" class="btn-primary w-full md:w-auto py-3 px-8">
          Submit Final Test
        </button>
      </div>
    </div>
  </div>

  <!-- =============================== -->
  <!-- 3. RESULTS CONTAINER            -->
  <!-- =============================== -->
  <div id="results-container" class="hidden flex-col items-center justify-center p-6 relative z-10 pt-20">
    <div class="glass-card rounded-2xl p-8 md:p-12 w-full max-w-4xl relative overflow-hidden">
      <div class="absolute top-0 right-0 w-48 h-48 bg-green-500/10 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="text-center mb-12 border-b border-white/10 pb-10 relative z-10">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white/5 border border-white/10 rounded-xl mb-6 shadow-inner">
          <span class="material-symbols-outlined text-white text-[32px]">task_alt</span>
        </div>
        <h2 class="text-3xl font-semibold text-white tracking-tight mb-2">Test Submitted</h2>
        <div id="score" class="text-sm font-mono text-green-400 mt-2 tracking-widest bg-green-500/10 border border-green-500/20 inline-block px-4 py-2 rounded-lg">You Scored: - / -</div>
      </div>

      <div class="flex items-center justify-between mb-6 relative z-10">
        <h3 class="text-sm font-semibold text-white uppercase tracking-widest">Question Breakdown</h3>
      </div>
      
      <div id="results-breakdown" class="space-y-4 relative z-10">
        <!-- Rendered dynamically -->
      </div>
    </div>
  </div>

  <!-- =============================== -->
  <!-- 4. WARNING MODAL                -->
  <!-- =============================== -->
  <div id="warning-modal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[100] p-6">
    <div class="glass-modal rounded-2xl shadow-2xl p-8 md:p-10 w-full max-w-md text-center transform transition-all border border-red-500/30">
      
      <div class="w-16 h-16 bg-red-500/10 border border-red-500/20 text-red-400 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-[32px]">security</span>
      </div>
      
      <h2 class="text-2xl font-semibold text-white tracking-tight mb-2">Warning!</h2>
      <p class="text-sm font-light text-gray-400 mb-6 leading-relaxed">You left the test window or exited fullscreen.</p>
      
      <div class="bg-red-500/10 border border-red-500/20 p-4 rounded-xl mb-8">
        <p class="text-[11px] text-red-400 uppercase tracking-widest leading-relaxed">If you switch tabs again, your test will be instantly submitted automatically with no further warning.</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button id="return-to-test" class="btn-secondary flex-1 py-3 px-4">
          Return to Test
        </button>
        <button id="submit-anyway" class="btn-ghost w-full sm:w-max py-3 px-4">
          Submit Now
        </button>
      </div>
    </div>
  </div>

  <script src="/js/test.js"></script>
</body>
</html>
