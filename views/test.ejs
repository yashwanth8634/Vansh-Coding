<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mr & Ms Coder Quiz | Vansh2k26</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="/css/vansh2k26-theme.css">

  <style>
    body { font-family: 'Inter', sans-serif; background-color: #000000; color: #ffffff; }
    
    .glass-header { background: rgba(0, 0, 0, 0.7); border-bottom: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(20px); }
    .glass-card { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.08); }
    .glass-modal { background: rgba(10, 10, 10, 0.8); border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(30px); }
    
    .grid-bg {
      background-size: 40px 40px;
      background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
                        linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
    }
  </style>
</head>
<body class="min-h-screen relative selection:bg-white/30 selection:text-white pb-24 antialiased">

  <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

  <!-- =============================== -->
  <!-- 1. STUDENT LOGIN CONTAINER      -->
  <!-- =============================== -->
  <div id="login-container" class="min-h-screen flex items-center justify-center p-6 relative z-10">
    <div class="glass-card rounded-2xl p-8 md:p-12 w-full max-w-md relative overflow-hidden">
      <!-- Ambient Glow -->
      <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="text-center mb-10 relative z-10">
        <div class="mx-auto w-12 h-12 border border-white/20 bg-white/5 rounded-xl flex items-center justify-center mb-6 shadow-inner">
          <span class="material-symbols-outlined text-white text-[24px]">vpn_key</span>
        </div>
        <h1 class="text-2xl font-semibold text-white tracking-tight mb-2">Mr & Ms Coder Quiz Round</h1>
        <p class="text-gray-400 font-light text-sm">Enter details to begin your Vansh2k26 attempt</p>
      </div>

      <form id="start-test-form" class="space-y-6 relative z-10">
        <div>
          <label class="sr-only">Roll Number</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-gray-500 text-[18px]">badge</span>
            </div>
            <input type="text" id="roll-no" required 
              class="w-full pl-12 pr-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none uppercase tracking-widest text-center" 
              placeholder="XX-XXXX-XX">
          </div>
        </div>
        <input type="hidden" id="unique-link" value="<%= uniqueLink %>" />

        <button type="submit" id="start-test-btn" class="w-full bg-white text-black hover:bg-gray-200 py-3 px-4 rounded-xl text-sm font-semibold transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.98] flex justify-center items-center gap-2">
          Start Test <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        </button>
      </form>
      <div id="login-error" class="hidden mt-6 bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-lg flex items-start gap-3 text-sm font-medium relative z-10"></div>
    </div>
  </div>

  <!-- =============================== -->
  <!-- 2. ACTIVE TEST CONTAINER        -->
  <!-- =============================== -->
  <div id="test-container" class="hidden relative z-10 pb-32">
    
    <!-- Header -->
    <div id="header" class="fixed top-0 left-0 w-full z-50 glass-header px-6 py-4 flex flex-col md:flex-row justify-between items-center transition-all gap-4">
      <div class="flex flex-col md:flex-row items-center gap-4">
        <h2 id="test-title" class="text-lg font-semibold text-white tracking-tight">Mr & Ms Coder</h2>
        <div class="hidden md:block w-px h-4 bg-white/20"></div>
        <div class="flex items-center gap-2">
           <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
           <p id="progress-text" class="text-gray-400 font-mono text-xs uppercase tracking-widest hover:text-white transition-colors">Answered 0 / 0</p>
        </div>
      </div>
      <div id="timer" class="bg-white/5 border border-white/10 text-white px-5 py-2.5 rounded-full font-mono text-sm tracking-widest flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px] text-gray-400">timer</span><span>--:--</span>
      </div>
    </div>

    <!-- Main Content -->
    <div class="pt-32 sm:pt-28 px-4 max-w-5xl mx-auto flex flex-col lg:flex-row gap-8 items-start relative">
      
      <!-- Questions Area -->
      <div id="question-area" class="w-full flex-1">
        <!-- Rendered dynamically -->
      </div>

      <!-- Quick Nav -->
      <div id="question-nav" class="hidden w-full lg:w-80 lg:sticky lg:top-28 glass-card rounded-2xl p-6 flex-shrink-0">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4 border-b border-white/10 pb-3">Question Navigator</h3>
        <div id="question-nav-buttons" class="grid grid-cols-5 gap-2">
          <!-- Rendered dynamically -->
        </div>
      </div>

    </div>

    <!-- Floating Footer -->
    <div id="footer" class="fixed bottom-0 left-0 w-full z-40 bg-black/80 backdrop-blur-xl border-t border-white/10 p-4">
      <div class="max-w-5xl mx-auto flex justify-end">
        <button id="submit-test-btn" class="w-full md:w-auto bg-white text-black hover:bg-gray-200 py-3 px-8 rounded-xl text-sm font-semibold transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.98]">
          Submit Final Test
        </button>
      </div>
    </div>
  </div>

  <!-- =============================== -->
  <!-- 3. RESULTS CONTAINER            -->
  <!-- =============================== -->
  <div id="results-container" class="hidden min-h-screen items-start justify-center p-6 relative z-10 pt-20">
    <div class="glass-card rounded-2xl p-8 md:p-12 w-full max-w-4xl relative overflow-hidden">
      <div class="absolute top-0 right-0 w-48 h-48 bg-green-500/10 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="text-center mb-12 border-b border-white/10 pb-10 relative z-10">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white/5 border border-white/10 rounded-xl mb-6 shadow-inner">
          <span class="material-symbols-outlined text-white text-[32px]">task_alt</span>
        </div>
        <h2 class="text-3xl font-semibold text-white tracking-tight mb-2">Test Submitted</h2>
        <div id="score" class="text-sm font-mono text-green-400 mt-2 tracking-widest bg-green-500/10 border border-green-500/20 inline-block px-4 py-2 rounded-lg">You Scored: - / -</div>
      </div>

      <div class="flex items-center justify-between mb-6 relative z-10">
        <h3 class="text-sm font-semibold text-white uppercase tracking-widest">Question Breakdown</h3>
      </div>
      
      <div id="results-breakdown" class="space-y-4 relative z-10">
        <!-- Rendered dynamically -->
      </div>
    </div>
  </div>

  <!-- =============================== -->
  <!-- 4. WARNING MODAL                -->
  <!-- =============================== -->
  <div id="warning-modal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[100] p-6">
    <div class="glass-modal rounded-2xl shadow-2xl p-8 md:p-10 w-full max-w-md text-center transform transition-all border border-red-500/30">
      
      <div class="w-16 h-16 bg-red-500/10 border border-red-500/20 text-red-400 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-[32px]">security</span>
      </div>
      
      <h2 class="text-2xl font-semibold text-white tracking-tight mb-2">Warning!</h2>
      <p class="text-sm font-light text-gray-400 mb-6 leading-relaxed">You tabbed out of the test window.</p>
      
      <div class="bg-red-500/10 border border-red-500/20 p-4 rounded-xl mb-8">
        <p class="text-[11px] text-red-400 uppercase tracking-widest leading-relaxed">If you switch tabs again, your test will be instantly submitted automatically with no further warning.</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button id="return-to-test" class="flex-1 bg-white text-black hover:bg-gray-200 py-3 px-4 rounded-xl text-sm font-semibold transition-colors">
          Return to Test
        </button>
        <button id="submit-anyway" class="w-full sm:w-max bg-transparent text-gray-500 hover:text-white border border-transparent hover:border-white/10 py-3 px-4 rounded-xl text-sm transition-colors">
          Submit Now
        </button>
      </div>
    </div>
  </div>

  <script src="/js/test.js"></script>
</body>
</html>
