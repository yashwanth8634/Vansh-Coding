<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mr & Ms Coder Quiz Result | Vansh2k26</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <%- include('partials/tailwind-setup') %>
</head>

<body
  class="vc-app min-h-screen relative selection:bg-white/30 selection:text-white pb-24 antialiased overflow-x-hidden">
  <%- include('partials/navbar', { isHome: false }) %>

    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <div class="relative z-10 flex items-start justify-center p-4 sm:p-6 pt-6 sm:pt-10 md:pt-16">
      <div class="glass-card rounded-2xl p-5 sm:p-8 md:p-12 w-full max-w-4xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-48 h-48 bg-green-500/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="text-center mb-8 sm:mb-12 border-b border-white/10 pb-8 sm:pb-10 relative z-10">
          <div
            class="inline-flex items-center justify-center w-12 sm:w-16 h-12 sm:h-16 bg-white/5 border border-white/10 rounded-xl mb-4 sm:mb-6 shadow-inner">
            <span class="material-symbols-outlined text-white text-[24px] sm:text-[32px]">task_alt</span>
          </div>
          <h1 class="text-2xl sm:text-3xl font-semibold text-white tracking-tight mb-2">Quiz Submitted</h1>
          <p class="text-gray-400 font-medium uppercase tracking-widest text-[10px] sm:text-xs mb-4 sm:mb-6">
            <%= (attempt.questionBank && attempt.questionBank.title) ? attempt.questionBank.title : 'Question Bank' %>
          </p>

          <div class="inline-block bg-[#0a0a0a] border border-white/10 px-6 sm:px-8 py-4 sm:py-5 rounded-xl">
            <p class="text-[9px] sm:text-[10px] font-semibold text-gray-500 uppercase tracking-widest mb-2">Score</p>
            <div class="text-2xl sm:text-3xl font-mono text-green-400 tracking-widest">
              <%= attempt.score %> <span class="text-gray-600 text-xl sm:text-2xl">/</span> <span
                  class="text-gray-400 text-xl sm:text-2xl">
                  <%= attempt.totalQuestions %>
                </span>
            </div>
          </div>
        </div>

        <div
          class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 sm:mb-6 relative z-10 gap-3 sm:gap-4">
          <h2 class="text-xs sm:text-sm font-semibold text-white uppercase tracking-widest">Question Breakdown</h2>
          <span
            class="text-[9px] sm:text-[10px] font-mono text-gray-400 bg-white/5 border border-white/10 px-2 sm:px-3 py-1 sm:py-1.5 rounded uppercase tracking-wider">Roll
            No: <%= attempt.studentRollNo %></span>
        </div>

        <div class="space-y-3 sm:space-y-4 relative z-10">
          <% attempt.answers.forEach((ans, index)=> {
            const isCorrect = ans.isCorrect;
            const q = ans.question;
            if (!q) return;

            const bgColor = isCorrect ? 'bg-green-500/5' : 'bg-red-500/5';
            const borderColor = isCorrect ? 'border-green-500/20' : 'border-red-500/20';
            %>
            <div class="p-4 sm:p-6 border <%= borderColor %> <%= bgColor %> rounded-xl bg-[#0a0a0a]">
              <% if(q.imageUrl && (q.imageUrl.startsWith('https://') || q.imageUrl.startsWith('http://'))) { %>
                <img src="<%= q.imageUrl %>" alt="Question Content"
                  class="w-full rounded-lg mb-4 sm:mb-5 max-h-48 sm:max-h-64 object-contain border border-white/10">
                <% } %>
                  <% const lines=q.questionText.split('\n'); const questionTitle=lines[0]; const
                    restOfText=lines.slice(1).join('\n').trim(); %>
                    <div class="mb-4">
                      <div class="flex items-start gap-2 mb-2">
                        <span class="text-gray-500 font-mono text-[10px] sm:text-xs mt-1 shrink-0">Q<%= index + 1 %>.</span>
                        <h4 class="font-semibold text-white leading-snug tracking-tight text-xs sm:text-sm break-words">
                          <%= questionTitle %>
                        </h4>
                      </div>
                      <% if (restOfText) { %>
                        <div class="font-code text-[10px] sm:text-[11px] text-gray-500 whitespace-pre-wrap leading-relaxed mt-3 overflow-x-auto">
                          <%= restOfText.split('\n').filter(l=> l.trim() !== "").map(l => l.replace(/^\s{1,8}/,
                            '')).join('\n').trim() %>
                        </div>
                        <% } %>
                    </div>

                    <% if(isCorrect) { %>
                      <div class="mt-3 sm:mt-4 p-3 sm:p-4 bg-[#050505] rounded-xl border border-white/10">
                        <span class="text-[9px] sm:text-[10px] font-mono uppercase tracking-widest text-green-400 block mb-1">Your
                          Answer (Correct)</span>
                        <span class="text-white font-medium text-xs sm:text-sm break-words">
                          <%= ans.selectedOption || 'Not Answered' %>
                        </span>
                      </div>
                      <% } else { %>
                        <div class="mt-3 sm:mt-4 flex flex-col sm:flex-row gap-2 sm:gap-3">
                          <div class="flex-1 p-3 sm:p-4 bg-[#050505] rounded-xl border border-red-500/20">
                            <span class="text-[9px] sm:text-[10px] font-mono uppercase tracking-widest text-red-400 block mb-1">Your
                              Answer</span>
                            <span class="text-gray-500 font-medium text-xs sm:text-sm line-through break-words">
                              <%= ans.selectedOption || 'Not Answered' %>
                            </span>
                          </div>
                          <div class="flex-1 p-3 sm:p-4 bg-[#050505] rounded-xl border border-green-500/20">
                            <span
                              class="text-[9px] sm:text-[10px] font-mono uppercase tracking-widest text-green-400 block mb-1">Correct
                              Answer</span>
                            <span class="text-white font-medium text-xs sm:text-sm break-words">
                              <%= q.correctAnswer %>
                            </span>
                          </div>
                        </div>
                        <% } %>
            </div>
            <% }); %>
        </div>
        <div class="text-center mt-8 sm:mt-10 relative z-10">
          <a href="/" class="text-gray-500 hover:text-white text-xs sm:text-sm font-medium transition-colors">← Back to Home</a>
        </div>
      </div>
    </div>

</body>

</html>