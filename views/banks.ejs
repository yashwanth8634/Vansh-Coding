<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Question Banks | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex min-h-screen flex-col md:h-screen md:flex-row overflow-x-hidden md:overflow-hidden antialiased selection:bg-white/30">

  <%- include('partials/admin-sidebar', { activePage: 'banks' }) %>

  <!-- Main Content -->
  <main class="flex-1 flex min-h-0 flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <!-- Header -->
    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">MCQ Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Question Banks</span>
      </div>
      
      <!-- Sub Tabs -->
      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/banks" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Question Banks</a>
        <a href="/admin/tests" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Tests</a>
      </div>
    </header>

    <!-- Scrollable content -->
    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-8">
        
        <!-- Create Bank Form (1/3 width on wide screens) -->
        <div class="xl:col-span-4 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Create Bank</h1>
            <p class="text-gray-400 font-light text-sm">Create a new question bank.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <form id="createBankForm" class="space-y-5 relative z-10">
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Bank Title</label>
                <input type="text" id="bankTitle" required 
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
                  placeholder="e.g., Fundamentals of React">
              </div>
              <button type="submit" class="btn-primary btn-block">
                <span class="material-symbols-outlined text-[18px]">add</span> Create Bank
              </button>
            </form>
          </div>
        </div>

        <!-- Banks List (2/3 width) -->
        <div class="xl:col-span-8 space-y-6">
          <div>
            <h2 class="text-2xl font-semibold tracking-tight text-white mb-2">Existing Banks</h2>
            <p class="text-gray-400 font-light text-sm">List of your created banks.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-2 h-max md:max-h-[calc(100vh-250px)] overflow-y-auto">
            <div class="space-y-2 p-2" id="banksList">
              <% banks.forEach(bank => { %>
                <div class="bg-black/40 border border-white/5 hover:border-white/10 hover:bg-white/5 p-4 rounded-xl flex flex-col sm:flex-row justify-between sm:items-center gap-4 transition-all group">
                  <div>
                     <strong class="text-base font-medium text-white block mb-1"><%= bank.title %></strong>
                     <div class="flex items-center gap-2">
                       <span class="inline-flex items-center bg-blue-500/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider"><%= bank.questions ? bank.questions.length : 0 %> Questions</span>
                     </div>
                   </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <a href="/admin/bank/<%= bank._id %>" class="btn-secondary btn-sm">Manage</a>
                      <button data-action="delete-bank" data-id="<%= bank._id %>" class="btn-danger btn-icon btn-sm" type="button" aria-label="Delete bank" title="Delete bank">
                      <span class="material-symbols-outlined text-[18px]">delete</span>
                    </button>
                  </div>
                </div>
              <% }); %>
              <% if(banks.length === 0) { %>
                <div class="text-gray-500 text-center py-16 text-sm font-medium bg-black/20 rounded-xl border border-dashed border-white/10 flex flex-col items-center">
                  <span class="material-symbols-outlined text-4xl mb-3 opacity-50">inventory_2</span>
                  Empty Registry. Create a bank to begin.
                </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <script>
    function showToast(message, type = 'error') {
      const existing = document.getElementById('vc-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.id = 'vc-toast';
      const color = type === 'error' ? 'border-red-500/30 text-red-500 bg-red-500/10' : 'border-green-500/30 text-green-500 bg-green-500/10';
      toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-5 py-3 rounded-xl glass-card border ${color} text-sm font-medium shadow-xl transition-all duration-300`;
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => { if (document.getElementById('vc-toast')) toast.remove() }, 4000);
    }

    async function getErrorMessage(res, fallback) {
      try {
        const data = await res.json();
        return data.message || fallback;
      } catch (error) {
        return fallback;
      }
    }

    document.getElementById('createBankForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Processing...';

      const title = document.getElementById('bankTitle').value;
      
      try {
        const res = await fetch('/api/banks', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title }) });
        if(res.ok) {
          window.location.reload(); 
        } else { 
          showToast(await getErrorMessage(res, 'Failed to create bank.')); 
          btn.innerHTML = originalText; 
          btn.disabled = false; 
        }
      } catch (err) {
        showToast('Network error: ' + err.message);
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });

    document.addEventListener('click', async (e) => {
      const deleteBtn = e.target.closest('[data-action="delete-bank"]');
      
      if (deleteBtn && !deleteBtn.dataset.confirmPending) {
        deleteBtn.dataset.confirmPending = 'true';
        deleteBtn.innerHTML = '<span class="material-symbols-outlined text-[14px]">check</span>';
        deleteBtn.title = 'Click again to confirm delete';
        deleteBtn.classList.replace('text-red-400', 'text-white');
        deleteBtn.classList.remove('btn-danger');
        deleteBtn.classList.add('bg-red-500/40', 'border-red-500', 'text-red-100');
        
        setTimeout(() => {
          if (deleteBtn.dataset.confirmPending) {
              delete deleteBtn.dataset.confirmPending;
              deleteBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
              deleteBtn.title = 'Delete bank';
              deleteBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
              deleteBtn.classList.add('btn-danger');
          }
        }, 3000);
        return;
      }

      const confirmBtn = e.target.closest('[data-confirm-pending]');
      if (confirmBtn) {
        const id = confirmBtn.dataset.id;
        delete confirmBtn.dataset.confirmPending;
        confirmBtn.disabled = true;
        confirmBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span>';
        
        try {
          const res = await fetch(`/api/banks/${id}`, { method: 'DELETE' });
          if(res.ok) {
            window.location.reload();
          } else {
            confirmBtn.disabled = false;
            showToast(await getErrorMessage(res, 'Failed to delete bank.'));
            confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
            confirmBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
            confirmBtn.classList.add('btn-danger');
          }
        } catch (err) {
          confirmBtn.disabled = false;
          showToast('Network error: ' + err.message);
          confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
          confirmBtn.classList.remove('bg-red-500/40', 'border-red-500', 'text-red-100');
          confirmBtn.classList.add('btn-danger');
        }
      }
    });
  </script>
</body>
</html>
