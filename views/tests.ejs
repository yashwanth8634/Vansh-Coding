<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tests | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex h-screen overflow-hidden antialiased selection:bg-white/30">

  <aside class="w-20 md:w-64 glass-sidebar flex flex-col shrink-0 z-20">
    <div class="h-16 flex items-center justify-center md:justify-start md:px-6 border-b border-white/10 shrink-0">
      <span class="material-symbols-outlined text-[24px] text-white">terminal</span>
      <span class="ml-3 font-semibold tracking-tight text-white hidden md:block">Mr & Ms Coder</span>
    </div>
    
    <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-2">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3 hidden md:block">Main</div>
      <a href="/admin" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">space_dashboard</span>
        <span class="text-sm hidden md:block">Overview</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">MCQ Section</div>
      <a href="/admin/banks" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">folder_open</span>
        <span class="text-sm hidden md:block">Question Banks</span>
      </a>
      <a href="/admin/tests" class="nav-item active flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">link</span>
        <span class="text-sm hidden md:block">Tests</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">Coding Section</div>
      <a href="/admin/coding/banks" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">data_object</span>
        <span class="text-sm hidden md:block">Coding Environments</span>
      </a>
      <a href="/admin/coding/tests" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">api</span>
        <span class="text-sm hidden md:block">Coding Sessions</span>
      </a>
      <a href="/admin/coding" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">code_blocks</span>
        <span class="text-sm hidden md:block">Coding Challenges</span>
      </a>
    </nav>
    
    <div class="p-4 border-t border-white/10 shrink-0">
      <form action="/api/admin/logout" method="POST">
        <button type="submit" class="w-full flex items-center justify-center md:justify-start gap-3 px-3 py-2.5 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors">
          <span class="material-symbols-outlined text-[20px]">logout</span>
          <span class="text-sm font-medium hidden md:block">Sign Out</span>
        </button>
      </form>
    </div>
  </aside>

  <main class="flex-1 flex flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">MCQ Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Tests</span>
      </div>
      
      <!-- Sub Tabs -->
      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/banks" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Question Banks</a>
        <a href="/admin/tests" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Create</a>
        <a href="/admin/tests/links" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Existing Tests</a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-8">
        
        <!-- Create Link Form (1/3 width) -->
        <div class="xl:col-span-4 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Create Test</h1>
            <p class="text-gray-400 font-light text-sm">Create a new test link.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <form id="createTestForm" class="space-y-5 relative z-10">
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Select Question Bank</label>
                <select id="bankId" required class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white appearance-none focus:bg-[#111] focus:border-white/30 transition-all outline-none">
                  <option value="" class="text-gray-500">-- Choose Bank --</option>
                  <% banks.forEach(b => { %>
                    <option value="<%= b._id %>"><%= b.title %></option>
                  <% }); %>
                </select>
              </div>
               
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Number of Questions</label>
                  <input type="number" id="numQuestions" min="1" max="100" value="10" required 
                    class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none">
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Duration (Minutes)</label>
                  <input type="number" id="duration" min="1" max="300" value="30" required 
                    class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none">
                </div>
              </div>

              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Link Expiry (Hours)</label>
                <input type="number" id="linkExpiryHours" min="1" max="720" value="24" required 
                    class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none">
              </div>

              <button type="submit" class="w-full bg-white text-black hover:bg-gray-200 py-3 px-4 rounded-xl text-sm font-semibold transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.98] flex justify-center items-center gap-2 mt-2">
                <span class="material-symbols-outlined text-[18px]">add_link</span> Create Test
              </button>
            </form>
          </div>
        </div>

        <!-- Quick Access (2/3 width) -->
        <div class="xl:col-span-8 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Manage Existing Tests</h1>
            <p class="text-gray-400 font-light text-sm">Open the dedicated page to view quiz links and results actions.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-8 md:p-10 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="relative z-10">
              <p class="text-xs uppercase tracking-[0.2em] text-gray-500 font-semibold">Quiz Links</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white">Existing Tests</h2>
              <p class="mt-3 max-w-xl text-sm text-gray-400 leading-relaxed">
                View all created quiz links on a separate page with actions for copying links, deleting tests, and opening results.
              </p>
              <a href="/admin/tests/links" class="mt-6 inline-flex items-center gap-2 rounded-xl bg-white text-black hover:bg-gray-200 py-3 px-5 text-sm font-semibold transition-colors">
                Open Existing Tests
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <script>
    async function getErrorMessage(res, fallback) {
      try {
        const data = await res.json();
        return data.message || fallback;
      } catch (error) {
        return fallback;
      }
    }

    document.getElementById('createTestForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Processing...';
      btn.disabled = true;

      const b = document.getElementById('bankId').value;
      const n = document.getElementById('numQuestions').value;
      const d = document.getElementById('duration').value;
      const eHours = document.getElementById('linkExpiryHours').value;
      const res = await fetch('/api/tests', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ questionBankId: b, numQuestions: n, duration: d, linkExpiryHours: eHours }) });
      if(res.ok) window.location.reload(); 
      else { alert(await getErrorMessage(res, 'Error generating session link.')); btn.innerHTML = originalText; btn.disabled = false; }
    });

    async function deleteTest(id, button) {
      if(confirm('Terminate session? This deletes the link and all associated attempt results immediately.')) {
        if (button) button.disabled = true;
        const res = await fetch(`/api/tests/${id}`, { method: 'DELETE' });
        if(res.ok) window.location.reload();
        else {
          if (button) button.disabled = false;
          alert(await getErrorMessage(res, 'Failed to delete test.'));
        }
      }
    }
  </script>
</body>
</html>
