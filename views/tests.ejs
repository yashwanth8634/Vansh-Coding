<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tests | Admin Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Montserrat:wght@600;700&family=Noto+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
      rel="stylesheet"
    />

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Albert Sans", "Noto Sans", "sans-serif"],
              display: ["Montserrat", "sans-serif"],
            },
          },
        },
      };
    </script>

    <style>
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        font-size: 20px;
      }
      .tab-btn.active { color: #4f46e5 !important; border-color: #4f46e5 !important; background-color: #eef2ff !important; }
    </style>
  </head>
  <body
    class="bg-[radial-gradient(circle_at_top_left,_#dbeafe,_#f8fafc_35%,_#f8fafc)] font-sans text-gray-900"
  >
    <!-- ===== NAVBAR ===== -->
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
      <div
        class="container max-w-7xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center"
      >
        <h1 class="text-xl sm:text-2xl font-bold font-display text-indigo-600">
          Admin Dashboard
        </h1>
        <button
          id="logout-btn"
          class="bg-red-600 text-white py-2 px-3 sm:px-4 rounded-lg hover:bg-red-700 font-medium transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 text-sm sm:text-base"
        >
          Logout
        </button>
      </div>
    </nav>

    <div class="container max-w-7xl mx-auto p-4 md:p-8">

      <!-- ===== TAB NAVIGATION ===== -->
      <div class="flex space-x-1 mb-6 bg-white rounded-xl border border-gray-200 p-1 shadow-sm overflow-x-auto">
        <a href="/admin" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">dashboard</span>
          Overview
        </a>
        <a href="/admin/banks" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">quiz</span>
          Question Banks
        </a>
        <a href="/admin/tests" class="tab-btn active flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">assignment</span>
          Tests
        </a>
      </div>

      <!-- ===== CONTENT ===== -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Create Test Form -->
        <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100 mb-6 lg:mb-0">
          <h2 class="text-lg sm:text-xl font-semibold mb-4 pb-4 border-b border-gray-200">
            Create New Test
          </h2>
          <form id="create-test-form" class="space-y-4">
            <div>
              <label
                for="bank-select"
                class="block text-sm font-medium text-gray-700 mb-1"
                >Question Bank:</label
              >
              <select
                id="bank-select"
                required
                class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500"
              >
                <option value="">-- Select a Bank --</option>
                <% if (banks.length > 0) { %> <% banks.forEach(bank => { %>
                <option value="<%= bank._id %>"><%= bank.title %></option>
                <% }); %> <% } else { %>
                <option value="" disabled>No question banks found.</option>
                <% } %>
              </select>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label
                  for="num-questions"
                  class="block text-sm font-medium text-gray-700 mb-1"
                  ># of Questions:</label
                >
                <input
                  type="number"
                  id="num-questions"
                  value="10"
                  required
                  class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500"
                />
              </div>
              <div>
                <label
                  for="duration"
                  class="block text-sm font-medium text-gray-700 mb-1"
                  >Duration (mins):</label
                >
                <input
                  type="number"
                  id="duration"
                  value="30"
                  required
                  class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500"
                />
              </div>
              <div>
                <label
                  for="expiry"
                  class="block text-sm font-medium text-gray-700 mb-1"
                  >Link Expiry (hours):</label
                >
                <input
                  type="number"
                  id="expiry"
                  value="24"
                  required
                  class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500"
                />
              </div>
            </div>
            <button
              type="submit"
              class="w-full bg-indigo-600 text-white py-3 px-4 rounded-lg hover:bg-indigo-700 font-medium transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
            >
              Create Test Link
            </button>
          </form>
          <div
            id="test-link-result"
            class="mt-4 p-4 bg-gray-50 rounded-lg"
            style="display: none"
          ></div>
        </div>

        <!-- Active & Expired Tests List -->
        <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100">
          <h2 class="text-lg sm:text-xl font-semibold mb-4 pb-4 border-b border-gray-200">
            Active & Expired Tests
            <span class="text-sm font-normal text-gray-400 ml-2">(<%= tests.length %>)</span>
          </h2>
          <div class="space-y-3 max-h-[32rem] overflow-y-auto">
            <% if (tests.length === 0) { %>
            <p class="text-gray-500 p-3">No tests created yet.</p>
            <% } else { %> <% tests.forEach(test => { %>
            <div
              class="border border-gray-200 p-4 rounded-lg hover:bg-gray-50 transition-colors duration-150"
            >
              <div class="flex flex-wrap justify-between items-start gap-3">
                <div>
                  <strong class="font-semibold text-indigo-600">
                    <%= test.questionBank ? test.questionBank.title : 'Deleted Bank' %></strong
                  >
                  <p class="text-sm text-gray-600">
                    <%= test.numQuestions %> Questions, <%= test.duration %>
                    Mins
                  </p>
                  <p class="text-sm text-gray-500">
                    Expires: <%= new Date(test.linkExpiresAt).toLocaleString()
                    %>
                  </p>
                </div>
                <a
                  href="/admin/test/<%= test._id %>/results"
                  class="text-sm bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
                >
                  View Results
                </a>
              </div>
              <input
                type="text"
                value="<%= `/test/${test.uniqueLink}` %>"
                readonly
                data-role="test-link"
                class="w-full p-2 border border-gray-200 rounded-md bg-gray-100 text-sm mt-3 font-mono"
              />
              <button
                type="button"
                data-action="copy-link"
                class="mt-2 text-sm text-indigo-600 font-semibold hover:text-indigo-800"
              >
                Copy Link
              </button>
            </div>
            <% }); %> <% } %>
          </div>
        </div>
      </div>

    </div>

    <script src="/js/admin.js"></script>
  </body>
</html>
