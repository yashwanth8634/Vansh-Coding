<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Questions</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
      rel="stylesheet"
    />

    <%- include('partials/tailwind-setup') %>
  </head>
  <body class="vc-admin bg-black text-white selection:bg-white/30">
    <div class="fixed inset-0 grid-bg pointer-events-none z-0"></div>

    <nav class="glass-nav sticky top-0 z-10 relative">
      <div
        class="container max-w-7xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center"
      >
        <h1 class="text-xl sm:text-2xl font-semibold text-white tracking-tight">
          Admin Dashboard
        </h1>
        <a
          href="/admin"
          class="bg-white/5 border border-white/10 text-gray-300 py-2 px-3 sm:px-4 rounded-lg hover:bg-white/10 hover:text-white font-medium transition-colors duration-150 text-sm sm:text-base"
        >
          &larr; Back to Dashboard
        </a>
      </div>
    </nav>

    <div class="container max-w-7xl mx-auto p-4 md:p-8 relative z-10">
      <h1 class="text-2xl sm:text-3xl font-semibold mb-6 tracking-tight">
        Editing Bank: <span class="text-white"><%= bank.title %></span>
      </h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
        <div class="glass-card p-5 md:p-6 rounded-xl">
          <h2
            id="form-title"
            class="text-lg sm:text-xl font-semibold mb-4 pb-4 border-b border-white/10 text-white"
          >
            Add a New Question
          </h2>
          <form id="add-question-form" class="space-y-4 pt-6">
            <input type="hidden" id="edit-question-id" value="" />

            <div>
              <label
                for="question-text"
                class="block text-sm font-medium text-gray-300 mb-1"
                >Question Text:</label
              >
              <textarea
                id="question-text"
                rows="3"
                required
                class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
              ></textarea>
            </div>

            <div>
              <label
                for="image-url"
                class="block text-sm font-medium text-gray-300 mb-1"
                >Image URL (Optional):</label
              >
              <input
                type="text"
                id="image-url"
                placeholder="https://i.imgur.com/your-image.png"
                class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
              />
              <p class="text-xs text-gray-500 mt-1">
                Paste a direct image URL to preview before saving.
              </p>
              <div id="image-preview-wrap" class="hidden mt-3">
                <img
                  id="image-preview"
                  alt="Question Preview"
                  class="w-full max-h-44 object-contain rounded-lg border border-white/10 bg-black p-2"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="option1"
                   class="block text-sm font-medium text-gray-300 mb-1"
                   >Option 1:</label
                >
                <input
                  type="text"
                  id="option1"
                  required
                   class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
                 />
              </div>
              <div>
                <label
                  for="option2"
                   class="block text-sm font-medium text-gray-300 mb-1"
                   >Option 2:</label
                >
                <input
                  type="text"
                  id="option2"
                  required
                   class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
                 />
              </div>
              <div>
                <label
                  for="option3"
                   class="block text-sm font-medium text-gray-300 mb-1"
                   >Option 3:</label
                >
                <input
                  type="text"
                  id="option3"
                  required
                   class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
                 />
              </div>
              <div>
                <label
                  for="option4"
                   class="block text-sm font-medium text-gray-300 mb-1"
                   >Option 4:</label
                >
                <input
                  type="text"
                  id="option4"
                  required
                   class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
                 />
              </div>
            </div>

            <div>
              <label
                for="correct-answer"
                 class="block text-sm font-medium text-gray-300 mb-1"
                 >Correct Answer:</label
              >
              <select
                id="correct-answer"
                required
                 class="mt-1 block w-full p-3 bg-[#0a0a0a] border border-white/10 rounded-lg text-white placeholder-gray-600 focus:bg-[#111] focus:border-white/30 outline-none"
               >
                <option value="">-- Select Correct Option --</option>
                <option value="1">Option 1</option>
                <option value="2">Option 2</option>
                <option value="3">Option 3</option>
                <option value="4">Option 4</option>
              </select>
            </div>

            <div
              class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-2 pt-2"
            >
              <button
                type="submit"
                id="submit-btn"
                class="w-full bg-white text-black py-3 px-4 rounded-lg hover:bg-gray-200 font-medium transition-colors duration-150"
              >
                Add Question
              </button>
              <button
                type="button"
                id="cancel-edit-btn"
                style="display: none"
                class="w-full bg-white/10 border border-white/10 text-gray-300 py-3 px-4 rounded-lg hover:bg-white/15 hover:text-white font-medium transition-colors duration-150"
              >
                Cancel Edit
              </button>
            </div>
          </form>
          <div id="form-message" class="mt-4 text-sm font-medium"></div>
        </div>

        <div class="glass-card p-5 md:p-6 rounded-xl">
          <h2
            class="text-lg sm:text-xl font-semibold mb-4 pb-4 border-b border-white/10 text-white"
          >
            Existing Questions (<span id="question-count"
              ><%= questions.length %></span
            >)
          </h2>
          <div
            id="question-list"
            class="space-y-4 max-h-[80vh] overflow-y-auto pt-6"
          >
            <% if (questions.length === 0) { %>
              <p id="no-questions-message" class="text-gray-500 p-3">
                No questions have been added to this bank yet.
              </p>
            <% } else { %> <% questions.forEach(q => { %>
            <div
              id="question-<%= q._id %>"
              class="border border-white/10 bg-black/30 p-4 rounded-lg"
            >
              <% if (q.imageUrl) { %>
              <img
                src="<%= q.imageUrl %>"
                alt="Question Image"
                class="w-full max-h-40 object-cover rounded-md mb-3 border border-white/10"
              />
              <% } %>

              <p class="font-medium text-gray-100 break-words">
                <%= q.questionText %>
              </p>
              <ul
                class="list-disc list-inside text-sm text-gray-400 my-2 space-y-1"
              >
                <% q.options.forEach(opt => { %> <% if (opt === q.correctAnswer)
                { %>
                <li class="text-green-400 font-bold"><%= opt %> (Correct)</li>
                <% } else { %>
                <li><%= opt %></li>
                <% } %> <% }); %>
              </ul>

              <div class="flex items-center space-x-3 mt-2">
                <button
                  data-action="edit-question"
                  data-id="<%= q._id %>"
                  data-text="<%= q.questionText %>"
                  data-imageurl="<%= q.imageUrl || '' %>"
                  data-opt1="<%= q.options[0] %>"
                  data-opt2="<%= q.options[1] %>"
                  data-opt3="<%= q.options[2] %>"
                  data-opt4="<%= q.options[3] %>"
                  data-correct="<%= q.correctAnswer %>"
                  class="text-gray-500 hover:text-indigo-600 transition-colors"
                  title="Edit Question"
                >
                  <span class="material-symbols-outlined">edit</span>
                </button>

                <button
                  data-action="delete-question"
                  data-id="<%= q._id %>"
                  class="text-gray-500 hover:text-red-600 transition-colors"
                  title="Delete Question"
                >
                  <span class="material-symbols-outlined">delete</span>
                </button>
              </div>
            </div>
            <% }); %> <% } %>
          </div>
        </div>
      </div>
    </div>

    <script src="/js/add-questions.js"></script>
  </body>
</html>
