<aside class="w-full md:w-64 glass-sidebar flex flex-col shrink-0 z-20 md:h-full">
  <div class="flex items-center justify-start gap-3 border-b border-white/10 px-4 py-4 md:h-16 md:px-6 shrink-0">
    <span class="material-symbols-outlined text-[24px] text-white">terminal</span>
    <span class="font-semibold tracking-tight text-white">Mr & Ms Coder</span>
  </div>

  <nav class="flex-1 overflow-x-auto md:overflow-y-auto px-3 py-3 md:py-6">
    <div class="flex md:block gap-2 md:space-y-2 min-w-max md:min-w-0">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3 hidden md:block">Main</div>
      <a href="/admin" class="nav-item <%= activePage === 'overview' ? 'active' : '' %> flex shrink-0 items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">space_dashboard</span>
        <span class="text-sm">Overview</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">MCQ Section</div>
      <a href="/admin/banks" class="nav-item <%= activePage === 'banks' ? 'active' : '' %> flex shrink-0 items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">folder_open</span>
        <span class="text-sm">Question Banks</span>
      </a>
      <a href="/admin/tests" class="nav-item <%= activePage === 'tests' || activePage === 'tests-links' ? 'active' : '' %> flex shrink-0 items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">link</span>
        <span class="text-sm">Tests</span>
      </a>

      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">Coding Section</div>
      <a href="/admin/coding/banks" class="nav-item <%= activePage === 'coding-banks' ? 'active' : '' %> flex shrink-0 items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">data_object</span>
        <span class="text-sm">Coding Environments</span>
      </a>
      <a href="/admin/coding/tests" class="nav-item <%= activePage === 'coding-tests' || activePage === 'coding-test-links' ? 'active' : '' %> flex shrink-0 items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">api</span>
        <span class="text-sm">Coding Sessions</span>
      </a>
      <a href="/admin/coding" class="nav-item <%= activePage === 'coding-admin' ? 'active' : '' %> flex shrink-0 items-center gap-3 px-3 py-2.5 rounded-lg">
        <span class="material-symbols-outlined text-[20px]">code_blocks</span>
        <span class="text-sm">Challenges</span>
      </a>
    </div>
  </nav>

  <div class="border-t border-white/10 p-3 md:p-4 shrink-0">
    <form action="/api/admin/logout" method="POST">
      <button type="submit" class="w-full md:w-full flex items-center justify-center md:justify-start gap-3 px-3 py-2.5 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors">
        <span class="material-symbols-outlined text-[20px]">logout</span>
        <span class="text-sm font-medium">Sign Out</span>
      </button>
    </form>
  </div>
</aside>
