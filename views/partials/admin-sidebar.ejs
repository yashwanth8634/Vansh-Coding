<aside class="w-20 md:w-64 glass-sidebar flex flex-col shrink-0 z-20">
  <div class="h-16 flex items-center justify-center md:justify-start md:px-6 border-b border-white/10 shrink-0">
    <span class="material-symbols-outlined text-[24px] text-white">terminal</span>
    <span class="ml-3 font-semibold tracking-tight text-white hidden md:block">Mr & Ms Coder</span>
  </div>

  <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-2">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3 hidden md:block">Main</div>
    <a href="/admin" class="nav-item <%= activePage === 'overview' ? 'active' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-lg">
      <span class="material-symbols-outlined text-[20px]">space_dashboard</span>
      <span class="text-sm hidden md:block">Overview</span>
    </a>

    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">MCQ Section</div>
    <a href="/admin/banks" class="nav-item <%= activePage === 'banks' ? 'active' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-lg">
      <span class="material-symbols-outlined text-[20px]">folder_open</span>
      <span class="text-sm hidden md:block">Question Banks</span>
    </a>
    <a href="/admin/tests" class="nav-item <%= activePage === 'tests' || activePage === 'tests-links' ? 'active' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-lg">
      <span class="material-symbols-outlined text-[20px]">link</span>
      <span class="text-sm hidden md:block">Tests</span>
    </a>

    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 px-3 hidden md:block">Coding Section</div>
    <a href="/admin/coding/banks" class="nav-item <%= activePage === 'coding-banks' ? 'active' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-lg">
      <span class="material-symbols-outlined text-[20px]">data_object</span>
      <span class="text-sm hidden md:block">Coding Environments</span>
    </a>
    <a href="/admin/coding/tests" class="nav-item <%= activePage === 'coding-tests' || activePage === 'coding-test-links' ? 'active' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-lg">
      <span class="material-symbols-outlined text-[20px]">api</span>
      <span class="text-sm hidden md:block">Coding Sessions</span>
    </a>
    <a href="/admin/coding" class="nav-item <%= activePage === 'coding-admin' ? 'active' : '' %> flex items-center gap-3 px-3 py-2.5 rounded-lg">
      <span class="material-symbols-outlined text-[20px]">code_blocks</span>
      <span class="text-sm hidden md:block">Challenges</span>
    </a>
  </nav>

  <div class="p-4 border-t border-white/10 shrink-0">
    <form action="/api/admin/logout" method="POST">
      <button type="submit" class="w-full flex items-center justify-center md:justify-start gap-3 px-3 py-2.5 rounded-lg text-red-400 hover:bg-red-500/10 transition-colors">
        <span class="material-symbols-outlined text-[20px]">logout</span>
        <span class="text-sm font-medium hidden md:block">Sign Out</span>
      </button>
    </form>
  </div>
</aside>
