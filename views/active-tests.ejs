<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Active Tests | Vansh2k26</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <%- include('partials/tailwind-setup') %>
</head>
<body class="font-brand bg-[radial-gradient(1200px_700px_at_-10%_-20%,rgba(239,77,141,0.16),transparent_50%),radial-gradient(1000px_600px_at_110%_-10%,rgba(33,197,165,0.16),transparent_55%),radial-gradient(900px_500px_at_50%_120%,rgba(127,109,255,0.14),transparent_55%),#f7f6f3] text-[#1c1a18] selection:bg-emerald-200/70">

  <div class="fixed inset-0 soft-grid pointer-events-none z-0"></div>

  <nav class="sticky top-0 z-40 border-b border-black/5 bg-white/50 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-4 md:py-0 min-h-20 flex flex-wrap items-center justify-between gap-3">
      <a href="/" class="flex items-center w-20 md:w-52">
        <img src="/images/1.png" alt="Vansh2k26 Logo" class="h-12 md:h-16 w-auto object-contain">
      </a>

      <div class="hidden md:flex items-center gap-8 text-sm font-bold text-stone-700">
        <a href="/" class="hover:text-stone-900 transition-colors">Home</a>
        <a href="/active-tests" class="hover:text-stone-900 transition-colors">Active Tests</a>
      </div>

      <div class="flex items-center justify-end gap-3 ml-auto md:ml-0 md:w-52 lg:w-56">
        <a href="/" class="btn-pill hidden md:inline-flex">Home</a>
        <a href="/active-tests" class="btn-pill">Active Tests</a>
      </div>
    </div>
  </nav>

  <main class="relative z-10 px-5 md:px-8 py-10 md:py-14">
    <section class="max-w-7xl mx-auto">
      <div class="glass rounded-3xl p-8 md:p-10">
        <p class="text-xs uppercase tracking-[0.2em] text-stone-500 font-semibold">Live Access</p>
        <h1 class="display-font mt-3 text-4xl md:text-6xl text-stone-900">Active Tests</h1>
        <p class="mt-4 max-w-2xl text-stone-600 text-lg leading-relaxed">
          Choose any active quiz or coding test. Student details will be collected before the attempt starts.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto mt-8">
      <% 
        const now = new Date();
        const validTests = (activeTests || []).filter(t => !t.expiresAt || new Date(t.expiresAt) > now);
        if (validTests.length > 0) { 
      %>
        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
          <% validTests.forEach((test) => { 
               const LOCALE = 'en-IN';
               const expiry = test.expiresAt ? new Date(test.expiresAt) : null;
               const isValidLink = test.link && (test.link.startsWith('/') || test.link.startsWith('http'));
               const safeLink = isValidLink ? test.link : '#';
          %>
            <article class="glass rounded-2xl p-6">
              <div class="flex items-center justify-between gap-3">
                <span class="inline-flex items-center rounded-full border border-stone-300 bg-white/70 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-stone-600">
                  <%= test.type %> Test
                </span>
                <span class="text-xs font-semibold uppercase tracking-[0.15em] text-stone-500">
                  <%= test.duration %> mins
                </span>
              </div>
              <h2 class="mt-5 text-xl font-extrabold text-stone-900"><%= test.title %></h2>
              <p class="mt-3 text-sm text-stone-600 leading-relaxed">
                <% if (expiry && !isNaN(expiry.valueOf())) { %>
                  Expires on <%= expiry.toLocaleString(LOCALE, { dateStyle: 'medium', timeStyle: 'short' }) %>
                <% } else { %>
                  No expiry set
                <% } %>
              </p>
              <a href="<%= safeLink %>" rel="noopener noreferrer" class="btn-primary mt-6 px-5 py-3">
                Open Test
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </a>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="glass rounded-2xl p-8 md:p-10">
          <p class="text-sm uppercase tracking-[0.2em] text-stone-500 font-semibold">No Active Tests</p>
          <h2 class="mt-3 text-2xl font-extrabold text-stone-900">Nothing is live right now.</h2>
          <p class="mt-3 max-w-2xl text-stone-600 leading-relaxed">
            Once an admin creates an unexpired quiz or coding link, it will automatically appear here.
          </p>
          <a href="/" class="btn-secondary mt-6 px-5 py-3">
            Back to Home
            <span class="material-symbols-outlined text-[18px]">west</span>
          </a>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
