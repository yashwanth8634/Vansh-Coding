<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Challenges | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex min-h-screen flex-col md:h-screen md:flex-row overflow-x-hidden md:overflow-hidden antialiased selection:bg-white/30">

  <%- include('partials/admin-sidebar', { activePage: 'coding-admin' }) %>

  <main class="flex-1 flex min-h-0 flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">Coding Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Coding Challenges</span>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-2 gap-8">
        
        <!-- Creator Form -->
        <div class="space-y-6">
          <div>
            <h1 id="form-heading" class="text-2xl font-semibold tracking-tight text-white mb-2">Create New Challenge</h1>
            <p id="form-subheading" class="text-gray-400 font-light text-sm">Define a new coding problem.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-orange-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <form id="challengeForm" class="space-y-5 relative z-10">
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Challenge Title</label>
                <input type="text" id="title" required 
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none" 
                  placeholder="e.g., Two Sum">
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Difficulty</label>
                <select id="difficulty" class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white appearance-none focus:bg-[#111] focus:border-white/30 transition-all outline-none cursor-pointer">
                  <option value="Easy" class="bg-[#111]">Easy</option>
                  <option value="Medium" class="bg-[#111]">Medium</option>
                  <option value="Hard" class="bg-[#111]">Hard</option>
                </select>
              </div>
              <div>
                <label class="flex justify-between items-center text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">
                  <span>Problem Description</span>
                  <span class="bg-white/10 text-white border border-white/10 px-2 py-0.5 rounded text-[10px] tracking-widest normal-case">Markdown</span>
                </label>
                <textarea id="description" rows="5" required 
                  class="w-full p-4 bg-[#0a0a0a] border border-white/10 rounded-xl font-mono text-sm text-gray-300 focus:bg-[#111] focus:border-white/30 transition-all outline-none resize-y"
                  placeholder="Given an array of integers nums and an integer target..."></textarea>
              </div>

              <!-- Test Cases -->
              <div class="border-t border-white/10 pt-5 mt-2">
                <div class="flex justify-between items-center mb-4">
                  <h3 class="text-sm font-medium text-white">Test Cases</h3>
                  <button type="button" onclick="addTestCase()" class="bg-white/10 hover:bg-white/20 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors border border-white/10 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">add</span> Add Case
                  </button>
                </div>
                
                <div id="testCasesContainer" class="space-y-4 max-h-[30rem] overflow-y-auto pr-2">
                  <div class="test-case-card relative bg-[#0a0a0a] border border-white/10 p-4 rounded-xl group focus-within:border-white/30">
                    <button type="button" onclick="this.parentElement.remove()" class="absolute top-2 right-2 text-gray-500 hover:text-red-400 transition-colors">
                      <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-1">
                      <div>
                        <label class="block text-[10px] font-medium text-gray-500 uppercase tracking-wider mb-1">STDIN Data</label>
                        <textarea class="tc-input w-full p-2.5 bg-black border border-white/5 rounded-lg font-mono text-xs text-gray-300 focus:border-white/20 outline-none resize-y" rows="2" placeholder="[2,7,11,15]\n9"></textarea>
                      </div>
                      <div>
                        <label class="block text-[10px] font-medium text-gray-500 uppercase tracking-wider mb-1">STDOUT Expected</label>
                        <textarea class="tc-output w-full p-2.5 bg-black border border-white/5 rounded-lg font-mono text-xs text-gray-300 focus:border-white/20 outline-none resize-y" rows="2" required placeholder="[0,1]"></textarea>
                      </div>
                    </div>
                    <label class="flex items-center mt-3 cursor-pointer w-max gap-2">
                      <input type="checkbox" class="tc-hidden w-4 h-4 rounded border-white/20 accent-white cursor-pointer">
                      <span class="text-xs text-gray-400 select-none hover:text-gray-300">Hidden from student</span>
                    </label>
                  </div>
                </div>
                </div>
              </div>

              <div class="flex gap-3 mt-4">
                <button type="submit" id="submitBtn" class="flex-1 bg-white text-black hover:bg-gray-200 py-3 px-4 rounded-xl text-sm font-semibold transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.98] flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-[18px]">add_circle</span> Create Challenge
                </button>
                <button type="button" id="cancelEditBtn" onclick="cancelEdit()" class="hidden bg-transparent border border-white/10 text-gray-400 hover:text-white hover:border-white/30 py-3 px-4 rounded-xl text-sm font-medium transition-colors flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-[18px]">close</span> Cancel
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Existing List -->
        <div class="space-y-6" id="challenges-list">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Existing Challenges</h1>
            <p class="text-gray-400 font-light text-sm">List of available challenges.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-2 h-max md:max-h-[calc(100vh-150px)] overflow-y-auto">
            <div class="space-y-2 p-2">
              <% challenges.forEach(c => { %>
                <div class="bg-black/40 border border-white/5 hover:border-white/10 hover:bg-white/5 p-5 rounded-xl transition-all group">
                  <div class="flex justify-between items-start mb-2">
                    <strong class="text-base font-medium text-white leading-tight"><%= c.title %></strong>
                    <div class="flex items-center gap-1 ml-2 shrink-0">
                      <button data-challenge="<%= JSON.stringify(c) %>" class="edit-btn text-gray-500 hover:text-blue-400 bg-transparent hover:bg-blue-500/10 border border-transparent hover:border-blue-500/20 p-1.5 rounded-lg transition-colors" title="Edit">
                        <span class="material-symbols-outlined text-[16px]">edit</span>
                      </button>
                      <button data-delete-id="<%= c._id %>" class="delete-btn text-gray-500 hover:text-red-400 bg-transparent hover:bg-red-500/10 border border-transparent hover:border-red-500/20 p-1.5 rounded-lg transition-colors" title="Delete">
                        <span class="material-symbols-outlined text-[16px]">delete</span>
                      </button>
                    </div>
                  </div>
                  
                  <div class="flex items-center gap-2 mt-1">
                    <% 
                       let badgeClass = 'bg-green-500/10 text-green-400 border-green-500/20';
                       if(c.difficulty === 'Medium') badgeClass = 'bg-orange-500/10 text-orange-400 border-orange-500/20';
                       if(c.difficulty === 'Hard') badgeClass = 'bg-red-500/10 text-red-400 border-red-500/20';
                    %>
                    <span class="inline-flex items-center border px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider <%= badgeClass %>">
                      <%= c.difficulty %>
                    </span>
                    <span class="inline-flex items-center text-[10px] font-semibold text-gray-400 tracking-wider uppercase border border-white/10 bg-white/5 px-2 py-0.5 rounded">
                      <%= c.testCases.length %> Test Cases
                    </span>
                  </div>
                </div>
              <% }); %>
              <% if(challenges.length === 0) { %>
                <div class="text-gray-500 text-center py-16 text-sm font-medium bg-black/20 rounded-xl border border-dashed border-white/10 flex flex-col items-center">
                  <span class="material-symbols-outlined text-4xl mb-3 opacity-50">data_array</span>
                  No challenges found.
                </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <script>
    function showToast(message, type = 'error') {
      const existing = document.getElementById('vc-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.id = 'vc-toast';
      const color = type === 'error' ? 'border-red-500/30 text-red-500 bg-red-500/10' : 'border-green-500/30 text-green-500 bg-green-500/10';
      toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-5 py-3 rounded-xl glass-card border ${color} text-sm font-medium shadow-xl transition-all duration-300`;
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => { if (document.getElementById('vc-toast')) toast.remove() }, 4000);
    }

    async function getErrorMessage(res, fallback) {
        try {
            const data = await res.json();
            return data.message || fallback;
        } catch (error) {
            return fallback;
        }
    }

    function addTestCase() {
        const container = document.getElementById('testCasesContainer');
        const div = document.createElement('div');
        div.className = "test-case-card relative bg-[#0a0a0a] border border-white/10 p-4 rounded-xl group focus-within:border-white/30";
        div.innerHTML = `
            <button type="button" onclick="this.parentElement.remove()" class="absolute top-2 right-2 text-gray-500 hover:text-red-400 transition-colors">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-1">
                <div>
                <label class="block text-[10px] font-medium text-gray-500 uppercase tracking-wider mb-1">STDIN Data</label>
                <textarea class="tc-input w-full p-2.5 bg-black border border-white/5 rounded-lg font-mono text-xs text-gray-300 focus:border-white/20 outline-none resize-y" rows="2"></textarea>
                </div>
                <div>
                <label class="block text-[10px] font-medium text-gray-500 uppercase tracking-wider mb-1">STDOUT Expected</label>
                <textarea class="tc-output w-full p-2.5 bg-black border border-white/5 rounded-lg font-mono text-xs text-gray-300 focus:border-white/20 outline-none resize-y" rows="2" required></textarea>
                </div>
            </div>
            <label class="flex items-center mt-3 cursor-pointer w-max gap-2">
                <input type="checkbox" class="tc-hidden w-4 h-4 rounded border-white/20 accent-white cursor-pointer">
                <span class="text-xs text-gray-400 select-none hover:text-gray-300">Hidden from student</span>
            </label>
        `;
        container.appendChild(div);
    }



    let editingId = null;

    function editChallenge(c) {
      editingId = c._id;
      document.getElementById('title').value = c.title;
      document.getElementById('difficulty').value = c.difficulty;
      document.getElementById('description').value = c.description;

      // Rebuild test cases
      const container = document.getElementById('testCasesContainer');
      container.innerHTML = '';
      (c.testCases || []).forEach(tc => {
        addTestCase();
        const cards = container.querySelectorAll('.test-case-card');
        const last = cards[cards.length - 1];
        last.querySelector('.tc-input').value = tc.input || '';
        last.querySelector('.tc-output').value = tc.expectedOutput || '';
        const hidden = last.querySelector('.tc-hidden');
        hidden.checked = tc.isHidden || false;
      });

      // Update UI
      document.getElementById('form-heading').textContent = 'Edit Challenge';
      document.getElementById('form-subheading').textContent = 'Modify "' + c.title + '"';
      document.getElementById('submitBtn').innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Update Challenge';
      document.getElementById('cancelEditBtn').classList.remove('hidden');
      document.getElementById('form-heading').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function cancelEdit() {
      editingId = null;
      document.getElementById('challengeForm').reset();
      document.getElementById('form-heading').textContent = 'Create New Challenge';
      document.getElementById('form-subheading').textContent = 'Define a new coding problem.';
      document.getElementById('submitBtn').innerHTML = '<span class="material-symbols-outlined text-[18px]">add_circle</span> Create Challenge';
      document.getElementById('cancelEditBtn').classList.add('hidden');

      // Reset test cases to one blank card
      const container = document.getElementById('testCasesContainer');
      container.innerHTML = '';
      addTestCase();
    }

    document.getElementById('challengeForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        
        const originalText = btn.innerHTML;
        btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Saving...';

        const title = document.getElementById('title').value;
        const difficulty = document.getElementById('difficulty').value;
        const description = document.getElementById('description').value;

        const testCaseElements = document.querySelectorAll('.test-case-card');
        const testCases = [];
        let hasInvalidCase = false;
        
        testCaseElements.forEach(card => {
            const output = card.querySelector('.tc-output').value.trim();
            if (!output) {
                hasInvalidCase = true;
                card.querySelector('.tc-output').classList.add('border-red-500/50');
            } else {
                card.querySelector('.tc-output').classList.remove('border-red-500/50');
            }
            
            testCases.push({
                input: card.querySelector('.tc-input').value,
                expectedOutput: output,
                isHidden: card.querySelector('.tc-hidden').checked
            });
        });

        if (testCases.length === 0) {
          showToast('At least 1 valid I/O circuit is required.');
          btn.innerHTML = originalText; btn.disabled = false;
          return;
        }
        
        if (hasInvalidCase) {
          showToast('All test cases must have an expected output.');
          btn.innerHTML = originalText; btn.disabled = false;
          return;
        }

        const isEditing = !!editingId;
        const url = isEditing ? `/api/coding/admin/${editingId}` : '/api/coding/admin/create';
        const method = isEditing ? 'PUT' : 'POST';

        try {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, difficulty, description, testCases })
            });

            if(res.ok) {
              window.location.href = window.location.pathname + '#challenges-list';
              window.location.reload();
            }
            else { showToast(await getErrorMessage(res, 'Operation failed.')); btn.innerHTML = originalText; btn.disabled = false; }
        } catch(err) { showToast('Error: ' + err.message); btn.innerHTML = originalText; btn.disabled = false; }
    });

    document.addEventListener('click', async (e) => {
      const editBtn = e.target.closest('.edit-btn');
      if (editBtn) {
        const c = JSON.parse(editBtn.dataset.challenge);
        editChallenge(c);
        return;
      }

      const deleteBtn = e.target.closest('.delete-btn');
      if (deleteBtn && !deleteBtn.dataset.confirmPending) {
        deleteBtn.dataset.confirmPending = 'true';
        deleteBtn.innerHTML = '<span class="material-symbols-outlined text-[14px]">check</span>';
        deleteBtn.title = 'Click again to confirm delete';
        deleteBtn.classList.add('text-red-400', 'border-red-500/20', 'bg-red-500/10');
        setTimeout(() => {
            if (deleteBtn.dataset.confirmPending) {
                delete deleteBtn.dataset.confirmPending;
                deleteBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">delete</span>';
                deleteBtn.title = 'Delete';
                deleteBtn.classList.remove('text-red-400', 'border-red-500/20', 'bg-red-500/10');
            }
        }, 3000);
        return;
      }

      const confirmBtn = e.target.closest('[data-confirm-pending]');
      if (confirmBtn) {
          const id = confirmBtn.dataset.deleteId;
          delete confirmBtn.dataset.confirmPending;
          confirmBtn.disabled = true;
          confirmBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[16px]">sync</span>';
          try {
              const res = await fetch(`/api/coding/admin/${id}`, { method: 'DELETE' });
              if(res.ok) window.location.reload();
              else {
                confirmBtn.disabled = false;
                showToast(await getErrorMessage(res, 'Failed to delete challenge.'));
                confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">delete</span>';
                confirmBtn.classList.remove('text-red-400', 'border-red-500/20', 'bg-red-500/10');
              }
          } catch(err) {
              confirmBtn.disabled = false;
              showToast('Error: ' + err.message);
              confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">delete</span>';
              confirmBtn.classList.remove('text-red-400', 'border-red-500/20', 'bg-red-500/10');
          }
      }
    });
  </script>
</body>
</html>
