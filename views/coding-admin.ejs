<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coding Platform | Admin Dashboard</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Montserrat:wght@600;700&family=Noto+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Albert Sans", "Noto Sans", "sans-serif"],
              display: ["Montserrat", "sans-serif"],
            },
          },
        },
      };
    </script>

    <style>
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        font-size: 20px;
      }
      .tab-btn.active { color: #4f46e5 !important; border-color: #4f46e5 !important; background-color: #eef2ff !important; }
    </style>
  </head>
  <body class="bg-[radial-gradient(circle_at_top_left,_#dbeafe,_#f8fafc_35%,_#f8fafc)] font-sans text-gray-900">
    <!-- ===== NAVBAR ===== -->
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
      <div class="container max-w-7xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center">
        <h1 class="text-xl sm:text-2xl font-bold font-display text-indigo-600">Admin Dashboard</h1>
        <button id="logout-btn" class="bg-red-600 text-white py-2 px-3 sm:px-4 rounded-lg hover:bg-red-700 font-medium transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 text-sm sm:text-base">Logout</button>
      </div>
    </nav>

    <div class="container max-w-7xl mx-auto p-4 md:p-8">

      <!-- ===== TAB NAVIGATION ===== -->
      <div class="flex space-x-1 mb-6 bg-white rounded-xl border border-gray-200 p-1 shadow-sm overflow-x-auto">
        <a href="/admin" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">dashboard</span> Overview
        </a>
        <a href="/admin/banks" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">quiz</span> Question Banks
        </a>
        <a href="/admin/tests" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">assignment</span> Tests
        </a>
        <a href="/admin/coding" class="tab-btn active flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-150 hover:bg-gray-50 whitespace-nowrap border border-transparent">
          <span class="material-symbols-outlined" style="font-size:18px">code</span> Coding Platform
        </a>
      </div>

      <!-- Sub Tabs for Coding -->
      <div class="flex space-x-1 mb-6 bg-white rounded-xl border border-gray-200 p-1 shadow-sm w-max">
        <a href="/admin/coding" class="px-4 py-2 rounded-lg text-sm font-semibold bg-indigo-50 text-indigo-700">Challenges</a>
        <a href="/admin/coding/banks" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50">Question Banks</a>
        <a href="/admin/coding/tests" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50">Test Links</a>
      </div>

      <!-- ===== CONTENT ===== -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- Create Challenge Form -->
        <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100 mb-6 lg:mb-0">
          <h2 class="text-lg sm:text-xl font-semibold mb-4 pb-4 border-b border-gray-200">Create Coding Challenge</h2>
          <form id="create-challenge-form" class="space-y-4">
            <div>
              <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title:</label>
              <input type="text" id="title" required class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500" placeholder="e.g., Two Sum" />
            </div>
            <div>
              <label for="difficulty" class="block text-sm font-medium text-gray-700 mb-1">Difficulty:</label>
              <select id="difficulty" class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500">
                <option value="Easy">Easy</option>
                <option value="Medium">Medium</option>
                <option value="Hard">Hard</option>
              </select>
            </div>
            <div>
              <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description (Text/Markdown):</label>
              <textarea id="description" rows="4" required class="mt-1 block w-full p-3 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-500" placeholder="Describe the problem, input format, and output format."></textarea>
            </div>

            <!-- Dynamic Test Cases -->
            <div>
              <div class="flex justify-between items-center mb-2">
                <label class="block text-sm font-medium text-gray-700">Test Cases:</label>
                <button type="button" id="add-testcase-btn" class="text-xs bg-gray-200 hover:bg-gray-300 text-gray-800 py-1 px-2 rounded font-medium transition-colors">
                  + Add Test Case
                </button>
              </div>
              <div id="testcases-container" class="space-y-3">
                <!-- Initially 1 visible test case -->
                <div class="testcase-block border border-gray-200 p-3 rounded-lg bg-gray-50 relative">
                  <div class="grid grid-cols-2 gap-2 mb-2">
                    <div>
                      <label class="block text-xs text-gray-500">Input (stdin):</label>
                      <textarea class="tc-input w-full p-2 border border-gray-300 rounded text-sm font-mono" rows="2"></textarea>
                    </div>
                    <div>
                      <label class="block text-xs text-gray-500">Expected Output (stdout):</label>
                      <textarea class="tc-output w-full p-2 border border-gray-300 rounded text-sm font-mono" rows="2" required></textarea>
                    </div>
                  </div>
                  <div class="flex items-center justify-between">
                    <label class="flex items-center text-sm text-gray-700 cursor-pointer">
                      <input type="checkbox" class="tc-hidden mr-2 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                      Hidden Test Case
                    </label>
                  </div>
                </div>
              </div>
            </div>

            <button type="submit" class="w-full bg-indigo-600 text-white py-3 px-4 rounded-lg hover:bg-indigo-700 font-medium transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              Create Challenge
            </button>
          </form>
          <div id="challenge-result" class="mt-4 p-4 rounded-lg hidden text-sm font-medium border"></div>
        </div>

        <!-- Existing Challenges List -->
        <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100">
          <h2 class="text-lg sm:text-xl font-semibold mb-4 pb-4 border-b border-gray-200">
            Existing Challenges <span class="text-sm font-normal text-gray-400 ml-2">(<%= challenges.length %>)</span>
          </h2>
          <div class="space-y-3 max-h-[40rem] overflow-y-auto">
            <% if (challenges.length === 0) { %>
              <p class="text-gray-500 p-3">No coding challenges created yet.</p>
            <% } else { %>
              <% challenges.forEach(c => { %>
                <div class="flex justify-between items-center border border-gray-200 p-4 rounded-lg hover:bg-gray-50 transition-colors duration-150">
                  <div>
                    <strong class="font-semibold text-gray-800 block"><%= c.title %></strong>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="text-xs px-2 py-0.5 rounded-full font-medium 
                        <%= c.difficulty === 'Easy' ? 'bg-green-100 text-green-700' : (c.difficulty === 'Medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700') %>">
                        <%= c.difficulty %>
                      </span>
                      <span class="text-xs text-gray-500"><%= c.testCases.length %> Test Cases</span>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <a href="/coding/workspace/<%= c._id %>" target="_blank" class="text-sm bg-blue-100 text-blue-700 px-3 py-1.5 rounded-md hover:bg-blue-200 transition-colors font-medium">Verify</a>
                    <button data-action="delete-challenge" data-id="<%= c._id %>" class="text-gray-400 hover:text-red-600 transition-colors bg-gray-100 p-1.5 rounded-md" title="Delete">
                      <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                    </button>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>

    </div>

    <script src="/js/admin.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // --- Dynamic Test Cases Logic ---
        const addBtn = document.getElementById('add-testcase-btn');
        const container = document.getElementById('testcases-container');

        addBtn.addEventListener('click', () => {
          const div = document.createElement('div');
          div.className = 'testcase-block border border-gray-200 p-3 rounded-lg bg-gray-50 relative mt-3';
          div.innerHTML = `
            <button type="button" class="absolute top-2 right-2 text-gray-400 hover:text-red-500 transition-colors remove-tc-btn" title="Remove">
              <span class="material-symbols-outlined" style="font-size: 16px;">close</span>
            </button>
            <div class="grid grid-cols-2 gap-2 mb-2 pr-6">
              <div>
                <label class="block text-xs text-gray-500">Input (stdin):</label>
                <textarea class="tc-input w-full p-2 border border-gray-300 rounded text-sm font-mono" rows="2"></textarea>
              </div>
              <div>
                <label class="block text-xs text-gray-500">Expected Output (stdout):</label>
                <textarea class="tc-output w-full p-2 border border-gray-300 rounded text-sm font-mono" rows="2" required></textarea>
              </div>
            </div>
            <div class="flex flex-wrap gap-4 items-center mt-2">
              <label class="flex items-center text-sm text-gray-700 cursor-pointer">
                <input type="checkbox" class="tc-hidden mr-2 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                Hidden Test Case
              </label>
            </div>
          `;
          container.appendChild(div);

          // Add remove logic
          div.querySelector('.remove-tc-btn').addEventListener('click', () => {
            div.remove();
          });
        });

        // --- Create Challenge Submission ---
        const form = document.getElementById('create-challenge-form');
        const resultDiv = document.getElementById('challenge-result');

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          resultDiv.className = 'mt-4 p-4 rounded-lg hidden text-sm font-medium border';
          
          const title = document.getElementById('title').value.trim();
          const description = document.getElementById('description').value.trim();
          const difficulty = document.getElementById('difficulty').value;

          // Gather Test Cases
          const testCaseBlocks = document.querySelectorAll('.testcase-block');
          const testCases = [];
          
          testCaseBlocks.forEach(block => {
            const input = block.querySelector('.tc-input').value;
            const output = block.querySelector('.tc-output').value.trim();
            const isHidden = block.querySelector('.tc-hidden').checked;
            
            if (output) { // only add if expected output exists
              testCases.push({ input, expectedOutput: output, isHidden });
            }
          });

          if (testCases.length === 0) {
            resultDiv.textContent = 'Please provide at least 1 test case with expected output.';
            resultDiv.classList.add('bg-red-50', 'text-red-700', 'border-red-200', 'block');
            resultDiv.classList.remove('hidden');
            return;
          }

          try {
            const btn = form.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = 'Creating...';

            const response = await fetch('/api/coding/admin/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ title, description, difficulty, testCases })
            });

            const data = await response.json();
            btn.disabled = false;
            btn.innerHTML = 'Create Challenge';

            if (response.ok) {
              window.location.reload();
            } else {
              resultDiv.textContent = data.message || 'Error creating challenge';
              resultDiv.classList.add('bg-red-50', 'text-red-700', 'border-red-200', 'block');
              resultDiv.classList.remove('hidden');
            }
          } catch (error) {
            console.error(error);
            resultDiv.textContent = 'A network error occurred.';
            resultDiv.classList.add('bg-red-50', 'text-red-700', 'border-red-200', 'block');
            resultDiv.classList.remove('hidden');
          }
        });

        // --- Delete Challenge Logic ---
        document.querySelectorAll('button[data-action="delete-challenge"]').forEach(button => {
          button.addEventListener('click', async (e) => {
            const challengeId = e.currentTarget.dataset.id;
            if (confirm('Are you sure you want to delete this challenge? It will also wipe associated student attempts.')) {
              try {
                const res = await fetch(`/api/coding/admin/${challengeId}`, { method: 'DELETE' });
                if (res.ok) {
                  window.location.reload();
                } else {
                  alert('Refused to delete challenge.');
                }
              } catch (error) {
                console.error(error);
                alert('Network error.');
              }
            }
          });
        });

      });
    </script>
  </body>
</html>
