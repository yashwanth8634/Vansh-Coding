<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Tests | Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&family=Montserrat:wght@600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    .material-symbols-outlined { font-size: 20px; }
    .tab-btn.active { color: #4f46e5 !important; border-color: #4f46e5 !important; background-color: #eef2ff !important; }
  </style>
</head>
<body class="bg-[radial-gradient(circle_at_top_left,_#dbeafe,_#f8fafc_35%,_#f8fafc)] font-sans text-gray-900">
  <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-10">
    <div class="container max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
      <h1 class="text-xl font-bold font-display text-indigo-600">Admin Dashboard</h1>
    </div>
  </nav>

  <div class="container max-w-7xl mx-auto p-4 md:p-8">
    <div class="flex space-x-1 mb-4 bg-white rounded-xl border border-gray-200 p-1 shadow-sm overflow-x-auto">
      <a href="/admin" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">dashboard</span> Overview</a>
      <a href="/admin/banks" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">quiz</span> MCQ Banks</a>
      <a href="/admin/tests" class="tab-btn flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">assignment</span> MCQ Tests</a>
      <a href="/admin/coding" class="tab-btn active flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-150 whitespace-nowrap"><span class="material-symbols-outlined" style="font-size:18px">code</span> Coding Platform</a>
    </div>

    <!-- Sub Tabs -->
    <div class="flex space-x-1 mb-6 bg-white rounded-xl border border-gray-200 p-1 shadow-sm w-max">
      <a href="/admin/coding" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50">Challenges</a>
      <a href="/admin/coding/banks" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50">Question Banks</a>
      <a href="/admin/coding/tests" class="px-4 py-2 rounded-lg text-sm font-semibold bg-indigo-50 text-indigo-700">Test Links</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Generate Link Form -->
      <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100">
        <h2 class="text-xl font-semibold mb-4 pb-4 border-b border-gray-200">Generate Test Link</h2>
        <form id="create-test-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Select Bank:</label>
            <select id="codingBankId" class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-300" required>
              <option value="">-- Choose a Bank --</option>
              <% banks.forEach(b => { %>
                <option value="<%= b._id %>"><%= b.title %> (<%= b.challenges.length %> Questions)</option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Link Validity (Hours):</label>
            <input type="number" id="validityHours" min="1" max="720" value="24" required class="w-full p-3 border border-gray-300 rounded-lg">
          </div>
          <button type="submit" class="w-full bg-indigo-600 text-white py-3 px-4 rounded-lg hover:bg-indigo-700 font-medium cursor-pointer text-center flex items-center justify-center gap-2">
             <span class="material-symbols-outlined" style="font-size:18px">link</span> Generate Link
          </button>
        </form>
      </div>

      <!-- Existing Links -->
      <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100">
        <h2 class="text-xl font-semibold mb-4 pb-4 border-b border-gray-200">Active Test Links</h2>
        <div class="space-y-3 max-h-[40rem] overflow-y-auto">
          <% tests.forEach(t => { %>
            <div class="border border-gray-200 p-4 rounded-lg bg-gray-50">
              <div class="flex justify-between items-start mb-2">
                <div>
                  <strong class="font-semibold text-gray-800 text-lg"><%= t.codingBank.title %></strong>
                  <div class="text-xs text-gray-500 mt-1">Expires: <%= new Date(t.linkExpiresAt).toLocaleString() %></div>
                </div>
                <div class="flex gap-2">
                  <a href="/admin/coding/results/<%= t._id %>" class="text-sm bg-blue-100 text-blue-700 px-3 py-1.5 rounded-md hover:bg-blue-200 font-medium">Results</a>
                  <button onclick="deleteTest('<%= t._id %>')" class="text-gray-400 hover:text-red-600 bg-gray-200 p-1.5 rounded-md" title="Delete">
                    <span class="material-symbols-outlined" style="font-size:18px">delete</span>
                  </button>
                </div>
              </div>
              <div class="mt-3 bg-white border border-gray-200 rounded p-2 flex items-center justify-between group">
                <a href="/coding/test/<%= t.uniqueLink %>" target="_blank" class="text-indigo-600 font-mono text-sm group-hover:underline truncate">
                  /coding/test/<%= t.uniqueLink %>
                </a>
                <button onclick="navigator.clipboard.writeText(window.location.origin + '/coding/test/<%= t.uniqueLink %>')" class="text-gray-400 hover:text-gray-700" title="Copy Link">
                  <span class="material-symbols-outlined" style="font-size:16px">content_copy</span>
                </button>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('create-test-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const codingBankId = document.getElementById('codingBankId').value;
      const validityHours = document.getElementById('validityHours').value;

      const res = await fetch('/api/coding/admin/test/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ codingBankId, validityHours })
      });
      if(res.ok) window.location.reload();
      else alert('Failed to create test link');
    });

    async function deleteTest(id) {
      if(confirm('Delete this test link? All student submissions will be lost forever.')) {
        const res = await fetch(`/api/coding/admin/test/${id}`, { method: 'DELETE' });
        if(res.ok) window.location.reload();
      }
    }
  </script>
</body>
</html>
