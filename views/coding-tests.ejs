<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Sessions | Admin</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

  <%- include('partials/tailwind-setup') %>
</head>
<body class="vc-admin flex h-screen overflow-hidden antialiased selection:bg-white/30">

  <%- include('partials/admin-sidebar', { activePage: 'coding-tests' }) %>

  <main class="flex-1 flex flex-col relative overflow-hidden bg-[#000]">
    <div class="absolute inset-0 grid-bg pointer-events-none z-0"></div>

    <header class="h-16 glass-nav flex items-center justify-between px-6 lg:px-10 shrink-0 z-10 relative">
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span class="text-gray-500 font-medium tracking-tight">Coding Section</span>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white font-medium">Coding Sessions</span>
      </div>
      
      <div class="hidden sm:flex items-center bg-white/5 border border-white/10 rounded-lg p-1 space-x-1">
        <a href="/admin/coding/banks" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Environments</a>
        <a href="/admin/coding/tests" class="bg-white/10 text-white shadow-sm px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Create</a>
        <a href="/admin/coding/tests/links" class="text-gray-400 hover:text-white hover:bg-white/5 px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Active Sessions</a>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto p-6 lg:p-10 relative z-10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-12 gap-8">
        
        <!-- Create Form (1/3) -->
        <div class="xl:col-span-4 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Create Session</h1>
            <p class="text-gray-400 font-light text-sm">Create a new coding session link.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <form id="createTestForm" class="space-y-5 relative z-10">
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Select Environment</label>
                <select id="bankId" required class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white appearance-none focus:bg-[#111] focus:border-white/30 transition-all outline-none">
                  <option value="" class="text-gray-500">-- Select Environment --</option>
                  <% banks.forEach(b => { %>
                    <option value="<%= b._id %>"><%= b.title %></option>
                  <% }); %>
                </select>
              </div>
              
              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Validity (Hours)</label>
                <input type="number" id="validityHours" min="1" max="720" value="24" required 
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none">
              </div>

              <div>
                <label class="block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2">Timer (Minutes)</label>
                <input type="number" id="durationMinutes" min="1" max="300" value="30" required
                  class="w-full px-4 py-3 bg-[#0a0a0a] border border-white/10 rounded-xl text-sm font-medium text-white focus:bg-[#111] focus:border-white/30 transition-all outline-none">
              </div>

              <button type="submit" class="w-full bg-white text-black hover:bg-gray-200 py-3 px-4 rounded-xl text-sm font-semibold transition-colors shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.98] flex justify-center items-center gap-2 mt-2">
                <span class="material-symbols-outlined text-[18px]">add_link</span> Create Session
              </button>
            </form>
          </div>
        </div>

        <!-- Quick Access (2/3) -->
        <div class="xl:col-span-8 space-y-6">
          <div>
            <h1 class="text-2xl font-semibold tracking-tight text-white mb-2">Manage Active Sessions</h1>
            <p class="text-gray-400 font-light text-sm">Open the dedicated page to view coding links and result actions.</p>
          </div>
          
          <div class="glass-card rounded-2xl p-8 md:p-10 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="relative z-10">
              <p class="text-xs uppercase tracking-[0.2em] text-gray-500 font-semibold">Coding Links</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white">Active Sessions</h2>
              <p class="mt-3 max-w-xl text-sm text-gray-400 leading-relaxed">
                View all created coding session links on a separate page with actions for copying links, deleting sessions, and opening results.
              </p>
              <a href="/admin/coding/tests/links" class="mt-6 inline-flex items-center gap-2 rounded-xl bg-white text-black hover:bg-gray-200 py-3 px-5 text-sm font-semibold transition-colors">
                Open Active Sessions
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <script>
    async function getErrorMessage(res, fallback) {
      try {
        const data = await res.json();
        return data.message || fallback;
      } catch (error) {
        return fallback;
      }
    }

    document.getElementById('createTestForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Processing...';
      btn.disabled = true;

      const b = document.getElementById('bankId').value;
      const v = document.getElementById('validityHours').value;
      const d = document.getElementById('durationMinutes').value;
      const res = await fetch('/api/coding/admin/tests', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ codingBankId: b, validityHours: v, durationMinutes: d }) });
      if(res.ok) window.location.reload(); 
      else { alert(await getErrorMessage(res, 'Error generating session link.')); btn.innerHTML = originalText; btn.disabled = false; }
    });

    async function deleteTest(id, button) {
      if(confirm('Are you sure you want to delete this session? This will remove all associated results.')) {
        if (button) button.disabled = true;
        const res = await fetch(`/api/coding/admin/tests/${id}`, { method: 'DELETE' });
        if(res.ok) window.location.reload();
        else {
          if (button) button.disabled = false;
          alert(await getErrorMessage(res, 'Failed to delete session.'));
        }
      }
    }
  </script>
</body>
</html>
